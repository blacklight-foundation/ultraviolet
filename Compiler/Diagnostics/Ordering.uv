// Obligation responsibility: Compiler/Diagnostics/Ordering.uv
//
// This file owns deterministic diagnostic-order predicates. Sorting is applied
// by the phase owner that has mutable collection authority; the predicates here
// define the stable comparison surface.

public procedure diagnosticCodeTextEquals(
    left: DiagnosticCode,
    right: string@View
) -> bool {
    return diagnosticTextEquals(left.text, right)
}

public procedure diagnosticTextEquals(left: string@View, right: string@View) -> bool {
    let left_length: usize = string::length(left)
    let right_length: usize = string::length(right)
    if (left_length != right_length) {
        return false
    }

    var index: usize = 0
    loop {
        if (index >= left_length) {
            break
        }

        if (diagnosticTextByte(left, index) != diagnosticTextByte(right, index)) {
            return false
        }

        index = index + 1
    }
    return true
}

internal procedure diagnosticTextByte(text: string@View, index: usize) -> u8
|: index < string::length(text)
{
    let view: bytes@View = bytes::view_string(text)
    let data: const [u8] = bytes::as_slice(view)
    return data[index]
}
