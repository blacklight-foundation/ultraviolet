// Obligation responsibility: Compiler/Diagnostics/Rendering.uv
//
// This file owns diagnostic text selected for command-surface reporting:
//
// - def.DiagnosticRender@L1778
//   Render(d) is the diagnostic head, optional message, and optional source
//   location.
// - def.DiagnosticRenderComponents@L1794
//   The plain head is either "code (severity)" or just "severity".

public procedure diagnosticSeverityText(
    severity: DiagnosticSeverityValue
) -> string@View {
    return if severity is {
        @Error {
            "error"
        }
        @Warning {
            "warning"
        }
        @Info {
            "info"
        }
        @Panic {
            "panic"
        }
        @Note {
            "note"
        }
    }
}

public procedure diagnosticMessage(diagnostic: Diagnostic) -> string@View {
    return diagnostic.message
}

public procedure diagnosticHasMessage(diagnostic: Diagnostic) -> bool {
    return !string::is_empty(diagnostic.message)
}

public procedure diagnosticHasSpan(diagnostic: Diagnostic) -> bool {
    return diagnosticSpanIsPresent(diagnostic.span)
}
