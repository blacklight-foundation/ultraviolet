// Obligation responsibility: Compiler/Project/RootDiscovery.uv
//
// This file owns command input path preparation and nearest-manifest project
// root search for project loading:
//
// - req.ProjectRootResolveInputPath@L2281
//   When project loading begins from one command-line input path `p`, the
//   implementation MUST first resolve any relative `p` against the host current
//   working directory before searching upward for `Ultraviolet.toml`.
// - req.ProjectRootFileInputStartsAtParent@L2296
//   If that resolved path denotes an existing non-directory, the upward search
//   MUST begin from its parent directory;
// - req.ProjectRootDirectoryInputStartsAtResolvedPath@L2310
//   otherwise the upward search MUST begin from the resolved path itself.
// - def.FindProjectRoot@L2324
//   `FindProjectRoot(p)` is the nearest searched directory `R` such that
//   `exists(R/`Ultraviolet.toml`)`; if no searched directory satisfies that
//   predicate, `FindProjectRoot(p)` is the search-start directory.
// - WF-Project-Root@L3491
//   exists(`Ultraviolet.toml` at R)
//   ───────────────────────────
//   ⊢ R : ProjectRoot

internal let ROOT_DISCOVERY_FORWARD_SEPARATOR: u8 = 47
internal let ROOT_DISCOVERY_BACK_SEPARATOR: u8 = 92
internal let ROOT_DISCOVERY_COLON: u8 = 58
internal let ROOT_DISCOVERY_UPPER_A: u8 = 65
internal let ROOT_DISCOVERY_UPPER_Z: u8 = 90
internal let ROOT_DISCOVERY_LOWER_A: u8 = 97
internal let ROOT_DISCOVERY_LOWER_Z: u8 = 122

public record CommandInputPath {
    public text: string@View
}

public record ResolvedInputPath {
    public text: string@View
}

public modal CommandInputPathResolution {
    @NeedsHostResolution {
        public current_directory: DirectoryPath
        public input: CommandInputPath

        public transition resolved(resolved_path: ResolvedInputPath) -> @Resolved {
            return CommandInputPathResolution@Resolved {
                resolved_path: resolved_path
            }
        }
    }

    @Resolved {
        public resolved_path: ResolvedInputPath
    }
}

public type CommandInputPathResolutionValue =
    CommandInputPathResolution@NeedsHostResolution |
    CommandInputPathResolution@Resolved

public modal ResolvedInputPathKind {
    @ExistingNonDirectory {
    }

    @DirectoryOrUnresolved {
    }
}

public type ResolvedInputPathKindValue =
    ResolvedInputPathKind@ExistingNonDirectory |
    ResolvedInputPathKind@DirectoryOrUnresolved

public record ProjectRootCandidate {
    public directory: DirectoryPath
    public manifest_exists: bool
}

public modal ProjectRootCandidateList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public candidate: ProjectRootCandidate
        public tail: ProjectRootCandidateListValue

        public procedure count(~) -> usize {
            return 1 + projectRootCandidateListCount(self.tail)
        }
    }
}

public type ProjectRootCandidateListValue =
    ProjectRootCandidateList@Empty | ProjectRootCandidateList@Entry

public modal ProjectRootSearch {
    @Searching {
        public start: DirectoryPath

        public transition found(root: ProjectRoot) -> @Found {
            return ProjectRootSearch@Found { root: root }
        }

        public transition searchStart() -> @SearchStart {
            return ProjectRootSearch@SearchStart {
                root: projectRoot(self.start.text)
            }
        }
    }

    @Found {
        public root: ProjectRoot
    }

    @SearchStart {
        public root: ProjectRoot
    }
}

public type ProjectRootSearchValue =
    ProjectRootSearch@Searching |
    ProjectRootSearch@Found |
    ProjectRootSearch@SearchStart

public procedure commandInputPath(text: string@View) -> CommandInputPath {
    return CommandInputPath { text: text }
}

public procedure resolvedInputPath(text: string@View) -> ResolvedInputPath {
    return ResolvedInputPath { text: text }
}

public procedure prepareCommandInputPathResolution(
    current_directory: DirectoryPath,
    input: CommandInputPath
) -> CommandInputPathResolutionValue {
    if (rootDiscoveryPathTextIsAbsolute(input.text)) {
        return CommandInputPathResolution@Resolved {
            resolved_path: resolvedInputPath(input.text)
        }
    }

    return CommandInputPathResolution@NeedsHostResolution {
        current_directory: current_directory,
        input: input
    }
}

public procedure completeCommandInputPathResolution(
    resolution: CommandInputPathResolutionValue,
    resolved_path: ResolvedInputPath
) -> CommandInputPathResolutionValue {
    return if resolution is {
        @NeedsHostResolution { current_directory, input } {
            CommandInputPathResolution@Resolved {
                resolved_path: resolved_path
            }
        }
        @Resolved {
            resolution
        }
    }
}

public procedure commandInputPathResolutionIsResolved(
    resolution: CommandInputPathResolutionValue
) -> bool {
    return if resolution is {
        @NeedsHostResolution {
            false
        }
        @Resolved {
            true
        }
    }
}

public procedure existingNonDirectoryInputPath() -> ResolvedInputPathKindValue {
    return ResolvedInputPathKind@ExistingNonDirectory {}
}

public procedure directoryOrUnresolvedInputPath() -> ResolvedInputPathKindValue {
    return ResolvedInputPathKind@DirectoryOrUnresolved {}
}

public procedure projectRootSearchStart(
    resolved_path: ResolvedInputPath,
    path_kind: ResolvedInputPathKindValue
) -> DirectoryPath {
    return if path_kind is {
        @ExistingNonDirectory {
            parentDirectoryOfResolvedInput(resolved_path)
        }
        @DirectoryOrUnresolved {
            directoryPath(resolved_path.text)
        }
    }
}

public procedure projectRootCandidate(
    directory: DirectoryPath,
    manifest_exists: bool
) -> ProjectRootCandidate {
    return ProjectRootCandidate {
        directory: directory,
        manifest_exists: manifest_exists
    }
}

public procedure projectRootCandidateHasManifest(candidate: ProjectRootCandidate) -> bool {
    return candidate.manifest_exists
}

public procedure projectRootCandidateIsWellFormed(candidate: ProjectRootCandidate) -> bool {
    return candidate.manifest_exists
}

public procedure emptyProjectRootCandidates() -> ProjectRootCandidateListValue {
    return ProjectRootCandidateList@Empty {}
}

public procedure projectRootCandidateListEntry(
    candidate: ProjectRootCandidate,
    move tail: ProjectRootCandidateListValue
) -> ProjectRootCandidateListValue {
    return ProjectRootCandidateList@Entry {
        candidate: candidate,
        tail: move tail
    }
}

public procedure projectRootCandidateListCount(
    candidates: ProjectRootCandidateListValue
) -> usize {
    return if candidates is {
        @Empty {
            candidates~>count()
        }
        @Entry {
            candidates~>count()
        }
    }
}

public procedure searchingProjectRoot(start: DirectoryPath) -> ProjectRootSearchValue {
    return ProjectRootSearch@Searching { start: start }
}

public procedure foundProjectRoot(root: ProjectRoot) -> ProjectRootSearchValue {
    return ProjectRootSearch@Found { root: root }
}

public procedure searchStartProjectRoot(root: ProjectRoot) -> ProjectRootSearchValue {
    return ProjectRootSearch@SearchStart { root: root }
}

public procedure findProjectRoot(
    start: DirectoryPath,
    candidates: ProjectRootCandidateListValue
) -> ProjectRootSearchValue {
    return findProjectRootFromSearch(searchingProjectRoot(start), candidates)
}

public procedure projectRootSearchRoot(search: ProjectRootSearchValue) -> ProjectRoot {
    return if search is {
        @Searching { start } {
            projectRoot(start.text)
        }
        @Found { root } {
            root
        }
        @SearchStart { root } {
            root
        }
    }
}

public procedure projectRootSearchUsedManifest(search: ProjectRootSearchValue) -> bool {
    return if search is {
        @Searching {
            false
        }
        @Found {
            true
        }
        @SearchStart {
            false
        }
    }
}

internal procedure findProjectRootFromSearch(
    search: ProjectRootSearchValue,
    candidates: ProjectRootCandidateListValue
) -> ProjectRootSearchValue {
    return if search is {
        @Searching {
            findProjectRootCandidates(search, candidates)
        }
        @Found {
            search
        }
        @SearchStart {
            search
        }
    }
}

internal procedure findProjectRootCandidates(
    search: ProjectRootSearch@Searching,
    candidates: ProjectRootCandidateListValue
) -> ProjectRootSearchValue {
    return if candidates is {
        @Empty {
            ProjectRootSearch@SearchStart {
                root: projectRoot(search.start.text)
            }
        }
        @Entry { candidate, tail } {
            if (candidate.manifest_exists) {
                ProjectRootSearch@Found {
                    root: projectRoot(candidate.directory.text)
                }
            } else {
                findProjectRootCandidates(search, tail)
            }
        }
    }
}

internal procedure parentDirectoryOfResolvedInput(
    resolved_path: ResolvedInputPath
) -> DirectoryPath {
    let parent_end: usize = rootDiscoveryParentDirectoryEnd(resolved_path.text)
    return directoryPath(string::slice(resolved_path.text, 0, parent_end))
}

internal procedure rootDiscoveryParentDirectoryEnd(text: string@View) -> usize {
    let length: usize = string::length(text)
    if (length == 0) {
        return 0
    }

    var index: usize = 0
    var parent_end: usize = length
    var found_separator: bool = false

    loop {
        if (index >= length) {
            break
        }

        if (rootDiscoveryByteIsSeparator(rootDiscoveryTextByte(text, index))) {
            found_separator = true
            if (index == 0) {
                parent_end = 1
            } else if (rootDiscoverySeparatorIsDriveRoot(text, index)) {
                parent_end = index + 1
            } else {
                parent_end = index
            }
        }

        index = index + 1
    }

    if (found_separator) {
        return parent_end
    }
    return length
}

internal procedure rootDiscoveryPathTextIsAbsolute(text: string@View) -> bool {
    return rootDiscoveryPathTextIsDriveRooted(text) ||
        rootDiscoveryPathTextIsRootRelative(text) ||
        rootDiscoveryPathTextIsUNC(text)
}

internal procedure rootDiscoveryPathTextIsDriveRooted(text: string@View) -> bool {
    if (string::length(text) < 3) {
        return false
    }

    return rootDiscoveryByteIsAsciiLetter(rootDiscoveryTextByte(text, 0)) &&
        rootDiscoveryTextByte(text, 1) == ROOT_DISCOVERY_COLON &&
        rootDiscoveryByteIsSeparator(rootDiscoveryTextByte(text, 2))
}

internal procedure rootDiscoveryPathTextIsRootRelative(text: string@View) -> bool {
    if (string::length(text) < 1) {
        return false
    }
    if (rootDiscoveryPathTextIsUNC(text)) {
        return false
    }
    return rootDiscoveryByteIsSeparator(rootDiscoveryTextByte(text, 0))
}

internal procedure rootDiscoveryPathTextIsUNC(text: string@View) -> bool {
    if (string::length(text) < 2) {
        return false
    }
    return rootDiscoveryTextByte(text, 0) == ROOT_DISCOVERY_BACK_SEPARATOR &&
        rootDiscoveryTextByte(text, 1) == ROOT_DISCOVERY_BACK_SEPARATOR
}

internal procedure rootDiscoverySeparatorIsDriveRoot(
    text: string@View,
    separator_index: usize
) -> bool
|: separator_index < string::length(text)
{
    if (separator_index != 2) {
        return false
    }
    if (string::length(text) < 3) {
        return false
    }
    if (!rootDiscoveryByteIsAsciiLetter(rootDiscoveryTextByte(text, 0))) {
        return false
    }
    return rootDiscoveryTextByte(text, 1) == ROOT_DISCOVERY_COLON
}

internal procedure rootDiscoveryByteIsSeparator(value: u8) -> bool {
    return value == ROOT_DISCOVERY_FORWARD_SEPARATOR ||
        value == ROOT_DISCOVERY_BACK_SEPARATOR
}

internal procedure rootDiscoveryByteIsAsciiLetter(value: u8) -> bool {
    return (value >= ROOT_DISCOVERY_UPPER_A && value <= ROOT_DISCOVERY_UPPER_Z) ||
        (value >= ROOT_DISCOVERY_LOWER_A && value <= ROOT_DISCOVERY_LOWER_Z)
}

internal procedure rootDiscoveryTextByte(text: string@View, index: usize) -> u8
|: index < string::length(text)
{
    let view: bytes@View = bytes::view_string(text)
    let data: const [u8] = bytes::as_slice(view)
    return data[index]
}
