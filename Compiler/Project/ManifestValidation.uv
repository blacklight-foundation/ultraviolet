using UltravioletCompiler::Diagnostics::{
    DiagnosticStreamValue,
    singleErrorDiagnosticStream
}

internal let MANIFEST_KIND_EXECUTABLE: string@View = "executable"
internal let MANIFEST_KIND_LIBRARY: string@View = "library"
internal let MANIFEST_KIND_DEPENDENCY: string@View = "dependency"
internal let MANIFEST_LINK_KIND_STATIC: string@View = "static"
internal let MANIFEST_LINK_KIND_SHARED: string@View = "shared"
internal let MANIFEST_EMIT_IR_NONE: string@View = "none"
internal let MANIFEST_EMIT_IR_LL: string@View = "ll"
internal let MANIFEST_EMIT_IR_BC: string@View = "bc"
internal let MANIFEST_EMPTY: string@View = ""
internal let MANIFEST_SLASH: u8 = 47
internal let MANIFEST_BACKSLASH: u8 = 92
internal let MANIFEST_COLON: u8 = 58
internal let MANIFEST_DOT: u8 = 46
internal let MANIFEST_UNDERSCORE: u8 = 95

public modal ManifestValidation {
    @Valid {
        public manifest: Manifest
    }

    @Invalid {
        public diagnostics: DiagnosticStreamValue
    }
}

public type ManifestValidationValue =
    ManifestValidation@Valid | ManifestValidation@Invalid

internal modal ManifestAssemblyValidation {
    @Valid {
    }

    @Invalid {
        internal diagnostics: DiagnosticStreamValue
    }
}

internal type ManifestAssemblyValidationValue =
    ManifestAssemblyValidation@Valid | ManifestAssemblyValidation@Invalid

internal modal ManifestLinkKindValidation {
    @Valid {
    }

    @InvalidValue {
    }

    @InvalidUse {
    }
}

internal type ManifestLinkKindValidationValue =
    ManifestLinkKindValidation@Valid |
    ManifestLinkKindValidation@InvalidValue |
    ManifestLinkKindValidation@InvalidUse

public procedure validateManifest(move manifest: Manifest) -> ManifestValidationValue {
    if (manifest.has_unknown_top_key) {
        return invalidManifest(
            singleErrorDiagnosticStream("E-PRJ-0101", "unknown manifest top-level key")
        )
    }
    if (manifestAssemblyListCount(manifest.assemblies) == 0) {
        return invalidManifest(
            singleErrorDiagnosticStream("E-PRJ-0103", "missing assembly table")
        )
    }
    if (manifestAssemblyNamesHaveDuplicates(manifest.assemblies)) {
        return invalidManifest(
            singleErrorDiagnosticStream("E-PRJ-0202", "duplicate assembly name")
        )
    }
    let assembly_validation: ManifestAssemblyValidationValue =
        validateManifestAssemblyList(manifest.assemblies)
    return if assembly_validation is {
        @Invalid { diagnostics } {
            invalidManifest(move diagnostics)
        }
        @Valid {
            validManifest(move manifest)
        }
    }
}

internal procedure validateManifestAssemblyList(
    assemblies: ManifestAssemblyListValue
) -> ManifestAssemblyValidationValue {
    return if assemblies is {
        @Empty {
            validManifestAssemblyList()
        }
        @Entry { assembly: manifest_assembly, tail } {
            if (manifest_assembly.has_unknown_key) {
                invalidManifestAssemblyList(
                    singleErrorDiagnosticStream(
                        "E-PRJ-0203",
                        "unknown assembly key"
                    )
                )
            } else if (!manifestAssemblyHasRequiredFields(manifest_assembly)) {
                invalidManifestAssemblyList(
                    singleErrorDiagnosticStream(
                        "E-PRJ-0204",
                        "missing required assembly field"
                    )
                )
            } else if (!manifestAssemblyNameIsValid(manifest_assembly.name)) {
                invalidManifestAssemblyList(
                    singleErrorDiagnosticStream(
                        "E-PRJ-0205",
                        "invalid assembly name"
                    )
                )
            } else if (!manifestAssemblyKindIsValid(manifest_assembly.kind)) {
                invalidManifestAssemblyList(
                    singleErrorDiagnosticStream(
                        "E-PRJ-0201",
                        "invalid assembly kind"
                    )
                )
            } else {
                let link_validation: ManifestLinkKindValidationValue =
                    validateManifestAssemblyLinkKind(manifest_assembly)
                if link_validation is {
                    @Valid {
                        if (!manifestAssemblyEmitIRIsValid(manifest_assembly.emit_ir)) {
                            invalidManifestAssemblyList(
                                singleErrorDiagnosticStream(
                                    "E-PRJ-0209",
                                    "invalid assembly emit_ir"
                                )
                            )
                        } else if (!manifestAssemblyRootPathIsValid(manifest_assembly.root)) {
                            invalidManifestAssemblyList(
                                singleErrorDiagnosticStream(
                                    "E-PRJ-0210",
                                    "invalid assembly root path"
                                )
                            )
                        } else if (!manifestAssemblyOutDirPathIsValid(
                            manifest_assembly.out_dir
                        )) {
                            invalidManifestAssemblyList(
                                singleErrorDiagnosticStream(
                                    "E-PRJ-0211",
                                    "invalid assembly output directory path"
                                )
                            )
                        } else {
                            validateManifestAssemblyList(tail)
                        }
                    }
                    @InvalidValue {
                        invalidManifestAssemblyList(
                            singleErrorDiagnosticStream(
                                "E-PRJ-0207",
                                "invalid assembly link kind"
                            )
                        )
                    }
                    @InvalidUse {
                        invalidManifestAssemblyList(
                            singleErrorDiagnosticStream(
                                "E-PRJ-0208",
                                "assembly link kind is only valid for libraries"
                            )
                        )
                    }
                }
            }
        }
    }
}

public procedure validManifest(move manifest: Manifest) -> ManifestValidationValue {
    return ManifestValidation@Valid { manifest: move manifest }
}

public procedure invalidManifest(
    move diagnostics: DiagnosticStreamValue
) -> ManifestValidationValue {
    return ManifestValidation@Invalid { diagnostics: move diagnostics }
}

internal procedure validManifestAssemblyList() -> ManifestAssemblyValidationValue {
    return ManifestAssemblyValidation@Valid {}
}

internal procedure invalidManifestAssemblyList(
    move diagnostics: DiagnosticStreamValue
) -> ManifestAssemblyValidationValue {
    return ManifestAssemblyValidation@Invalid { diagnostics: move diagnostics }
}

public procedure manifestAssemblyKindIsValid(kind: string@View) -> bool {
    return projectTextEquals(kind, MANIFEST_KIND_EXECUTABLE) ||
        projectTextEquals(kind, MANIFEST_KIND_LIBRARY) ||
        projectTextEquals(kind, MANIFEST_KIND_DEPENDENCY)
}

public procedure manifestAssemblyHasRequiredFields(
    assembly: ManifestAssembly
) -> bool {
    return !projectTextEquals(assembly.name, MANIFEST_EMPTY) &&
        !projectTextEquals(assembly.kind, MANIFEST_EMPTY) &&
        !projectTextEquals(assembly.root, MANIFEST_EMPTY)
}

public procedure manifestAssemblyNameIsValid(name: string@View) -> bool {
    if (projectTextEquals(name, MANIFEST_EMPTY)) {
        return false
    }
    if (manifestAssemblyNameIsKeyword(name)) {
        return false
    }

    let length: usize = string::length(name)
    if (!manifestIdentifierStartByte(manifestTextByteOrZero(name, 0))) {
        return false
    }

    var index: usize = 1
    loop {
        if (index >= length) {
            break
        }
        if (!manifestIdentifierContinueByte(manifestTextByteOrZero(name, index))) {
            return false
        }
        index = index + 1
    }

    return true
}

internal procedure manifestAssemblyNameIsKeyword(name: string@View) -> bool {
    return projectTextEquals(name, "as") ||
        projectTextEquals(name, "async") ||
        projectTextEquals(name, "await") ||
        projectTextEquals(name, "break") ||
        projectTextEquals(name, "class") ||
        projectTextEquals(name, "const") ||
        projectTextEquals(name, "continue") ||
        projectTextEquals(name, "else") ||
        projectTextEquals(name, "enum") ||
        projectTextEquals(name, "extern") ||
        projectTextEquals(name, "false") ||
        projectTextEquals(name, "for") ||
        projectTextEquals(name, "if") ||
        projectTextEquals(name, "import") ||
        projectTextEquals(name, "internal") ||
        projectTextEquals(name, "let") ||
        projectTextEquals(name, "loop") ||
        projectTextEquals(name, "modal") ||
        projectTextEquals(name, "move") ||
        projectTextEquals(name, "private") ||
        projectTextEquals(name, "procedure") ||
        projectTextEquals(name, "public") ||
        projectTextEquals(name, "record") ||
        projectTextEquals(name, "region") ||
        projectTextEquals(name, "return") ||
        projectTextEquals(name, "shared") ||
        projectTextEquals(name, "true") ||
        projectTextEquals(name, "type") ||
        projectTextEquals(name, "unique") ||
        projectTextEquals(name, "unsafe") ||
        projectTextEquals(name, "using") ||
        projectTextEquals(name, "var") ||
        projectTextEquals(name, "while")
}

internal procedure manifestIdentifierStartByte(value: u8) -> bool {
    return manifestAsciiLowercase(value) ||
        manifestAsciiUppercase(value) ||
        value == MANIFEST_UNDERSCORE
}

internal procedure manifestIdentifierContinueByte(value: u8) -> bool {
    return manifestIdentifierStartByte(value) || manifestAsciiDigit(value)
}

internal procedure manifestAsciiLowercase(value: u8) -> bool {
    return value >= 97 && value <= 122
}

internal procedure manifestAsciiUppercase(value: u8) -> bool {
    return value >= 65 && value <= 90
}

internal procedure manifestAsciiDigit(value: u8) -> bool {
    return value >= 48 && value <= 57
}

internal procedure validateManifestAssemblyLinkKind(
    assembly: ManifestAssembly
) -> ManifestLinkKindValidationValue {
    if (projectTextEquals(assembly.kind, MANIFEST_KIND_LIBRARY)) {
        if (projectTextEquals(assembly.link_kind, MANIFEST_EMPTY) ||
            projectTextEquals(assembly.link_kind, MANIFEST_LINK_KIND_STATIC) ||
            projectTextEquals(assembly.link_kind, MANIFEST_LINK_KIND_SHARED)) {
            return ManifestLinkKindValidation@Valid {}
        }
        return ManifestLinkKindValidation@InvalidValue {}
    }
    if (projectTextEquals(assembly.link_kind, MANIFEST_EMPTY)) {
        return ManifestLinkKindValidation@Valid {}
    }
    return ManifestLinkKindValidation@InvalidUse {}
}

public procedure manifestAssemblyLinkKindIsValid(assembly: ManifestAssembly) -> bool {
    let validation: ManifestLinkKindValidationValue =
        validateManifestAssemblyLinkKind(assembly)
    return if validation is {
        @Valid {
            true
        }
        @InvalidValue {
            false
        }
        @InvalidUse {
            false
        }
    }
}

public procedure manifestAssemblyEmitIRIsValid(value: string@View) -> bool {
    return projectTextEquals(value, MANIFEST_EMPTY) ||
        projectTextEquals(value, MANIFEST_EMIT_IR_NONE) ||
        projectTextEquals(value, MANIFEST_EMIT_IR_LL) ||
        projectTextEquals(value, MANIFEST_EMIT_IR_BC)
}

public procedure manifestAssemblyRootPathIsValid(value: string@View) -> bool {
    return !projectTextEquals(value, MANIFEST_EMPTY) && manifestPathIsRelative(value)
}

public procedure manifestAssemblyOutDirPathIsValid(value: string@View) -> bool {
    return projectTextEquals(value, MANIFEST_EMPTY) || manifestPathIsRelative(value)
}

internal procedure manifestPathIsRelative(value: string@View) -> bool {
    let length: usize = string::length(value)
    if (length == 0) {
        return false
    }
    if (manifestTextByteOrZero(value, 0) == MANIFEST_SLASH ||
        manifestTextByteOrZero(value, 0) == MANIFEST_BACKSLASH) {
        return false
    }
    if (length >= 2 && manifestTextByteOrZero(value, 1) == MANIFEST_COLON) {
        return false
    }
    return !manifestPathContainsParentTraversal(value)
}

internal procedure manifestPathContainsParentTraversal(value: string@View) -> bool {
    let length: usize = string::length(value)
    var segment_start: usize = 0

    loop {
        if (segment_start >= length) {
            break
        }
        let segment_end: usize = manifestPathSegmentEnd(value, segment_start)
        if (manifestPathSegmentIsParent(value, segment_start, segment_end)) {
            return true
        }
        segment_start = segment_end + 1
    }

    return false
}

internal procedure manifestPathSegmentEnd(
    value: string@View,
    start: usize
) -> usize {
    let length: usize = string::length(value)
    var index: usize = start
    loop {
        if (index >= length) {
            break
        }
        let byte: u8 = manifestTextByteOrZero(value, index)
        if (byte == MANIFEST_SLASH || byte == MANIFEST_BACKSLASH) {
            break
        }
        index = index + 1
    }
    return index
}

internal procedure manifestPathSegmentIsParent(
    value: string@View,
    start: usize,
    end: usize
) -> bool {
    if (end != start + 2) {
        return false
    }
    return projectTextSegmentEquals(value, start, "..")
}

internal procedure manifestTextByteOrZero(text: string@View, index: usize) -> u8 {
    if (index >= string::length(text)) {
        return 0
    }
    return projectTextByte(text, index)
}

public procedure manifestAssemblyNamesHaveDuplicates(
    assemblies: ManifestAssemblyListValue
) -> bool {
    return if assemblies is {
        @Empty {
            false
        }
        @Entry { assembly: manifest_assembly, tail } {
            if (manifestAssemblyListContainsName(tail, manifest_assembly.name)) {
                true
            } else {
                manifestAssemblyNamesHaveDuplicates(tail)
            }
        }
    }
}

internal procedure manifestAssemblyListContainsName(
    assemblies: ManifestAssemblyListValue,
    name: string@View
) -> bool {
    return if assemblies is {
        @Empty {
            false
        }
        @Entry { assembly: manifest_assembly, tail } {
            if (projectTextEquals(manifest_assembly.name, name)) {
                true
            } else {
                manifestAssemblyListContainsName(tail, name)
            }
        }
    }
}
