// Test responsibility: Compiler/Tests/Diagnostics/TestAttributes/DiagnosticsTestAttributesTests.uv
//
// This file owns source-native tests for diagnostics.TestAttributes@L28593:
//
// Source-native test attributes emit E-MOD-2452 and E-TST-0101 through
// E-TST-0108 for the diagnostic conditions listed in SPECIFICATION.md §9.6.7.

using UltravioletCompiler::Diagnostics::{
    CODE_TEST_ATTRIBUTE_WRONG_TARGET,
    CODE_TEST_DUPLICATE_NAME,
    CODE_TEST_INVALID_CONTEXT_PARAMETER,
    CODE_TEST_INVALID_PROCEDURE_SHAPE,
    CODE_TEST_MALFORMED_ARGUMENT,
    CODE_TEST_MALFORMED_COVERAGE,
    CODE_TEST_MISSING_POSTCONDITION,
    CODE_TEST_UNKNOWN_COVERAGE_REFERENCE,
    CODE_TEST_UNKNOWN_TARGET,
    Diagnostic,
    diagnosticHasCode,
    unknownCoverageReferenceDiagnostic,
    unknownTestTargetDiagnostic
}
using UltravioletCompiler::Project::{ projectTextEquals }

[[test(
    name: "test attribute diagnostic codes are canonical",
    covers("diagnostics.TestAttributes@L28593")
)]]
internal procedure testAttributeDiagnosticCodesAreCanonical() -> bool
|: => @result
{
    return projectTextEquals(CODE_TEST_ATTRIBUTE_WRONG_TARGET, "E-MOD-2452") &&
        projectTextEquals(CODE_TEST_MALFORMED_ARGUMENT, "E-TST-0101") &&
        projectTextEquals(CODE_TEST_DUPLICATE_NAME, "E-TST-0102") &&
        projectTextEquals(CODE_TEST_MALFORMED_COVERAGE, "E-TST-0103") &&
        projectTextEquals(CODE_TEST_INVALID_PROCEDURE_SHAPE, "E-TST-0104") &&
        projectTextEquals(CODE_TEST_INVALID_CONTEXT_PARAMETER, "E-TST-0105") &&
        projectTextEquals(CODE_TEST_MISSING_POSTCONDITION, "E-TST-0106") &&
        projectTextEquals(CODE_TEST_UNKNOWN_COVERAGE_REFERENCE, "E-TST-0107") &&
        projectTextEquals(CODE_TEST_UNKNOWN_TARGET, "E-TST-0108")
}

[[test(
    name: "test attribute diagnostic helpers emit canonical codes",
    covers("diagnostics.TestAttributes@L28593")
)]]
internal procedure testAttributeDiagnosticHelpersEmitCanonicalCodes() -> bool
|: => @result
{
    let target: Diagnostic = unknownTestTargetDiagnostic("missing")
    let coverage: Diagnostic =
        unknownCoverageReferenceDiagnostic("missing.Obligation@L1")
    return diagnosticHasCode(target, CODE_TEST_UNKNOWN_TARGET) &&
        diagnosticHasCode(coverage, CODE_TEST_UNKNOWN_COVERAGE_REFERENCE)
}
