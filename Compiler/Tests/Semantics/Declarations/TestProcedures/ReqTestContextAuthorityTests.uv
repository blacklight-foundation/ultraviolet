// Test responsibility: Compiler/Tests/Semantics/Declarations/TestProcedures/ReqTestContextAuthorityTests.uv
//
// This file owns source-native tests for req.TestContextAuthority@L28477:
//
// `TestContext` is the only runner-injected value and carries io,
// process, temporary-directory, target-profile, and compiler-invocation
// authority.

[[test(
    name: "parameterless test procedure requires no injected context",
    covers("req.TestContextAuthority@L28477")
)]]
internal procedure parameterlessTestProcedureRequiresNoInjectedContext() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let check: TestProcedureShapeCheckValue =
            checkTestProcedureShape(
                diagnostics_region,
                validTestProcedureDeclaration(noTestProcedureParameters())
            )
        passed = if check is {
            @Valid { requires_context } {
                !requires_context
            }
            @Invalid {
                false
            }
        }
    }
    return passed
}

[[test(
    name: "TestContext parameter is the runner-injected authority",
    covers("req.TestContextAuthority@L28477")
)]]
internal procedure testContextParameterIsRunnerInjectedAuthority() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let check: TestProcedureShapeCheckValue =
            checkTestProcedureShape(
                diagnostics_region,
                validTestProcedureDeclaration(testContextProcedureParameter())
            )
        passed = if check is {
            @Valid { requires_context } {
                requires_context
            }
            @Invalid {
                false
            }
        }
    }
    return passed
}

[[test(
    name: "non-TestContext parameter is rejected for source-native test",
    covers("req.TestContextAuthority@L28477")
)]]
internal procedure nonTestContextParameterIsRejectedForSourceNativeTest() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let check: TestProcedureShapeCheckValue =
            checkTestProcedureShape(
                diagnostics_region,
                validTestProcedureDeclaration(invalidTestProcedureParameter())
            )
        passed = if check is {
            @Valid {
                false
            }
            @Invalid {
                true
            }
        }
    }
    return passed
}
