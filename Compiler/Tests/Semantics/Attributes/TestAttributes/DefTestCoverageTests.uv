// Test responsibility: Compiler/Tests/Semantics/Attributes/TestAttributes/DefTestCoverageTests.uv
//
// This file owns source-native tests for def.TestCoverage@L28404:
//
// TestCoverage(proc) is the source-ordered list of string arguments from
// `covers(r_i)` entries.

[[test(
    name: "test coverage preserves source-order coverage references",
    covers("def.TestCoverage@L28404")
)]]
internal procedure testCoveragePreservesSourceOrderCoverageReferences() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let check: TestAttributeArgumentCheckValue =
            checkTestAttributeArguments(
                diagnostics_region,
                testAttributeArguments2(
                    testCoverageAttributeArgument("def.TestCoverage@L28404"),
                    testCoverageAttributeArgument("def.TestAttributeArgsOk@L28435")
                ),
                "UltravioletCompiler::Tests::Example::coverage"
            )
        passed = if check is {
            @Accepted { coverage_references } {
                coverageReferenceListCount(coverage_references) == 2 &&
                    coverageReferencesMatchSourceOrder(coverage_references)
            }
            @Rejected {
                false
            }
        }
    }
    return passed
}

internal procedure coverageReferencesMatchSourceOrder(
    references: CoverageReferenceListValue
) -> bool {
    return if references is {
        @Empty {
            false
        }
        @Entry { reference, tail } {
            if (!projectTextEquals(reference.text, "def.TestCoverage@L28404")) {
                return false
            }
            return if tail is {
                @Empty {
                    false
                }
                @Entry { reference: second_reference, tail: final_tail } {
                    if (!projectTextEquals(
                        second_reference.text,
                        "def.TestAttributeArgsOk@L28435"
                    )) {
                        return false
                    }
                    return if final_tail is {
                        @Empty {
                            true
                        }
                        @Entry {
                            false
                        }
                    }
                }
            }
        }
    }
}
