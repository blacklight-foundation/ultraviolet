// Test responsibility: Compiler/Tests/Semantics/Attributes/TestAttributes/DefTestNameTests.uv
//
// This file owns source-native tests for def.TestName@L28389:
//
// TestName(proc) is the unique `name: s` argument when present, otherwise the
// fully-qualified procedure path.

[[test(
    name: "test name defaults to fully-qualified procedure path",
    covers("def.TestName@L28389")
)]]
internal procedure testNameDefaultsToFullyQualifiedProcedurePath() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let check: TestAttributeArgumentCheckValue =
            checkTestAttributeArguments(
                diagnostics_region,
                emptyAttributeArguments(),
                "UltravioletCompiler::Tests::Example::defaultName"
            )
        passed = if check is {
            @Accepted { display_name } {
                projectTextEquals(
                    display_name.text,
                    "UltravioletCompiler::Tests::Example::defaultName"
                )
            }
            @Rejected {
                false
            }
        }
    }
    return passed
}

[[test(
    name: "test name uses explicit name argument",
    covers("def.TestName@L28389")
)]]
internal procedure testNameUsesExplicitNameArgument() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let check: TestAttributeArgumentCheckValue =
            checkTestAttributeArguments(
                diagnostics_region,
                singleTestNameArgument("display label"),
                "UltravioletCompiler::Tests::Example::explicitName"
            )
        passed = if check is {
            @Accepted { display_name } {
                projectTextEquals(display_name.text, "display label")
            }
            @Rejected {
                false
            }
        }
    }
    return passed
}
