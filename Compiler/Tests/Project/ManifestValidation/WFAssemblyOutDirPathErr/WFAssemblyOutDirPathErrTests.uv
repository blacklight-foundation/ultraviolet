// Test responsibility:
// Compiler/Tests/Project/ManifestValidation/WFAssemblyOutDirPathErr/WFAssemblyOutDirPathErrTests.uv
//
// This file owns source-native tests for WF-Assembly-OutDir-Path-Err@L2484.

using UltravioletCompiler::Project::{ manifestAssemblyOutDirPathIsValid }

[[test(
    name: "manifest validation rejects absolute or escaping output directories",
    covers("WF-Assembly-OutDir-Path-Err@L2484")
)]]
internal procedure manifestValidationRejectsAbsoluteOrEscapingOutputDirs() -> bool
|: => @result
{
    return !manifestAssemblyOutDirPathIsValid("/build") &&
        !manifestAssemblyOutDirPathIsValid("D:/build") &&
        !manifestAssemblyOutDirPathIsValid("Artifacts/../build")
}
