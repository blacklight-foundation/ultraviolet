// Test responsibility:
// Compiler/Tests/Project/ManifestValidation/WFAssemblyOutDirPath/WFAssemblyOutDirPathTests.uv
//
// This file owns source-native tests for WF-Assembly-OutDir-Path@L2466.

using UltravioletCompiler::Project::{ manifestAssemblyOutDirPathIsValid }

[[test(
    name: "manifest validation accepts absent or relative output directories",
    covers("WF-Assembly-OutDir-Path@L2466")
)]]
internal procedure manifestValidationAcceptsAbsentOrRelativeOutputDirs() -> bool
|: => @result
{
    return manifestAssemblyOutDirPathIsValid("") &&
        manifestAssemblyOutDirPathIsValid("build") &&
        manifestAssemblyOutDirPathIsValid("Artifacts/Compiler")
}
