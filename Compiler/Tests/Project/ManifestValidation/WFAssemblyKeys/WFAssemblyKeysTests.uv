// Test responsibility:
// Compiler/Tests/Project/ManifestValidation/WFAssemblyKeys/WFAssemblyKeysTests.uv
//
// This file owns source-native tests for WF-Assembly-Keys@L2748.

using UltravioletCompiler::Project::{
    ManifestValidationValue,
    emptyManifestAssemblies,
    manifest,
    manifestAssembly,
    manifestAssemblyListEntry,
    validateManifest
}

[[test(
    name: "manifest validation accepts known assembly keys",
    covers("WF-Assembly-Keys@L2748")
)]]
internal procedure manifestValidationAcceptsKnownAssemblyKeys() -> bool
|: => @result
{
    let validation: ManifestValidationValue = validateManifest(
        manifest(
            manifestAssemblyListEntry(
                manifestAssembly("App", "executable", "", "Tools/Uv"),
                emptyManifestAssemblies()
            )
        )
    )

    return manifestValidationIsValid(validation)
}

internal procedure manifestValidationIsValid(
    validation: ManifestValidationValue
) -> bool {
    return if validation is {
        @Valid {
            true
        }
        @Invalid {
            false
        }
    }
}
