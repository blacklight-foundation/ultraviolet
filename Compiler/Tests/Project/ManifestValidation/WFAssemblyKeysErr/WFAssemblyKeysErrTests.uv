// Test responsibility:
// Compiler/Tests/Project/ManifestValidation/WFAssemblyKeysErr/WFAssemblyKeysErrTests.uv
//
// This file owns source-native tests for WF-Assembly-Keys-Err@L2766.

using UltravioletCompiler::Project::{
    ManifestAssembly,
    ManifestValidationValue,
    emptyManifestAssemblies,
    manifest,
    manifestAssembly,
    manifestAssemblyListEntry,
    manifestAssemblyWithUnknownKey,
    validateManifest
}

[[test(
    name: "manifest validation rejects unknown assembly keys",
    covers("WF-Assembly-Keys-Err@L2766")
)]]
internal procedure manifestValidationRejectsUnknownAssemblyKeys() -> bool
|: => @result
{
    let manifest_assembly: ManifestAssembly =
        manifestAssemblyWithUnknownKey(
            manifestAssembly("App", "executable", "", "Tools/Uv")
        )
    let validation: ManifestValidationValue = validateManifest(
        manifest(
            manifestAssemblyListEntry(
                manifest_assembly,
                emptyManifestAssemblies()
            )
        )
    )

    return manifestValidationIsInvalid(validation)
}

internal procedure manifestValidationIsInvalid(
    validation: ManifestValidationValue
) -> bool {
    return if validation is {
        @Valid {
            false
        }
        @Invalid {
            true
        }
    }
}
