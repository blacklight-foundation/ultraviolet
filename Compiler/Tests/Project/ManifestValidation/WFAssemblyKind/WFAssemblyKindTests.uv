// Test responsibility:
// Compiler/Tests/Project/ManifestValidation/WFAssemblyKind/WFAssemblyKindTests.uv
//
// This file owns source-native tests for WF-Assembly-Kind@L2394.

using UltravioletCompiler::Project::{ manifestAssemblyKindIsValid }

[[test(
    name: "manifest validation accepts declared assembly kinds",
    covers("WF-Assembly-Kind@L2394")
)]]
internal procedure manifestValidationAcceptsDeclaredAssemblyKinds() -> bool
|: => @result
{
    return manifestAssemblyKindIsValid("executable") &&
        manifestAssemblyKindIsValid("library") &&
        manifestAssemblyKindIsValid("dependency")
}
