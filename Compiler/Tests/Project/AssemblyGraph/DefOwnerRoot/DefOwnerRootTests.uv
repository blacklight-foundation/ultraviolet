// Test responsibility:
// Compiler/Tests/Project/AssemblyGraph/DefOwnerRoot/DefOwnerRootTests.uv
//
// This file owns source-native tests for def.OwnerRoot@L4435:
//
// OwnerRoot(d, Rs) = S_k ⇔ S_k ∈ Rs ∧ prefix(d, S_k) ∧
// (∀ S_i ∈ Rs. prefix(d, S_i) ⇒ RootDepth(S_i) ≤ RootDepth(S_k)) ∧
// (∀ S_j ∈ Rs. prefix(d, S_j) ∧ RootDepth(S_j) = RootDepth(S_k) ⇒ S_j = S_k)

using UltravioletCompiler::Project::{
    OwnerRootResolutionValue,
    assemblySourceRootListEntry,
    directoryPath,
    emptyAssemblySourceRoots,
    ownerRoot,
    projectTextEquals
}

[[test(
    name: "owner root chooses deepest unique source-root prefix",
    covers("def.OwnerRoot@L4435")
)]]
internal procedure ownerRootChoosesDeepestUniqueSourceRootPrefix() -> bool
|: => @result
{
    let ownership: OwnerRootResolutionValue =
        ownerRoot(
            directoryPath("Compiler/Core/Path"),
            assemblySourceRootListEntry(
                directoryPath("Compiler"),
                assemblySourceRootListEntry(
                    directoryPath("Compiler/Core"),
                    emptyAssemblySourceRoots()
                )
            )
        )

    return if ownership is {
        @Ambiguous {
            false
        }
        @Owned { source_root } {
            projectTextEquals(source_root.text, "Compiler/Core")
        }
    }
}
