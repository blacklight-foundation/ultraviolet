// Test responsibility:
// Compiler/Tests/Project/DeterministicOrder/FileKey/DefFileKeyTests.uv
//
// This file owns source-native tests for def.FileKey@L4109.

using UltravioletCompiler::Project::{ projectPathTextPrecedes }

[[test(
    name: "file keys use original path as folded-key tiebreaker",
    covers("def.FileKey@L4109")
)]]
internal procedure fileKeysUseOriginalPathAsFoldedKeyTiebreaker() -> bool
|: => @result
{
    return projectPathTextPrecedes("Compiler/A.uv", "Compiler/a.uv") &&
        !projectPathTextPrecedes("Compiler/a.uv", "Compiler/A.uv")
}
