// Test responsibility:
// Compiler/Tests/Project/AssemblySelection/SelectErr/SelectErrTests.uv
//
// This file owns source-native tests for Select-Err@L3905.

using UltravioletCompiler::Project::{
    AssemblySelectionValue,
    absentAssemblyTarget,
    assembly,
    assemblyListEntry,
    assemblyName,
    directoryPath,
    emptyAssemblies,
    emptyModules,
    libraryAssemblyKind,
    selectAssembly,
    staticLinkKind
}

[[test(
    name: "assembly selection reports ambiguous absent target",
    covers("Select-Err@L3905")
)]]
internal procedure assemblySelectionReportsAmbiguousAbsentTarget() -> bool
|: => @result
{
    let selection: AssemblySelectionValue = selectAssembly(
        assemblyListEntry(
            assembly(
                assemblyName("A"),
                libraryAssemblyKind(),
                staticLinkKind(),
                directoryPath("A"),
                emptyModules()
            ),
            assemblyListEntry(
                assembly(
                    assemblyName("B"),
                    libraryAssemblyKind(),
                    staticLinkKind(),
                    directoryPath("B"),
                    emptyModules()
                ),
                emptyAssemblies()
            )
        ),
        absentAssemblyTarget()
    )

    return if selection is {
        @Selected {
            false
        }
        @Missing {
            false
        }
        @Ambiguous {
            true
        }
    }
}
