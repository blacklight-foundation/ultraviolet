// Test responsibility:
// Compiler/Tests/Project/Manifest/ParseManifestOk/ParseManifestOkTests.uv
//
// This file owns source-native tests for Parse-Manifest-Ok@L2183.

using UltravioletCompiler::Project::{
    ManifestAssemblyListValue,
    ManifestParseValue,
    manifestAssemblyListCount,
    parseManifestText,
    projectTextEquals
}

[[test(
    name: "manifest parser accepts the ultraviolet assembly manifest shape",
    covers("Parse-Manifest-Ok@L2183")
)]]
internal procedure manifestParserAcceptsUltravioletAssemblyManifestShape() -> bool
|: => @result
{
    let parse: ManifestParseValue = parseManifestText("[[assembly]]\nname = \"UltravioletRT\"\nkind = \"library\"\nlink_kind = \"static\"\nroot = \"Runtime\"\n\n[[assembly]]\nname = \"UltravioletCompiler\"\nkind = \"library\"\nlink_kind = \"static\"\nroot = \"Compiler\"\n\n[[assembly]]\nname = \"uv\"\nkind = \"executable\"\nroot = \"Tools/Uv\"\n")

    return if parse is {
        @Parsed { manifest } {
            manifestAssemblyListCount(manifest.assemblies) == 3 &&
                manifestListContainsAssembly(
                    manifest.assemblies,
                    "UltravioletRT",
                    "library",
                    "static",
                    "Runtime"
                ) &&
                manifestListContainsAssembly(
                    manifest.assemblies,
                    "UltravioletCompiler",
                    "library",
                    "static",
                    "Compiler"
                ) &&
                manifestListContainsAssembly(
                    manifest.assemblies,
                    "uv",
                    "executable",
                    "",
                    "Tools/Uv"
                )
        }
        @Failed {
            false
        }
    }
}

internal procedure manifestListContainsAssembly(
    assemblies: ManifestAssemblyListValue,
    name: string@View,
    kind: string@View,
    link_kind: string@View,
    root: string@View
) -> bool {
    return if assemblies is {
        @Empty {
            false
        }
        @Entry { assembly: manifest_assembly, tail } {
            if (projectTextEquals(manifest_assembly.name, name) &&
                projectTextEquals(manifest_assembly.kind, kind) &&
                projectTextEquals(manifest_assembly.link_kind, link_kind) &&
                projectTextEquals(manifest_assembly.root, root)) {
                true
            } else {
                manifestListContainsAssembly(tail, name, kind, link_kind, root)
            }
        }
    }
}
