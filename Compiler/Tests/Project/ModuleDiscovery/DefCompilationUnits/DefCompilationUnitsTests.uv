// Test responsibility:
// Compiler/Tests/Project/ModuleDiscovery/DefCompilationUnits/DefCompilationUnitsTests.uv
//
// This file owns source-native tests for def.CompilationUnits@L4338.

using UltravioletCompiler::Project::{
    CompilationUnitResultValue,
    SourceFileListValue,
    compilationUnitForDirectory,
    directoryPath,
    emptySourceFilePaths,
    moduleDirectoryScan,
    modulePath,
    projectTextEquals,
    sourceFilePath,
    sourceFilePathListEntry
}

[[test(
    name: "compilation unit sorts uv source files deterministically",
    covers("def.CompilationUnits@L4338")
)]]
internal procedure compilationUnitSortsUvSourceFilesDeterministically() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let unit: CompilationUnitResultValue =
            compilationUnitForDirectory(
                diagnostics_region,
                moduleDirectoryScan(
                    directoryPath("Compiler/Tests"),
                    modulePath("UltravioletCompiler::Tests"),
                    sourceFilePathListEntry(
                        sourceFilePath("Compiler/Tests/B.uv"),
                        sourceFilePathListEntry(
                            sourceFilePath("Compiler/Tests/a.uv"),
                            sourceFilePathListEntry(
                                sourceFilePath("Compiler/Tests/notes.txt"),
                                emptySourceFilePaths()
                            )
                        )
                    ),
                    true
                )
            )

        passed = if unit is {
            @Computed { source_files } {
                sourceFileListStartsWith(source_files, "Compiler/Tests/a.uv")
            }
            @Failed {
                false
            }
        }
    }
    return passed
}

internal procedure sourceFileListStartsWith(
    files: SourceFileListValue,
    expected_path: string@View
) -> bool {
    return if files is {
        @Empty {
            false
        }
        @Entry { file } {
            projectTextEquals(file.path.text, expected_path) &&
                file.file_order == 0
        }
    }
}
