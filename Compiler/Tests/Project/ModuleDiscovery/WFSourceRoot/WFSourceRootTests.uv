// Test responsibility:
// Compiler/Tests/Project/ModuleDiscovery/WFSourceRoot/WFSourceRootTests.uv
//
// This file owns source-native tests for WF-Source-Root@L4270.

using UltravioletCompiler::Project::{
    directoryPath,
    emptyDirectoryScans,
    sourceRootScan,
    sourceRootScanIsWellFormed
}

[[test(
    name: "directory source root is well formed",
    covers("WF-Source-Root@L4270")
)]]
internal procedure directorySourceRootIsWellFormed() -> bool
|: => @result
{
    let scan = sourceRootScan(
        directoryPath("Compiler"),
        true,
        emptyDirectoryScans()
    )

    return sourceRootScanIsWellFormed(scan)
}
