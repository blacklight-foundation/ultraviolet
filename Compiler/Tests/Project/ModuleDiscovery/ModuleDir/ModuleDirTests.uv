// Test responsibility:
// Compiler/Tests/Project/ModuleDiscovery/ModuleDir/ModuleDirTests.uv
//
// This file owns source-native tests for Module-Dir@L4306.

using UltravioletCompiler::Project::{
    directoryPath,
    emptySourceFilePaths,
    moduleDirectoryScan,
    moduleDirectoryScanIsModuleDirectory,
    modulePath,
    sourceFilePath,
    sourceFilePathListEntry
}

[[test(
    name: "directory containing uv source is a module directory",
    covers("Module-Dir@L4306")
)]]
internal procedure directoryContainingUvSourceIsModuleDirectory() -> bool
|: => @result
{
    let scan = moduleDirectoryScan(
        directoryPath("Compiler/Core"),
        modulePath("UltravioletCompiler::Core"),
        sourceFilePathListEntry(
            sourceFilePath("Compiler/Core/Path.uv"),
            emptySourceFilePaths()
        ),
        true
    )

    return moduleDirectoryScanIsModuleDirectory(scan)
}
