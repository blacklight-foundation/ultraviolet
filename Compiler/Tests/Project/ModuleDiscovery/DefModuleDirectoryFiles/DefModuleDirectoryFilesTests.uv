// Test responsibility:
// Compiler/Tests/Project/ModuleDiscovery/DefModuleDirectoryFiles/DefModuleDirectoryFilesTests.uv
//
// This file owns source-native tests for def.ModuleDirectoryFiles@L4324.

using UltravioletCompiler::Project::{
    SourceFilePathListValue,
    directoryPath,
    emptySourceFilePaths,
    moduleDirectoryFiles,
    moduleDirectoryScan,
    modulePath,
    projectTextEquals,
    sourceFilePath,
    sourceFilePathListEntry
}

[[test(
    name: "module directory files include only uv sources",
    covers("def.ModuleDirectoryFiles@L4324")
)]]
internal procedure moduleDirectoryFilesIncludeOnlyUvSources() -> bool
|: => @result
{
    let files: SourceFilePathListValue =
        moduleDirectoryFiles(
            moduleDirectoryScan(
                directoryPath("Compiler/Core"),
                modulePath("UltravioletCompiler::Core"),
                sourceFilePathListEntry(
                    sourceFilePath("Compiler/Core/readme.txt"),
                    sourceFilePathListEntry(
                        sourceFilePath("Compiler/Core/Path.uv"),
                        emptySourceFilePaths()
                    )
                ),
                true
            )
        )

    return if files is {
        @Empty {
            false
        }
        @Entry { path, tail } {
            projectTextEquals(path.text, "Compiler/Core/Path.uv") &&
                sourceFilePathListIsEmpty(tail)
        }
    }
}

internal procedure sourceFilePathListIsEmpty(files: SourceFilePathListValue) -> bool {
    return if files is {
        @Empty {
            true
        }
        @Entry {
            false
        }
    }
}
