// Test responsibility:
// Compiler/Tests/Project/AssemblyLoader/LoadProjectErr/LoadProjectErrTests.uv
//
// This file owns source-native tests for LoadProject-Err@L4017.

using UltravioletCompiler::Diagnostics::{
    diagnosticStreamHasErrors,
    singleErrorDiagnosticStream
}
using UltravioletCompiler::Project::{
    ProjectLoadValue,
    emptyManifestAssemblies,
    failedManifestParse,
    manifest,
    manifestAssembly,
    manifestAssemblyListEntry,
    parsedManifest,
    projectLoadFromManifestParse,
    projectRoot
}

[[test(
    name: "project load preserves manifest parse failure diagnostics",
    covers("LoadProject-Err@L4017")
)]]
internal procedure projectLoadPreservesManifestParseFailureDiagnostics() -> bool
|: => @result
{
    let load: ProjectLoadValue =
        projectLoadFromManifestParse(
            projectRoot("C:/Dev/Ultraviolet"),
            failedManifestParse(
                singleErrorDiagnosticStream("E-PRJ-0102", "invalid manifest")
            )
        )

    return projectLoadFailedWithErrors(load)
}

[[test(
    name: "project load preserves manifest validation failure diagnostics",
    covers("LoadProject-Err@L4017")
)]]
internal procedure projectLoadPreservesManifestValidationFailureDiagnostics() -> bool
|: => @result
{
    let load: ProjectLoadValue =
        projectLoadFromManifestParse(
            projectRoot("C:/Dev/Ultraviolet"),
            parsedManifest(
                manifest(
                    manifestAssemblyListEntry(
                        manifestAssembly("Bad", "executable", "static", "Bad"),
                        emptyManifestAssemblies()
                    )
                )
            )
        )

    return projectLoadFailedWithErrors(load)
}

internal procedure projectLoadFailedWithErrors(load: ProjectLoadValue) -> bool {
    return if load is {
        @Failed { diagnostics } {
            diagnosticStreamHasErrors(diagnostics)
        }
        @RootLocated {
            false
        }
        @ManifestParsed {
            false
        }
        @ManifestValidated {
            false
        }
        @AssembliesDiscovered {
            false
        }
        @Complete {
            false
        }
    }
}
