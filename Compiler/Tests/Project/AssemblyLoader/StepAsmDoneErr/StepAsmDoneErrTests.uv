// Test responsibility:
// Compiler/Tests/Project/AssemblyLoader/StepAsmDoneErr/StepAsmDoneErrTests.uv
//
// This file owns source-native tests for Step-Asm-Done-Err@L3831.

using UltravioletCompiler::Diagnostics::{ diagnosticStreamHasErrors }
using UltravioletCompiler::Project::{
    ProjectLoadValue,
    assembly,
    assemblyListEntry,
    assemblyName,
    directoryPath,
    emptyAssemblies,
    emptyManifestAssemblies,
    emptyModules,
    libraryAssemblyKind,
    manifest,
    noLinkKind,
    projectLoadFromDiscoveredAssemblies,
    projectRoot
}

[[test(
    name: "project load reports ambiguous assembly selection",
    covers("Step-Asm-Done-Err@L3831")
)]]
internal procedure projectLoadReportsAmbiguousAssemblySelection() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let load: ProjectLoadValue =
            projectLoadFromDiscoveredAssemblies(
                diagnostics_region,
                projectRoot("C:/Dev/Ultraviolet"),
                manifest(emptyManifestAssemblies()),
                assemblyListEntry(
                    assembly(
                        assemblyName("A"),
                        libraryAssemblyKind(),
                        noLinkKind(),
                        directoryPath("A"),
                        emptyModules()
                    ),
                    assemblyListEntry(
                        assembly(
                            assemblyName("B"),
                            libraryAssemblyKind(),
                            noLinkKind(),
                            directoryPath("B"),
                            emptyModules()
                        ),
                        emptyAssemblies()
                    )
                )
            )

        passed = if load is {
            @Failed { diagnostics } {
                diagnosticStreamHasErrors(diagnostics)
            }
            @RootLocated {
                false
            }
            @ManifestParsed {
                false
            }
            @ManifestValidated {
                false
            }
            @AssembliesDiscovered {
                false
            }
            @Complete {
                false
            }
        }
    }
    return passed
}
