// Test responsibility:
// Compiler/Tests/Project/AssemblyLoader/StepParseErr/StepParseErrTests.uv
//
// This file owns source-native tests for Step-Parse-Err@L3576.

using UltravioletCompiler::Diagnostics::{
    diagnosticStreamHasErrors
}
using UltravioletCompiler::Project::{
    ProjectLoadValue,
    projectLoadParseManifestText,
    projectRoot
}

[[test(
    name: "project load parse transition enters failed state on parse error",
    covers("Step-Parse-Err@L3576")
)]]
internal procedure projectLoadParseTransitionEntersFailedStateOnParseError() -> bool
|: => @result
{
    let load: ProjectLoadValue = projectLoadParseManifestText(
        projectRoot("C:/Dev/Ultraviolet"),
        "[[assembly]]\nname \"UltravioletCompiler\"\nkind = \"library\"\nroot = \"Compiler\"\n"
    )

    return if load is {
        @Failed { diagnostics } {
            diagnosticStreamHasErrors(diagnostics)
        }
        @RootLocated {
            false
        }
        @ManifestParsed {
            false
        }
        @ManifestValidated {
            false
        }
        @AssembliesDiscovered {
            false
        }
        @Complete {
            false
        }
    }
}
