// Test responsibility:
// Compiler/Tests/Project/AssemblyLoader/StepValidateErr/StepValidateErrTests.uv
//
// This file owns source-native tests for Step-Validate-Err@L3612.

using UltravioletCompiler::Diagnostics::{
    diagnosticStreamHasErrors
}
using UltravioletCompiler::Project::{
    ProjectLoadValue,
    emptyManifestAssemblies,
    manifest,
    manifestAssembly,
    manifestAssemblyListEntry,
    projectLoadFromManifestValidation,
    projectRoot,
    validateManifest
}

[[test(
    name: "project load validation transition enters failed state on validation error",
    covers("Step-Validate-Err@L3612")
)]]
internal procedure projectLoadValidationTransitionEntersFailedStateOnValidationError() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let load: ProjectLoadValue =
            projectLoadFromManifestValidation(
                projectRoot("C:/Dev/Ultraviolet"),
                validateManifest(
                    diagnostics_region,
                    manifest(
                        manifestAssemblyListEntry(
                            manifestAssembly("BadExecutable", "executable", "static", "Bad"),
                            emptyManifestAssemblies()
                        )
                    )
                )
            )

        passed = if load is {
            @Failed { diagnostics } {
                diagnosticStreamHasErrors(diagnostics)
            }
            @RootLocated {
                false
            }
            @ManifestParsed {
                false
            }
            @ManifestValidated {
                false
            }
            @AssembliesDiscovered {
                false
            }
            @Complete {
                false
            }
        }
    }
    return passed
}
