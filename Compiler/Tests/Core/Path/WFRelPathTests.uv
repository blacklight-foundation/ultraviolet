[[test(
    name: "WF-RelPath accepts relative path under canonical root",
    covers("WF-RelPath@L3441")
)]]
internal procedure wfRelPathAcceptsRelativePathUnderCanonicalRoot() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root/.")
        let path: Path = pathFromViewText(paths, "child/./file")
        let value: RelativePathWellFormednessResultValue =
            checkRelativePathWellFormedness(paths, move root, move path)
        passed = relativePathWellFormedAcceptedAs(value, "C:/root/child/file")
    }
    return passed
}

[[test(
    name: "WF-RelPath rejects absolute path",
    covers("WF-RelPath-Err@L3459")
)]]
internal procedure wfRelPathRejectsAbsolutePath() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root")
        let path: Path = pathFromViewText(paths, "D:/other")
        let value: RelativePathWellFormednessResultValue =
            checkRelativePathWellFormedness(paths, move root, move path)
        passed = relativePathWellFormedRejectedForAbsolutePath(value)
    }
    return passed
}

[[test(
    name: "WF-RelPath rejects root parent traversal",
    covers("WF-RelPath-Err@L3459")
)]]
internal procedure wfRelPathRejectsRootParentTraversal() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root/..")
        let path: Path = pathFromViewText(paths, "child")
        let value: RelativePathWellFormednessResultValue =
            checkRelativePathWellFormedness(paths, move root, move path)
        passed = relativePathWellFormedRejectedForRootTraversal(value)
    }
    return passed
}

[[test(
    name: "WF-RelPath rejects path parent traversal",
    covers("WF-RelPath-Err@L3459")
)]]
internal procedure wfRelPathRejectsPathParentTraversal() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root")
        let path: Path = pathFromViewText(paths, "child/..")
        let value: RelativePathWellFormednessResultValue =
            checkRelativePathWellFormedness(paths, move root, move path)
        passed = relativePathWellFormedRejectedForPathTraversal(value)
    }
    return passed
}
