internal procedure componentAtEquals(path: Path, index: usize, text: string@View) -> bool {
    return pathComponentEquals(path, index, text)
}

internal procedure componentCountEquals(path: Path, expected: usize) -> bool {
    return pathComponentCount(path) == expected
}

internal procedure canonicalPathAcceptedAs(
    value: CanonicalPathResultValue,
    text: string@View
) -> bool {
    return if value is {
        @Accepted { canonical_path } {
            pathTextEquals(canonical_path~>path(), text)
        }
        @RejectedParentTraversal {
            false
        }
    }
}

internal procedure canonicalPathRejected(value: CanonicalPathResultValue) -> bool {
    return if value is {
        @Accepted {
            false
        }
        @RejectedParentTraversal {
            true
        }
    }
}

internal procedure relativePathComputedAs(
    value: RelativePathResultValue,
    text: string@View
) -> bool {
    return if value is {
        @Computed { relative_path } {
            pathTextEquals(relative_path~>path(), text)
        }
        @Unavailable {
            false
        }
    }
}

internal procedure relativePathUnavailable(value: RelativePathResultValue) -> bool {
    return if value is {
        @Computed {
            false
        }
        @Unavailable {
            true
        }
    }
}

internal procedure pathResolutionResolvedAs(
    value: PathResolutionResultValue,
    text: string@View
) -> bool {
    return if value is {
        @Resolved { resolved_path } {
            pathTextEquals(resolved_path~>path(), text)
        }
        @Unavailable {
            false
        }
    }
}

internal procedure pathResolutionResolvedUnderRoot(value: PathResolutionResultValue) -> bool {
    return if value is {
        @Resolved { resolved_path } {
            resolved_path~>pathHasCanonicalRootPrefix()
        }
        @Unavailable {
            false
        }
    }
}

internal procedure pathResolutionUnavailableFromRoot(
    value: PathResolutionResultValue
) -> bool {
    return if value is {
        @Resolved {
            false
        }
        @Unavailable { reason } {
            return if reason is {
                @RootRejectedParentTraversal {
                    true
                }
                @PathRejectedParentTraversal {
                    false
                }
            }
        }
    }
}

internal procedure pathResolutionUnavailableFromPath(
    value: PathResolutionResultValue
) -> bool {
    return if value is {
        @Resolved {
            false
        }
        @Unavailable { reason } {
            return if reason is {
                @RootRejectedParentTraversal {
                    false
                }
                @PathRejectedParentTraversal {
                    true
                }
            }
        }
    }
}

internal procedure relativePathWellFormedAcceptedAs(
    value: RelativePathWellFormednessResultValue,
    text: string@View
) -> bool {
    return if value is {
        @Accepted { relative_path } {
            pathTextEquals(relative_path~>resolvedPath(), text)
        }
        @Rejected {
            false
        }
    }
}

internal procedure relativePathWellFormedRejectedForAbsolutePath(
    value: RelativePathWellFormednessResultValue
) -> bool {
    return if value is {
        @Accepted {
            false
        }
        @Rejected { reason } {
            return if reason is {
                @PathIsAbsolute {
                    true
                }
                @RootRejectedParentTraversal {
                    false
                }
                @PathRejectedParentTraversal {
                    false
                }
                @ResolvedPathOutsideRoot {
                    false
                }
            }
        }
    }
}

internal procedure relativePathWellFormedRejectedForRootTraversal(
    value: RelativePathWellFormednessResultValue
) -> bool {
    return if value is {
        @Accepted {
            false
        }
        @Rejected { reason } {
            return if reason is {
                @PathIsAbsolute {
                    false
                }
                @RootRejectedParentTraversal {
                    true
                }
                @PathRejectedParentTraversal {
                    false
                }
                @ResolvedPathOutsideRoot {
                    false
                }
            }
        }
    }
}

internal procedure relativePathWellFormedRejectedForPathTraversal(
    value: RelativePathWellFormednessResultValue
) -> bool {
    return if value is {
        @Accepted {
            false
        }
        @Rejected { reason } {
            return if reason is {
                @PathIsAbsolute {
                    false
                }
                @RootRejectedParentTraversal {
                    false
                }
                @PathRejectedParentTraversal {
                    true
                }
                @ResolvedPathOutsideRoot {
                    false
                }
            }
        }
    }
}
