// Obligation responsibility: Compiler/Driver/CLI/RunCommand.uv
//
// This file owns the `uv run` command entry procedure. It receives the parsed
// command arguments from the command modal and routes executable build/run
// execution to the canonical project pipeline boundary.

public procedure executeRunCommand(
    host: DriverHost,
    diagnostics_region: unique Region@Active,
    arguments: CommandArguments
) -> CommandResultValue {
    let request: PipelineRequest = runPipelineRequest(
        host~>currentDirectory(),
        host~>executablePath(),
        arguments
    )
    let submission: PipelineSubmissionValue = submitPipelineRequest(request)
    return commandResultFromPipelineSubmission(diagnostics_region, submission)
}

public procedure runPipelineRequest(
    current_directory: string@View,
    executable_path: string@View,
    arguments: CommandArguments
) -> PipelineRequest {
    return pipelineRequest(
        current_directory,
        executable_path,
        pipelineTargetProfileFromInput(arguments.target_profile),
        pipelineOutputModeFromInput(arguments.output_mode),
        pipelineRunCommand()
    )
}
