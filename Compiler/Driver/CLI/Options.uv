// Obligation responsibility: Compiler/Driver/CLI/Options.uv
//
// This file owns command argument records and command parsing from the
// normalized `System` invocation argument surface. Positional argument state,
// target-profile input, output-mode input, and CLI text comparison are owned by
// their focused files in this module.
//
// Relevant source-native test command rule:
//
// - lowering.TestHarnessGeneration@L28516
//   TestArg is absent or one positional argument. The test command target model
//   resolves that argument as a host path, assembly name, or module path.

internal let COMMAND_BUILD: string@View = "build"
internal let COMMAND_CHECK: string@View = "check"
internal let COMMAND_CLEAN: string@View = "clean"
internal let COMMAND_INIT: string@View = "init"
internal let COMMAND_RUN: string@View = "run"
internal let COMMAND_TEST: string@View = "test"
internal let COMMAND_VERSION: string@View = "version"

public record CommandArguments {
    public command_name: string@View
    public positionals: PositionalArgumentsValue
    public target_profile: TargetProfileInputValue
    public output_mode: OutputModeValue

    public procedure positionalCount(~) -> usize {
        return positionalArgumentsCount(self.positionals)
    }

    public procedure hasNoPositionals(~) -> bool {
        return self~>positionalCount() == 0
    }

    public procedure hasOnePositional(~) -> bool {
        return self~>positionalCount() == 1
    }
}

internal record CommandArgumentAccumulator {
    internal command_name: string@View
    internal positionals: PositionalArgumentsValue
    internal target_profile: TargetProfileInputValue
    internal output_mode: OutputModeValue

    internal procedure withCommandName(
        ~,
        command_name: string@View
    ) -> CommandArgumentAccumulator {
        return CommandArgumentAccumulator {
            command_name: command_name,
            positionals: self.positionals,
            target_profile: self.target_profile,
            output_mode: self.output_mode
        }
    }

    internal procedure withPositional(
        ~,
        value: string@View
    ) -> CommandArgumentAccumulator {
        return CommandArgumentAccumulator {
            command_name: self.command_name,
            positionals: appendPositionalArgument(self.positionals, value),
            target_profile: self.target_profile,
            output_mode: self.output_mode
        }
    }

    internal procedure withTargetProfile(
        ~,
        target_profile: TargetProfileInputValue
    ) -> CommandArgumentAccumulator {
        return CommandArgumentAccumulator {
            command_name: self.command_name,
            positionals: self.positionals,
            target_profile: target_profile,
            output_mode: self.output_mode
        }
    }

    internal procedure withOutputMode(
        ~,
        output_mode: OutputModeValue
    ) -> CommandArgumentAccumulator {
        return CommandArgumentAccumulator {
            command_name: self.command_name,
            positionals: self.positionals,
            target_profile: self.target_profile,
            output_mode: output_mode
        }
    }

    internal procedure finish(~) -> CommandArguments {
        return commandArguments(
            self.command_name,
            self.positionals,
            self.target_profile,
            self.output_mode
        )
    }
}

internal modal CommandArgumentParser {
    @ReadingCommand {
        internal accumulator: CommandArgumentAccumulator

        internal procedure acceptArgument(
            ~,
            text: string@View
        ) -> CommandArgumentParserValue {
            return CommandArgumentParser@ReadingPositionals {
                accumulator: self.accumulator~>withCommandName(text)
            }
        }

        internal procedure withTargetProfile(
            ~,
            target_profile: TargetProfileInputValue
        ) -> CommandArgumentParserValue {
            return CommandArgumentParser@ReadingCommand {
                accumulator: self.accumulator~>withTargetProfile(target_profile)
            }
        }

        internal procedure withOutputMode(
            ~,
            output_mode: OutputModeValue
        ) -> CommandArgumentParserValue {
            return CommandArgumentParser@ReadingCommand {
                accumulator: self.accumulator~>withOutputMode(output_mode)
            }
        }

        internal procedure finish(~) -> CommandArguments {
            return self.accumulator~>finish()
        }
    }

    @ReadingPositionals {
        internal accumulator: CommandArgumentAccumulator

        internal procedure acceptArgument(
            ~,
            text: string@View
        ) -> CommandArgumentParserValue {
            return CommandArgumentParser@ReadingPositionals {
                accumulator: self.accumulator~>withPositional(text)
            }
        }

        internal procedure withTargetProfile(
            ~,
            target_profile: TargetProfileInputValue
        ) -> CommandArgumentParserValue {
            return CommandArgumentParser@ReadingPositionals {
                accumulator: self.accumulator~>withTargetProfile(target_profile)
            }
        }

        internal procedure withOutputMode(
            ~,
            output_mode: OutputModeValue
        ) -> CommandArgumentParserValue {
            return CommandArgumentParser@ReadingPositionals {
                accumulator: self.accumulator~>withOutputMode(output_mode)
            }
        }

        internal procedure finish(~) -> CommandArguments {
            return self.accumulator~>finish()
        }
    }
}

internal type CommandArgumentParserValue =
    CommandArgumentParser@ReadingCommand |
    CommandArgumentParser@ReadingPositionals

public procedure commandArguments(
    command_name: string@View,
    positionals: PositionalArgumentsValue,
    target_profile: TargetProfileInputValue,
    output_mode: OutputModeValue
) -> CommandArguments {
    return CommandArguments {
        command_name: command_name,
        positionals: positionals,
        target_profile: target_profile,
        output_mode: output_mode
    }
}

internal procedure emptyCommandArgumentAccumulator() -> CommandArgumentAccumulator {
    return CommandArgumentAccumulator {
        command_name: CLI_EMPTY_TEXT,
        positionals: noPositionals(),
        target_profile: absentTargetProfile(),
        output_mode: normalOutputMode()
    }
}

internal procedure commandArgumentParser() -> CommandArgumentParserValue {
    return CommandArgumentParser@ReadingCommand {
        accumulator: emptyCommandArgumentAccumulator()
    }
}

internal procedure commandArgumentParserAcceptArgument(
    parser: CommandArgumentParserValue,
    text: string@View
) -> CommandArgumentParserValue {
    return if parser is {
        @ReadingCommand {
            parser~>acceptArgument(text)
        }
        @ReadingPositionals {
            parser~>acceptArgument(text)
        }
    }
}

internal procedure commandArgumentParserWithTargetProfile(
    parser: CommandArgumentParserValue,
    target_profile: TargetProfileInputValue
) -> CommandArgumentParserValue {
    return if parser is {
        @ReadingCommand {
            parser~>withTargetProfile(target_profile)
        }
        @ReadingPositionals {
            parser~>withTargetProfile(target_profile)
        }
    }
}

internal procedure commandArgumentParserWithOutputMode(
    parser: CommandArgumentParserValue,
    output_mode: OutputModeValue
) -> CommandArgumentParserValue {
    return if parser is {
        @ReadingCommand {
            parser~>withOutputMode(output_mode)
        }
        @ReadingPositionals {
            parser~>withOutputMode(output_mode)
        }
    }
}

internal procedure commandArgumentParserFinish(
    parser: CommandArgumentParserValue
) -> CommandArguments {
    return if parser is {
        @ReadingCommand {
            parser~>finish()
        }
        @ReadingPositionals {
            parser~>finish()
        }
    }
}

public procedure entrypointCommandArguments(system: System) -> CommandArguments {
    let argument_count: usize = system~>argument_count()
    var parser: CommandArgumentParserValue = commandArgumentParser()
    var index: usize = 0

    loop {
        if (index >= argument_count) {
            break
        }

        let text: string@View = system~>argument(index)
        if (cliTextEquals(text, OPTION_TARGET_PROFILE)) {
            let value_index: usize = index + 1
            if (value_index < argument_count) {
                parser = commandArgumentParserWithTargetProfile(
                    parser,
                    targetProfileFromText(system~>argument(value_index))
                )
                index = value_index + 1
            } else {
                parser = commandArgumentParserWithTargetProfile(
                    parser,
                    targetProfileFromText(CLI_EMPTY_TEXT)
                )
                index = argument_count
            }
        } else if (cliTextEquals(text, OPTION_QUIET)) {
            parser = commandArgumentParserWithOutputMode(parser, quietOutputMode())
            index = index + 1
        } else if (cliTextEquals(text, OPTION_MACHINE_READABLE)) {
            parser = commandArgumentParserWithOutputMode(
                parser,
                machineReadableOutputMode()
            )
            index = index + 1
        } else {
            parser = commandArgumentParserAcceptArgument(parser, text)
            index = index + 1
        }
    }

    return commandArgumentParserFinish(parser)
}

public procedure buildCommandArguments() -> CommandArguments {
    return commandArguments(
        COMMAND_BUILD,
        noPositionals(),
        absentTargetProfile(),
        normalOutputMode()
    )
}

public procedure checkCommandArguments() -> CommandArguments {
    return commandArguments(
        COMMAND_CHECK,
        noPositionals(),
        absentTargetProfile(),
        normalOutputMode()
    )
}

public procedure testCommandArguments() -> CommandArguments {
    return commandArguments(
        COMMAND_TEST,
        noPositionals(),
        absentTargetProfile(),
        normalOutputMode()
    )
}

public procedure testCommandArgumentsWithTarget(target: string@View) -> CommandArguments {
    return commandArguments(
        COMMAND_TEST,
        onePositional(target),
        absentTargetProfile(),
        normalOutputMode()
    )
}

public procedure versionCommandArguments() -> CommandArguments {
    return commandArguments(
        COMMAND_VERSION,
        noPositionals(),
        absentTargetProfile(),
        normalOutputMode()
    )
}
