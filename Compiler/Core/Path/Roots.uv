// Obligation responsibility: Compiler/Core/Path/Roots.uv
//
// This file owns root classification for project.path-resolution:
//
// - def.PathRootPredicates@L3146
//   WinSep = {"\\", "/"}
//   AsciiLetter(c) iff c is in "A"..."Z" or "a"..."z"
//   DriveRooted(p) iff |p| >= 3, At(p, 0) is AsciiLetter,
//   At(p, 1) = ":", and At(p, 2) is in WinSep.
//   UNC(p) iff StartsWith(p, "//") or StartsWith(p, "\\\\").
//   RootRelative(p) iff p starts with "/" or "\\" and is not UNC or DriveRooted.
//
// - def.PathRootTagAndTail@L3165
//   RootTag(p) = p[0..2) for DriveRooted paths, "//" for UNC paths,
//   "/" for RootRelative paths, and "" otherwise.
//   Tail(p) = p[3..|p|) for DriveRooted paths, p[2..|p|) for UNC paths,
//   p[1..|p|) for RootRelative paths, and p otherwise.
//
// - def.AbsPath@L3253
//   AbsPath(p) iff DriveRooted(p), UNC(p), or RootRelative(p).
//   is_relative(p) iff not AbsPath(p).

internal let SLASH_BYTE: u8 = 47
internal let BACKSLASH_BYTE: u8 = 92
internal let COLON_BYTE: u8 = 58
internal let DOT_BYTE: u8 = 46
internal let ASCII_UPPER_A: u8 = 65
internal let ASCII_UPPER_Z: u8 = 90
internal let ASCII_LOWER_A: u8 = 97
internal let ASCII_LOWER_Z: u8 = 122

internal modal PathRoot {
    @Relative {
        private _text: PathTextValue

        internal procedure textView(~) -> string@View {
            return pathTextView(self._text)
        }

        internal procedure tailStart(~) -> usize {
            return 0
        }

        internal procedure componentCount(~) -> usize {
            return 0
        }

        internal procedure componentAt(~, index: usize) -> PathComponentLookupValue {
            return missingPathComponent()
        }

        internal procedure isAbsolute(~) -> bool {
            return false
        }
    }

    @DriveRooted {
        private _text: PathTextValue

        internal procedure textView(~) -> string@View {
            return pathTextView(self._text)
        }

        internal procedure tailStart(~) -> usize {
            return 3
        }

        internal procedure componentCount(~) -> usize {
            return 1
        }

        internal procedure componentAt(~, index: usize) -> PathComponentLookupValue
        |: pathViewLength(pathTextView(self._text)) >= 3
        {
            if (index != 0) {
                return missingPathComponent()
            }
            return foundPathComponent(pathComponentFromViewSlice(pathTextView(self._text), 0, 2))
        }

        internal procedure isAbsolute(~) -> bool {
            return true
        }
    }

    @UNC {
        private _text: PathTextValue

        internal procedure textView(~) -> string@View {
            return pathTextView(self._text)
        }

        internal procedure tailStart(~) -> usize {
            return 2
        }

        internal procedure componentCount(~) -> usize {
            return 1
        }

        internal procedure componentAt(~, index: usize) -> PathComponentLookupValue {
            if (index != 0) {
                return missingPathComponent()
            }
            return foundPathComponent(pathComponentFromView("//"))
        }

        internal procedure isAbsolute(~) -> bool {
            return true
        }
    }

    @RootRelative {
        private _text: PathTextValue

        internal procedure textView(~) -> string@View {
            return pathTextView(self._text)
        }

        internal procedure tailStart(~) -> usize {
            return 1
        }

        internal procedure componentCount(~) -> usize {
            return 1
        }

        internal procedure componentAt(~, index: usize) -> PathComponentLookupValue {
            if (index != 0) {
                return missingPathComponent()
            }
            return foundPathComponent(pathComponentFromView("/"))
        }

        internal procedure isAbsolute(~) -> bool {
            return true
        }
    }
} |: {
    pathRootSatisfiesStatePredicate(self)
}

internal type PathRootValue =
    PathRoot@Relative |
    PathRoot@DriveRooted |
    PathRoot@UNC |
    PathRoot@RootRelative

internal procedure pathRootSatisfiesStatePredicate(root: PathRootValue) -> bool {
    return if root is {
        @Relative { _text } {
            !isDriveRootedPathText(_text) &&
                !isUNCPathText(_text) &&
                !isRootRelativePathText(_text)
        }
        @DriveRooted { _text } {
            isDriveRootedPathText(_text)
        }
        @UNC { _text } {
            isUNCPathText(_text)
        }
        @RootRelative { _text } {
            isRootRelativePathText(_text)
        }
    }
}

internal procedure classifyPathRoot(move text: PathTextValue) -> PathRootValue {
    if (isDriveRootedPathText(text)) {
        return pathRootFromDriveRootedText(move text)
    }
    if (isUNCPathText(text)) {
        return pathRootFromUNCText(move text)
    }
    if (isRootRelativePathText(text)) {
        return pathRootFromRootRelativeText(move text)
    }
    return pathRootFromRelativeText(move text)
}

internal procedure pathRootFromRelativeText(move text: PathTextValue) -> PathRoot@Relative
|: !isDriveRootedPathText(text) && !isUNCPathText(text) && !isRootRelativePathText(text)
{
    return PathRoot@Relative { _text: move text }
}

internal procedure pathRootFromDriveRootedText(move text: PathTextValue) -> PathRoot@DriveRooted
|: isDriveRootedPathText(text)
{
    return PathRoot@DriveRooted { _text: move text }
}

internal procedure pathRootFromUNCText(move text: PathTextValue) -> PathRoot@UNC
|: isUNCPathText(text)
{
    return PathRoot@UNC { _text: move text }
}

internal procedure pathRootFromRootRelativeText(move text: PathTextValue) -> PathRoot@RootRelative
|: isRootRelativePathText(text)
{
    return PathRoot@RootRelative { _text: move text }
}

internal procedure isAsciiLetter(value: u8) -> bool {
    let is_upper: bool = (value >= ASCII_UPPER_A) && (value <= ASCII_UPPER_Z)
    let is_lower: bool = (value >= ASCII_LOWER_A) && (value <= ASCII_LOWER_Z)
    return is_upper || is_lower
}

internal procedure isWinSeparator(value: u8) -> bool {
    return (value == SLASH_BYTE) || (value == BACKSLASH_BYTE)
}

internal procedure isDriveRootedPathText(text: PathTextValue) -> bool {
    if (pathTextLength(text) < 3) {
        return false
    }

    return pathTextByteIsAsciiLetter(text, 0) &&
        pathTextByteEquals(text, 1, COLON_BYTE) &&
        pathTextByteIsWinSeparator(text, 2)
}

internal procedure isUNCPathText(text: PathTextValue) -> bool {
    if (pathTextLength(text) < 2) {
        return false
    }

    let forward_unc: bool =
        pathTextByteEquals(text, 0, SLASH_BYTE) &&
        pathTextByteEquals(text, 1, SLASH_BYTE)
    let backward_unc: bool =
        pathTextByteEquals(text, 0, BACKSLASH_BYTE) &&
        pathTextByteEquals(text, 1, BACKSLASH_BYTE)
    return forward_unc || backward_unc
}

internal procedure isRootRelativePathText(text: PathTextValue) -> bool {
    if (pathTextLength(text) == 0) {
        return false
    }

    return pathTextByteIsWinSeparator(text, 0) &&
        !isUNCPathText(text) &&
        !isDriveRootedPathText(text)
}

internal procedure pathRootTextView(root: PathRootValue) -> string@View {
    return if root is {
        @Relative {
            root~>textView()
        }
        @DriveRooted {
            root~>textView()
        }
        @UNC {
            root~>textView()
        }
        @RootRelative {
            root~>textView()
        }
    }
}

internal procedure pathRootTailStart(root: PathRootValue) -> usize {
    return if root is {
        @Relative {
            root~>tailStart()
        }
        @DriveRooted {
            root~>tailStart()
        }
        @UNC {
            root~>tailStart()
        }
        @RootRelative {
            root~>tailStart()
        }
    }
}

internal procedure pathRootComponentCount(root: PathRootValue) -> usize {
    return if root is {
        @Relative {
            root~>componentCount()
        }
        @DriveRooted {
            root~>componentCount()
        }
        @UNC {
            root~>componentCount()
        }
        @RootRelative {
            root~>componentCount()
        }
    }
}

internal procedure pathRootComponentAt(root: PathRootValue, index: usize) -> PathComponentLookupValue {
    return if root is {
        @Relative {
            root~>componentAt(index)
        }
        @DriveRooted {
            root~>componentAt(index)
        }
        @UNC {
            root~>componentAt(index)
        }
        @RootRelative {
            root~>componentAt(index)
        }
    }
}

internal procedure pathRootIsAbsolute(root: PathRootValue) -> bool {
    return if root is {
        @Relative {
            root~>isAbsolute()
        }
        @DriveRooted {
            root~>isAbsolute()
        }
        @UNC {
            root~>isAbsolute()
        }
        @RootRelative {
            root~>isAbsolute()
        }
    }
}
