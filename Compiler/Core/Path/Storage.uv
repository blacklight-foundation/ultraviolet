// Support responsibility: Compiler/Core/Path/Storage.uv
//
// This file owns the backing storage states that keep path component views tied
// to their source text for the lifetime of a Path value.

internal modal PathStorage {
    @Text {
        private _root: PathRootValue
    }

    @Joined {
        private _base: Path
        private _path: Path
    }

    @Derived {
        private _source: Path
    }
}

internal type PathStorageValue =
    PathStorage@Text |
    PathStorage@Joined |
    PathStorage@Derived

internal procedure textPathStorage(
    paths: unique Region@Active,
    move root: PathRootValue
) -> PathStorageValue {
    return paths ^ PathStorage@Text { _root: move root }
}

internal procedure joinedPathStorage(
    paths: unique Region@Active,
    move base: Path,
    move path: Path
) -> PathStorageValue {
    return paths ^ PathStorage@Joined {
        _base: move base,
        _path: move path
    }
}

internal procedure derivedPathStorage(
    paths: unique Region@Active,
    move source: Path
) -> PathStorageValue {
    return paths ^ PathStorage@Derived { _source: move source }
}
