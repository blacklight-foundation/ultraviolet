//! Diagnostic key-system specimen for speculative acquisition over a large aggregate.

public record LargeSpeculativePayload {
    public words: [i64; 17]
}

public procedure speculativeLargeStructWarningReference() -> i64 {
    var payload: shared LargeSpeculativePayload = LargeSpeculativePayload {
        words: [1i64; 17]
    }
    %speculative write payload {
        payload.words[0usize] = 2i64
    }
    return payload.words[0usize] + 0i64
}
