//! Diagnostic-absence key-system specimen for stale_ok release suppression.

public procedure staleOkSuppressesReleaseWarningReference() -> Async<i32, (), (), !> {
    var shared_value: shared i32 = 1
    %read shared_value {
        #stale_ok
        let observed_value = shared_value
        yield release 1
        let resumed_value = observed_value
    }
    return
}
