//! Diagnostic key-system specimen for nested release interleaving.

public procedure nestedReleaseInterleavingWarningReference() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    %write shared_value {
        %release read shared_value {
            observed = shared_value + 0
        }
    }
    return observed
}
