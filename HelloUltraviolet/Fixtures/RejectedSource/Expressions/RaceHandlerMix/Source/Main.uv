//! Rejected async composition specimen for mixed race handler forms.

public procedure firstAsyncValue() -> Async<(), (), i32, !> {
    return 1
}

public procedure secondAsyncValue() -> Async<(), (), i32, !> {
    return 2
}

public procedure raceHandlerMixReference() -> Async<i32, (), (), !> {
    let value: i32 = race {
        firstAsyncValue() -> |result| result,
        secondAsyncValue() -> |result| yield result,
    }
    return
}
