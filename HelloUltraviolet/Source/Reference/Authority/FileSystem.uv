//! Reference specimens for Authority / FileSystem.

internal record FileSystemAuthorityReference {
    internal can_read: bool
    internal can_write: bool
    internal requires_capability: bool
}

internal procedure fileSystemAuthorityReference(
    can_read: bool,
    can_write: bool,
    requires_capability: bool
) -> FileSystemAuthorityReference {
    return FileSystemAuthorityReference {
        can_read: can_read,
        can_write: can_write,
        requires_capability: requires_capability
    }
}

internal procedure fileSystemAuthorityCanObserveHost(
    reference: FileSystemAuthorityReference
) -> bool {
    return reference.requires_capability && (reference.can_read || reference.can_write)
}

/// Exercises the Authority FileSystem reference surface.
public procedure runAuthorityFileSystemReference() -> bool {
    let read_only: FileSystemAuthorityReference =
        fileSystemAuthorityReference(true, false, true)
    let write_only: FileSystemAuthorityReference =
        fileSystemAuthorityReference(false, true, true)
    return fileSystemAuthorityCanObserveHost(read_only) &&
        fileSystemAuthorityCanObserveHost(write_only)
}
