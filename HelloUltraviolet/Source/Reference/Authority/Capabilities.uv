//! Reference specimens for Authority / Capabilities.

internal enum CapabilityReferenceKind {
    IO
    Network
    HeapAllocator
    Reactor
    ExecutionDomain
    System
}

internal record CapabilityReference {
    internal kind: CapabilityReferenceKind
    internal explicit_parameter: bool
}

internal procedure capabilityReference(
    kind: CapabilityReferenceKind,
    explicit_parameter: bool
) -> CapabilityReference {
    return CapabilityReference {
        kind: kind,
        explicit_parameter: explicit_parameter
    }
}

internal procedure capabilityHasAuthority(reference: CapabilityReference) -> bool {
    return reference.explicit_parameter
}

/// Exercises the Authority Capabilities reference surface.
public procedure runAuthorityCapabilitiesReference() -> bool {
    let io: CapabilityReference =
        capabilityReference(CapabilityReferenceKind::IO, true)
    let system: CapabilityReference =
        capabilityReference(CapabilityReferenceKind::System, true)
    return capabilityHasAuthority(io) && capabilityHasAuthority(system)
}
