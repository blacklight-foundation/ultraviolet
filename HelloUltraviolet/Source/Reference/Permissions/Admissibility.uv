//! Reference specimens for Permissions / Admissibility.

internal procedure receiverAdmissibilityValue() -> i32 {
    var shared_cell: shared PermissionCell = PermissionCell { value: 4 }
    let unique_cell: unique PermissionCell = PermissionCell { value: 5 }
    var observed: i32 = unique_cell~>readConst()
    observed = observed + unique_cell~>readShared()
    #shared_cell write {
        observed = observed + shared_cell~>readConst()
        observed = observed + shared_cell~>readShared()
    }
    return observed
}

/// Exercises the Permissions Admissibility reference surface.
public procedure runPermissionsAdmissibilityReference() -> bool {
    return receiverAdmissibilityValue() == 18
}
