//! Reference specimens for Permissions / ActivityStates.

internal procedure uniqueActivityValue() -> i32 {
    let unique_cell: unique PermissionCell = PermissionCell { value: 9 }
    let first_read: i32 = unique_cell~>readConst()
    let second_read: i32 = unique_cell~>readUnique()
    return first_read + second_read
}

/// Exercises the Permissions ActivityStates reference surface.
public procedure runPermissionsActivityStatesReference() -> bool {
    return uniqueActivityValue() == 18
}
