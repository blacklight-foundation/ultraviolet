//! Reference specimens for FFI / BoundaryUnwinding.

extern "C-unwind" {
    [[unwind("catch")]]
    public procedure importedReferenceCatchBoundary(value: i32) -> i32
}

/// Foreign-visible C-unwind provider used by the imported catch boundary.
[[export("C-unwind")]]
[[unwind("catch")]]
[[mangle("importedReferenceCatchBoundary")]]
public procedure ffiImportedReferenceCatchBoundaryProvider(value: i32) -> i32 {
    return value
}

internal procedure callImportedReferenceCatchBoundary(value: i32) -> i32 {
    return unsafe { importedReferenceCatchBoundary(value) }
}

/// Raw exported C-unwind boundary that catches panics and returns zero on failure.
[[export("C-unwind")]]
[[unwind("catch")]]
[[mangle("uv_reference_exported_catch_boundary")]]
public procedure ffiExportedCatchBoundary(value: i32) -> i32 {
    return value
}

/// Exercises the FFI BoundaryUnwinding reference surface.
public procedure runFFIBoundaryUnwindingReference() -> bool {
    return callImportedReferenceCatchBoundary(23) == 23 &&
        ffiExportedCatchBoundary(29) == 29
}
