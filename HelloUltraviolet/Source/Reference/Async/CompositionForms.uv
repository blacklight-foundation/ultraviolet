//! Reference specimens for Async / CompositionForms.

/// Exercises the Async CompositionForms reference surface.
public procedure runAsyncCompositionFormsReference() -> bool {
    let sequence: AsyncReference = asyncReference(2usize, true, false)
    let racing_form: AsyncReference = asyncReference(2usize, true, false)
    return asyncReferenceIsCovered(sequence) && asyncReferenceIsCovered(racing_form)
}
