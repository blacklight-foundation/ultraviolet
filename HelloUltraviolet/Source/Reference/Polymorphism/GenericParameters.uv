//! Reference specimens for Polymorphism / GenericParameters.

internal type GenericAlias<TValue> = TValue

internal record GenericCarrier<TValue; TTag = TValue> {
    internal value: TValue
    internal tag: TTag
}

internal record PolymorphismReference {
    internal feature_count: usize
    internal statically_checked: bool
    internal dynamically_dispatchable: bool
}

internal procedure defaultedGenericValue<TValue; TMirror = TValue>(
    move value: TValue,
    mirror: TMirror
) -> TValue
|: Bitcopy(TValue)
{
    return move value
}

internal procedure genericAliasValue<TValue>(move value: TValue) -> GenericAlias<TValue>
|: Bitcopy(TValue)
{
    return move value
}

internal procedure multiPredicateGenericValue<TValue>(move value: TValue) -> TValue
|: Bitcopy(TValue)
Clone(TValue)
{
    return move value
}

internal procedure duplicateBitcopyGenericValue<TValue>(value: TValue) -> (TValue, TValue)
|: Bitcopy(TValue)
{
    return (value, value)
}

internal procedure classBoundGenericValue<TValue <: ClassReadable>(value: TValue) -> i32 {
    return value~>classValue()
}

internal procedure polymorphismReference(
    feature_count: usize,
    statically_checked: bool,
    dynamically_dispatchable: bool
) -> PolymorphismReference {
    return PolymorphismReference {
        feature_count: feature_count,
        statically_checked: statically_checked,
        dynamically_dispatchable: dynamically_dispatchable
    }
}

internal procedure polymorphismReferenceIsCovered(
    reference: PolymorphismReference
) -> bool {
    return reference.feature_count > 0usize && reference.statically_checked
}

/// Exercises the Polymorphism GenericParameters reference surface.
public procedure runPolymorphismGenericParametersReference() -> bool {
    let defaulted_value: i32 = defaultedGenericValue<i32>(17, 23)
    let alias_value: i32 = genericAliasValue<i32>(31)
    let multi_predicate_value: i32 = multiPredicateGenericValue<i32>(29)
    let duplicated_value: (i32, i32) = duplicateBitcopyGenericValue<i32>(59)
    let inferred_default_carrier: GenericCarrier<i32> =
        GenericCarrier { value: 43, tag: 47 }
    let inferred_explicit_carrier: GenericCarrier<i32, bool> =
        GenericCarrier { value: 53, tag: true }
    let defaulted_carrier_layout: bool =
        sizeof(GenericCarrier<i32>) == 2usize * sizeof(i32) &&
            alignof(GenericCarrier<i32>) == alignof(i32)
    let explicit_carrier_layout: bool =
        sizeof(GenericCarrier<i32, bool>) >= sizeof(i32) + sizeof(bool) &&
            alignof(GenericCarrier<i32, bool>) == alignof(i32)
    let owner: ClassOwner = ClassOwner { value: 37, inspected_value: 41 }
    let reference: PolymorphismReference =
        polymorphismReference(
            10usize,
            defaulted_value == 17 &&
                alias_value == 31 &&
                multi_predicate_value == 29 &&
                duplicated_value.0 == 59 &&
                duplicated_value.1 == 59 &&
                inferred_default_carrier.value == 43 &&
                inferred_default_carrier.tag == 47 &&
                inferred_explicit_carrier.value == 53 &&
                inferred_explicit_carrier.tag &&
                defaulted_carrier_layout &&
                explicit_carrier_layout &&
                classBoundGenericValue<ClassOwner>(owner) == 11 &&
                owner~>classValue() == 11 &&
                owner.inspected_value == 41,
            false
        )
    return polymorphismReferenceIsCovered(reference)
}
