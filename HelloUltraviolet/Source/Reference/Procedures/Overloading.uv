//! Reference specimens for Procedures / Overloading.

internal record LeftOverloadReceiver {
    internal value: i32

    internal procedure selectedByReceiver(~) -> i32 {
        return self.value + 10
    }
}

internal record RightOverloadReceiver {
    internal value: i32

    internal procedure selectedByReceiver(~) -> i32 {
        return self.value + 20
    }
}

internal procedure selectFreeOverload(value: i32) -> i32 {
    return value + 1
}

internal procedure selectFreeOverload(value: bool) -> i32 {
    if value {
        return 2
    }

    return 0
}

internal procedure selectFreeOverload(left: i32, right: i32) -> i32 {
    return left + right + 3
}

internal procedure arityOverloadReference() -> i32 {
    return selectFreeOverload(2, 3)
}

internal procedure parameterTypeOverloadReference() -> i32 {
    return selectFreeOverload(4) + selectFreeOverload(true)
}

internal procedure receiverTypeLookupReference() -> i32 {
    let left: LeftOverloadReceiver = LeftOverloadReceiver { value: 1 }
    let right: RightOverloadReceiver = RightOverloadReceiver { value: 2 }
    return left~>selectedByReceiver() + right~>selectedByReceiver()
}

/// Exercises the Procedures Overloading reference surface.
public procedure runProceduresOverloadingReference() -> bool {
    return arityOverloadReference() == 8 &&
        parameterTypeOverloadReference() == 7 &&
        receiverTypeLookupReference() == 33
}
