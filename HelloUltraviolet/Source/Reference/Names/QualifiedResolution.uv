//! Reference specimens for Names / QualifiedResolution.

import HelloUltraviolet::Reference::DataTypes as QualifiedDataTypes
import HelloUltraviolet::Reference::ModalTypes as QualifiedModalTypes

internal record QualifiedNameReference {
    internal path_segments: usize
    internal terminal_name_present: bool
}

internal class QualifiedLocalReadable {
    internal procedure qualifiedLocalValue(~) -> i32
}

internal record QualifiedLocalOwner <: HelloUltraviolet::Reference::Names::QualifiedLocalReadable {
    internal value: i32

    internal procedure qualifiedLocalValue(~) -> i32 {
        return self.value
    }
}

internal type QualifiedRecordFactory =
    (string@View, usize, bool) -> QualifiedDataTypes::RecordReference

internal type QualifiedRecordConsumer =
    (QualifiedDataTypes::RecordReference) -> usize

internal procedure qualifiedNameReference(
    path_segments: usize,
    terminal_name_present: bool
) -> QualifiedNameReference {
    return QualifiedNameReference {
        path_segments: path_segments,
        terminal_name_present: terminal_name_present
    }
}

internal procedure qualifiedNameCanResolve(reference: QualifiedNameReference) -> bool {
    return reference.path_segments > 0usize && reference.terminal_name_present
}

internal procedure qualifiedModuleAliasProcedureValue() -> usize {
    let reference: QualifiedDataTypes::RecordReference =
        QualifiedDataTypes::recordReference("qualified-call", 34usize, true)
    return reference.count
}

internal procedure qualifiedFullPathProcedureValue() -> usize {
    let reference: HelloUltraviolet::Reference::DataTypes::RecordReference =
        HelloUltraviolet::Reference::DataTypes::recordReference(
            "qualified-full-path-call",
            35usize,
            true
        )
    return reference.count
}

internal procedure qualifiedRecordLiteralValue() -> usize {
    let reference: QualifiedDataTypes::RecordReference =
        QualifiedDataTypes::RecordReference {
            name: "qualified-record",
            count: 55usize,
            is_active: true
        }
    return reference.count
}

internal procedure qualifiedEnumConstructorsValue() -> i32 {
    let idle: QualifiedDataTypes::EnumReference = QualifiedDataTypes::EnumReference::Idle
    let count: QualifiedDataTypes::EnumReference = QualifiedDataTypes::EnumReference::Count(7)
    let named: QualifiedDataTypes::EnumReference =
        QualifiedDataTypes::EnumReference::Named { value: 11 }

    let idle_score: i32 = if idle is {
        QualifiedDataTypes::EnumReference::Idle {
            1
        }
        QualifiedDataTypes::EnumReference::Count(value) {
            value
        }
        QualifiedDataTypes::EnumReference::Named { value } {
            value
        }
    }
    let count_score: i32 = if count is {
        QualifiedDataTypes::EnumReference::Idle {
            0
        }
        QualifiedDataTypes::EnumReference::Count(value) {
            value
        }
        QualifiedDataTypes::EnumReference::Named { value } {
            value
        }
    }
    let named_score: i32 = if named is {
        QualifiedDataTypes::EnumReference::Idle {
            0
        }
        QualifiedDataTypes::EnumReference::Count(value) {
            value
        }
        QualifiedDataTypes::EnumReference::Named { value } {
            value
        }
    }
    return idle_score + count_score + named_score
}

internal procedure qualifiedEnumPatternValue() -> i32 {
    let value: QualifiedDataTypes::EnumReference =
        QualifiedDataTypes::EnumReference::Named { value: 17 }

    return if value is {
        QualifiedDataTypes::EnumReference::Idle {
            0
        }
        QualifiedDataTypes::EnumReference::Count(payload_value) {
            payload_value
        }
        QualifiedDataTypes::EnumReference::Named { value: payload_value } {
            payload_value
        }
    }
}

internal procedure qualifiedGenericTypeApplyValue() -> i32 {
    let item: QualifiedDataTypes::GenericEnumReference<i32> =
        QualifiedDataTypes::GenericEnumReference::Item(23)

    return if item is {
        QualifiedDataTypes::GenericEnumReference::Item(value) {
            value
        }
    }
}

internal procedure qualifiedModalStateValue() -> i32 {
    let opened: QualifiedModalTypes::ModalReference@Open =
        QualifiedModalTypes::ModalReference@Open { value: 29 }
    return opened.value
}

internal procedure qualifiedProcedureValueValue() -> usize {
    let make_record: QualifiedRecordFactory = QualifiedDataTypes::recordReference
    let reference: QualifiedDataTypes::RecordReference =
        make_record("qualified-procedure-value", 89usize, true)
    return reference.count
}

internal procedure qualifiedConsumerValue(
    reference: QualifiedDataTypes::RecordReference
) -> usize {
    return reference.count
}

internal procedure qualifiedFunctionTypeValue() -> usize {
    let consume: QualifiedRecordConsumer = qualifiedConsumerValue
    let reference: QualifiedDataTypes::RecordReference =
        QualifiedDataTypes::recordReference("qualified-parameter", 97usize, true)
    return consume(reference)
}

internal procedure qualifiedRecordPatternValue() -> usize {
    let reference: QualifiedDataTypes::RecordReference =
        QualifiedDataTypes::recordReference("qualified-pattern", 101usize, true)
    let QualifiedDataTypes::RecordReference {
        count: resolved_count,
        is_active
    } = reference

    if is_active {
        return resolved_count
    }
    return 0usize
}

internal procedure qualifiedLocalUsingAliasValue() -> i32 {
    let source_value: i32 = 37
    using source_value as alias_value
    return alias_value
}

internal procedure qualifiedClassPathValue() -> i32 {
    let owner: HelloUltraviolet::Reference::Names::QualifiedLocalOwner =
        HelloUltraviolet::Reference::Names::QualifiedLocalOwner { value: 144 }
    return owner~>qualifiedLocalValue()
}

internal procedure qualifiedDynamicClassPathValue() -> i32 {
    let owner: QualifiedLocalOwner = QualifiedLocalOwner { value: 233 }
    let dynamic_owner: $HelloUltraviolet::Reference::Names::QualifiedLocalReadable =
        owner as $HelloUltraviolet::Reference::Names::QualifiedLocalReadable
    return dynamic_owner~>qualifiedLocalValue()
}

/// Exercises the Names QualifiedResolution reference surface.
public procedure runNamesQualifiedResolutionReference() -> bool {
    let variant_value: DisambiguatedNameKind = DisambiguatedNameKind::Type
    let path: QualifiedNameReference = qualifiedNameReference(4usize, true)
    let variant_ok: bool = if variant_value is {
        DisambiguatedNameKind::Type {
            true
        }
        DisambiguatedNameKind::Value {
            false
        }
        DisambiguatedNameKind::Module {
            false
        }
        DisambiguatedNameKind::Class {
            false
        }
    }
    return qualifiedNameCanResolve(path) &&
        variant_ok &&
        qualifiedModuleAliasProcedureValue() == 34usize &&
        qualifiedFullPathProcedureValue() == 35usize &&
        qualifiedRecordLiteralValue() == 55usize &&
        qualifiedEnumConstructorsValue() == 19 &&
        qualifiedEnumPatternValue() == 17 &&
        qualifiedGenericTypeApplyValue() == 23 &&
        qualifiedModalStateValue() == 29 &&
        qualifiedProcedureValueValue() == 89usize &&
        qualifiedFunctionTypeValue() == 97usize &&
        qualifiedRecordPatternValue() == 101usize &&
        qualifiedLocalUsingAliasValue() == 37 &&
        qualifiedClassPathValue() == 144 &&
        qualifiedDynamicClassPathValue() == 233
}
