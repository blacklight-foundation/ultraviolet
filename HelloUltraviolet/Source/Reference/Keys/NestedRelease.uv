//! Reference specimens for Keys / NestedRelease.

internal procedure nestedReleaseValue() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    #shared_value write {
        #shared_value release read {
            observed = shared_value + 0
        }
        shared_value = observed + 1
    }
    return shared_value + 0
}

/// Exercises the Keys NestedRelease reference surface.
public procedure runKeysNestedReleaseReference() -> bool {
    return nestedReleaseValue() == 2
}
