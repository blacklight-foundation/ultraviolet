//! Reference specimens for Keys / MemoryOrdering.

internal procedure acquireOrderedKeyReadValue() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    %read shared_value {
        observed = (#acquire shared_value) + 0
    }
    return observed
}

internal procedure expressionMemoryOrderingValue() -> i32 {
    var shared_value: shared i32 = 3
    var observed: i32 = 0
    %read shared_value {
        observed = observed + (#relaxed shared_value)
        observed = observed + (#acquire shared_value)
        observed = observed + (#release shared_value)
        observed = observed + (#acqrel shared_value)
        observed = observed + (#seqcst shared_value)
    }
    return observed
}

internal procedure keyBlockDefaultMemoryOrderingValue() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    #relaxed
    %read shared_value {
        observed = observed + shared_value
    }
    #acquire
    %read shared_value {
        observed = observed + shared_value
    }
    #release
    %write shared_value {
        shared_value = 2
    }
    #acqrel
    %read shared_value {
        observed = observed + shared_value
    }
    #seqcst
    %write shared_value {
        shared_value = 3
    }
    %read shared_value {
        observed = observed + shared_value
    }
    return observed
}

internal procedure expressionOrderingOverridesKeyBlockDefaultValue() -> i32 {
    var shared_value: shared i32 = 4
    var observed: i32 = 0
    #relaxed
    %read shared_value {
        observed = (#seqcst shared_value) + 0
    }
    #seqcst
    %read shared_value {
        observed = observed + (#relaxed shared_value)
    }
    return observed
}

internal procedure fenceOrderingValue() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    fence(acquire)
    %write shared_value {
        shared_value = 2
    }
    fence(release)
    %read shared_value {
        observed = shared_value + 0
    }
    fence(seqcst)
    return observed
}

/// Exercises the Keys MemoryOrdering reference surface.
public procedure runKeysMemoryOrderingReference() -> bool {
    return acquireOrderedKeyReadValue() == 1 &&
        expressionMemoryOrderingValue() == 15 &&
        keyBlockDefaultMemoryOrderingValue() == 7 &&
        expressionOrderingOverridesKeyBlockDefaultValue() == 8 &&
        fenceOrderingValue() == 2
}
