//! Reference specimens for Keys / AcquisitionBlocks.

internal type EscapingSharedKeyReader = || -> i32 [shared: { shared_value: shared i32 }]

internal record KeyModeContextCell {
    internal value: i32

    internal procedure readConst(~) -> i32 {
        return self.value
    }

    internal procedure readShared(~%) -> i32 {
        return self.value + 1
    }
}

internal procedure readConstModeContext(value: const KeyModeContextCell) -> i32 {
    return value.value + 0
}

internal procedure readAndWriteKeyBlockValue() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    %read shared_value {
        observed = shared_value + 0
    }
    %write shared_value {
        shared_value = observed + 1
    }
    return shared_value + 0
}

internal procedure orderedKeyBlockValue() -> i32 {
    var values: shared [i32; 4] = [1, 2, 3, 4]
    var observed: i32 = 0
    %read values[0usize], values[1usize] [ordered] {
        observed = values[0usize] + values[1usize]
    }
    return observed
}

internal procedure defaultReadKeyBlockValue() -> i32 {
    var shared_value: shared i32 = 5
    var observed: i32 = 0
    %read shared_value {
        observed = shared_value + 0
    }
    return observed
}

internal procedure canonicalOrderFromUnsortedPathsValue() -> i32 {
    var container: shared KeyContainer =
        KeyContainer {
            leaf: KeyLeaf { value: 29 },
            values: [1, 2, 3, 4]
        }
    var observed: i32 = 0
    %read container.values[1usize], container.leaf.value {
        observed = container.leaf.value + container.values[1usize]
    }
    return observed
}

internal procedure keyModeContextValue() -> i32 {
    var cell: shared KeyModeContextCell = KeyModeContextCell { value: 6 }
    var observed: i32 = 0
    %read cell {
        let initializer_read: shared i32 = cell.value
        observed = initializer_read + cell~>readConst()
        if cell.value > 0 {
            observed = observed + readConstModeContext(cell)
        }
    }
    %write cell {
        cell.value = observed + 7
        observed = cell~>readShared()
    }
    return observed
}

internal procedure sharedArgumentReadReference(value: shared i32) -> i32 {
    %read value {
        return value + 0
    }
    return 0
}

internal procedure sharedArgumentNoCallSiteAcquisitionValue() -> i32 {
    var shared_value: shared i32 = 8
    return sharedArgumentReadReference(shared_value)
}

internal procedure localClosureSharedCaptureValue() -> i32 {
    var shared_value: shared i32 = 13
    let reader = || -> i32 {
        %read shared_value {
            return shared_value + 0
        }
        return 0
    }
    return reader()
}

internal procedure invokeEscapingSharedKeyReader(reader: EscapingSharedKeyReader) -> i32 {
    return reader()
}

internal procedure escapingClosureSharedCaptureValue() -> i32 {
    var shared_value: shared i32 = 31
    let reader: EscapingSharedKeyReader = || -> i32 {
        %read shared_value {
            return shared_value + 0
        }
        return 0
    }
    return invokeEscapingSharedKeyReader(reader)
}

internal procedure inlineCoarsenedFieldKeyValue() -> i32 {
    var container: shared KeyContainer =
        KeyContainer {
            leaf: KeyLeaf { value: 17 },
            values: [1, 2, 3, 4]
        }
    var observed: i32 = 0
    %read container.#leaf.value {
        observed = container.leaf.value + 0
    }
    return observed
}

internal procedure inlineCoarsenedIndexKeyValue() -> i32 {
    var leaves: shared [KeyLeaf; 2] =
        [
            KeyLeaf { value: 19 },
            KeyLeaf { value: 23 }
        ]
    var observed: i32 = 0
    %read leaves[#1usize].value {
        observed = leaves[1usize].value + 0
    }
    return observed
}

internal procedure keyBlockBreakReleaseValue() -> i32 {
    var shared_value: shared i32 = 1
    var observed: i32 = 0
    loop {
        %write shared_value {
            shared_value = 29
            break
        }
    }
    %read shared_value {
        observed = shared_value + 0
    }
    return observed
}

internal procedure keyBlockContinueReleaseValue() -> i32 {
    var shared_value: shared i32 = 1
    var index: i32 = 0
    var observed: i32 = 0
    loop {
        index = index + 1
        %write shared_value {
            if index == 1 {
                shared_value = 2
                continue
            }
            shared_value = 12
        }
        break
    }
    %read shared_value {
        observed = shared_value + 0
    }
    return observed
}

internal procedure keyBlockReturnReleaseValue() -> i32 {
    var shared_value: shared i32 = 37
    %read shared_value {
        return shared_value + 0
    }
}

/// Exercises the Keys AcquisitionBlocks reference surface.
public procedure runKeysAcquisitionBlocksReference() -> bool {
    return readAndWriteKeyBlockValue() == 2 &&
        orderedKeyBlockValue() == 3 &&
        defaultReadKeyBlockValue() == 5 &&
        canonicalOrderFromUnsortedPathsValue() == 31 &&
        keyModeContextValue() == 26 &&
        sharedArgumentNoCallSiteAcquisitionValue() == 8 &&
        localClosureSharedCaptureValue() == 13 &&
        escapingClosureSharedCaptureValue() == 31 &&
        inlineCoarsenedFieldKeyValue() == 17 &&
        inlineCoarsenedIndexKeyValue() == 23 &&
        keyBlockBreakReleaseValue() == 29 &&
        keyBlockContinueReleaseValue() == 12 &&
        keyBlockReturnReleaseValue() == 37
}
