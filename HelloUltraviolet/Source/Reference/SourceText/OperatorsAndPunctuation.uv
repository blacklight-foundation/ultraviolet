//! Reference specimens for SourceText / OperatorsAndPunctuation.

internal record TokenReference {
    internal operator_count: usize
    internal punctuator_count: usize
    internal has_attribute_delimiters: bool
}

internal record TokenMethodReference {
    internal value: i32

    internal procedure readTokenValue(~) -> i32 {
        return self.value
    }
}

internal procedure tokenReference(
    operator_count: usize,
    punctuator_count: usize,
    has_attribute_delimiters: bool
) -> TokenReference {
    return TokenReference {
        operator_count: operator_count,
        punctuator_count: punctuator_count,
        has_attribute_delimiters: has_attribute_delimiters
    }
}

internal procedure tokenReferenceCoversCoreSurface(reference: TokenReference) -> bool {
    return reference.operator_count >= 20usize &&
        reference.punctuator_count >= 10usize &&
        reference.has_attribute_delimiters
}

internal procedure compoundAssignmentTokensReference() -> bool {
    var arithmetic: i32 = 8
    arithmetic += 4
    arithmetic -= 3
    arithmetic *= 2
    arithmetic /= 3
    arithmetic %= 5

    return arithmetic == 1
}

internal procedure rangeAndSuffixTokensReference() -> bool {
    let values: [i32; 5] = [3, 5, 8, 13, 21]
    let exclusive: [i32] = values[1usize..3usize]
    let inclusive: [i32] = values[1usize..=3usize]
    let from_start: [i32] = values[2usize..]
    let to_end: [i32] = values[..3usize]
    let to_inclusive_end: [i32] = values[..=2usize]
    let full: [i32] = values[..]

    return exclusive[1usize] == 8 &&
        inclusive[2usize] == 13 &&
        from_start[2usize] == 21 &&
        to_end[2usize] == 8 &&
        to_inclusive_end[2usize] == 8 &&
        full[4usize] == 21
}

internal procedure bindingAndReceiverTokensReference() -> bool {
    let payload: TokenMethodReference := TokenMethodReference { value: 17 }
    return payload~>readTokenValue() == 17
}

/// Exercises the SourceText OperatorsAndPunctuation reference surface.
public procedure runSourceTextOperatorsAndPunctuationReference() -> bool {
    let arithmetic: i32 = ((8 + 4) - 2) * 3 / 5 % 5
    let comparison: bool = arithmetic == 1 && arithmetic != 2 && 1 < 2 && 2 >= 2
    let bitwise: i32 = (1 | 2) & 3
    let shifted: i32 = (1 << 3) >> 1
    let ranges_ok: bool = true
    let reference: TokenReference = tokenReference(28usize, 12usize, true)
    return comparison &&
        bitwise == 3 &&
        shifted == 4 &&
        ranges_ok &&
        tokenReferenceCoversCoreSurface(reference) &&
        compoundAssignmentTokensReference() &&
        rangeAndSuffixTokensReference() &&
        bindingAndReceiverTokensReference()
}
