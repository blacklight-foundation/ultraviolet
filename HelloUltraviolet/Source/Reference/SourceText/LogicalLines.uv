//! Reference specimens for SourceText / LogicalLines.

internal procedure logicalLineContinuedByOperator() -> i32 {
    return 4 +
        5 +
        6
}

internal procedure logicalLineContinuedInDelimitedList() -> i32 {
    let values: [i32; 3] = [
        1,
        2,
        3
    ]
    return values[0usize] + values[1usize] + values[2usize]
}

/// Exercises the SourceText LogicalLines reference surface.
public procedure runSourceTextLogicalLinesReference() -> bool {
    let semicolon_value: i32 = 1; let newline_value: i32 = 2
    return logicalLineContinuedByOperator() == 15 &&
        logicalLineContinuedInDelimitedList() == 6 &&
        semicolon_value + newline_value == 3
}
