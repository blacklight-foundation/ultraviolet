public procedure expectedCatalogCompiledSymbolCount() -> usize {
    return 66usize
}

public procedure catalogCompiledSymbolCount() -> usize {
    return 66usize
}

internal procedure catalogSymbolTargetMatches(
    module_path: string@View,
    symbol: string@View,
    source_path: string@View,
    expected_module_path: string@View,
    expected_symbol: string@View,
    expected_source_path: string@View
) -> bool {
    return auditTextEquals(module_path, expected_module_path) &&
        auditTextEquals(symbol, expected_symbol) &&
        auditTextEquals(source_path, expected_source_path)
}

