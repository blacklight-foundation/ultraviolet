            "Source/Audit/SpecClarifications.uv"
        ) &&
        catalogSymbolTargetMatches(
            "HelloUltraviolet::Fixtures::AcceptedProjects",
            "validatedAcceptedProjectFixtureCount",
            "Fixtures/AcceptedProjects/CrossAssemblyImplementation/Source/CrossAssemblyImplementation/Library.uv",
