    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceKeys(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceModules(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceNames(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceParallelism(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceParsing(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourcePatterns(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourcePermissions(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourcePolymorphism(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceProcedures(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceSourceText(context) && passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceStatements(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceAsync(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceAttributes(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceAuthority(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceComptime(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceConformance(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceDataTypes(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceDiagnostics(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceExpressions(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceFFI(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceKeys(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceLowering(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceModalTypes(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceModules(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceNames(context) && passed
    passed = catalogCompiledSymbolsExecuteReferenceParallelism(context) && passed
    passed = catalogCompiledSymbolsExecuteReferencePatterns(context) && passed
    passed = catalogCompiledSymbolsExecuteReferencePermissions(context) && passed
