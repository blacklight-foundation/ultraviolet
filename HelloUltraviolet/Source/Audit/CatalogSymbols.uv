public procedure expectedCatalogCompiledSymbolCount() -> usize {
    return 602usize
}

public procedure catalogCompiledSymbolCount() -> usize {
    return 602usize
}

internal procedure catalogSymbolTargetMatches(
    module_path: string@View,
    symbol: string@View,
    source_path: string@View,
    expected_module_path: string@View,
    expected_symbol: string@View,
    expected_source_path: string@View
) -> bool {
    return auditTextEquals(module_path, expected_module_path) &&
        auditTextEquals(symbol, expected_symbol) &&
        auditTextEquals(source_path, expected_source_path)
}

internal procedure writeCatalogSymbolMessage(context: Context, text: string@View) -> bool {
    let output: Outcome<(), IoError> = context.fs~>write_stderr(text)
    return if output is {
        @Value {
            true
        }
        @Error {
            false
        }
    }
}

internal procedure recordCatalogSymbolExecution(
    context: Context,
    symbol: string@View,
    passed: bool
) -> bool {
    if passed {
        return true
    }

    if (!writeCatalogSymbolMessage(context, "catalog compiled symbol failed: ")) {
        return false
    }
    if (!writeCatalogSymbolMessage(context, symbol)) {
        return false
    }
    if (!writeCatalogSymbolMessage(context, "\n")) {
        return false
    }
    return false
}

public procedure catalogCompiledSymbolTargetsAreIndexed() -> bool {
    return catalogCompiledSymbolCount() == expectedCatalogCompiledSymbolCount() &&
        catalogSymbolTargetMatches(
            "HelloUltraviolet::Audit",
            "specClarificationLedgerIsIndexed",
            "Source/Audit/SpecClarifications.uv",
