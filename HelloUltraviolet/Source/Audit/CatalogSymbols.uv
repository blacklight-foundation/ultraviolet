        passed
    passed = traceCatalogSymbolGroup(context, "catalog start: FixturesRejectedSourceExpressions\n") &&
        passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceExpressions(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: FixturesRejectedSourceExpressions\n") &&
        passed
    passed = traceCatalogSymbolGroup(context, "catalog start: FixturesRejectedSourceFFI\n") &&
        passed
    passed = catalogCompiledSymbolsExecuteFixturesRejectedSourceFFI(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: FixturesRejectedSourceFFI\n") &&
