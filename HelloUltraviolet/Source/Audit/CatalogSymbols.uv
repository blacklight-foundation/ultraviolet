    passed = traceCatalogSymbolGroup(context, "catalog start: ReferencePermissions\n") && passed
    passed = catalogCompiledSymbolsExecuteReferencePermissions(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: ReferencePermissions\n") && passed
    passed = traceCatalogSymbolGroup(context, "catalog start: ReferencePolymorphism\n") && passed
    passed = catalogCompiledSymbolsExecuteReferencePolymorphism(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: ReferencePolymorphism\n") && passed
    passed = traceCatalogSymbolGroup(context, "catalog start: ReferenceProcedures\n") && passed
    passed = catalogCompiledSymbolsExecuteReferenceProcedures(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: ReferenceProcedures\n") && passed
    passed = traceCatalogSymbolGroup(context, "catalog start: ReferenceProjects\n") && passed
    passed = catalogCompiledSymbolsExecuteReferenceProjects(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: ReferenceProjects\n") && passed
    passed = traceCatalogSymbolGroup(context, "catalog start: ReferenceSourceText\n") && passed
    passed = catalogCompiledSymbolsExecuteReferenceSourceText(context) && passed
    passed = traceCatalogSymbolGroup(context, "catalog done: ReferenceSourceText\n") && passed
    passed = traceCatalogSymbolGroup(context, "catalog start: ReferenceStatements\n") && passed
