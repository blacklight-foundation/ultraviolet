public procedure catalogCompiledSymbolsExecute(context: Context) -> bool {
    return runAsyncAsyncTypeReference() &&
        runAttributesGeneralAttributesReference() &&
        runAuthorityBindingRuntimeStateReference() &&
        runAuthorityCapabilitiesReference() &&
        runAuthorityFileSystemReference() &&
        runAuthorityNetworkReference() &&
        runAuthorityRegionsAndFramesReference() &&
        runAuthoritySystemReference() &&
        runAuthorityTimeReference(context) &&
        runComptimeCompileTimeFormsReference() &&
        runConformanceBehaviorClassificationReference() &&
        runConformanceConstructVocabularyReference() &&
        runConformanceTranslationOrderingReference() &&
        runDataTypesArraysReference() &&
        runDataTypesEnumsReference() &&
