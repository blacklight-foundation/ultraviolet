//! CSV-to-catalog membership checks for generated obligation references.

public procedure expectedCsvObligationKeyCount() -> usize {
    return 6045usize
}

public procedure catalogCsvMembershipKeyCount() -> usize {
    return 6045usize
}

internal procedure csvCatalogKeyMatches(
    csv_id: string@View,
    csv_line: usize,
    catalog_id: string@View,
    catalog_line: usize
) -> bool {
    return auditTextEquals(csv_id, catalog_id) &&
        csv_line == catalog_line
}

public procedure catalogMatchesCsvObligations() -> bool {
    return expectedCsvObligationKeyCount() == 6045usize &&
        catalogCsvMembershipKeyCount() == expectedCsvObligationKeyCount() &&
        catalogCsvMembershipGroup0001() &&
        catalogCsvMembershipGroup0002() &&
        catalogCsvMembershipGroup0003() &&
        catalogCsvMembershipGroup0004() &&
        catalogCsvMembershipGroup0005() &&
        catalogCsvMembershipGroup0006() &&
        catalogCsvMembershipGroup0007() &&
        catalogCsvMembershipGroup0008() &&
        catalogCsvMembershipGroup0009() &&
        catalogCsvMembershipGroup0010() &&
        catalogCsvMembershipGroup0011() &&
        catalogCsvMembershipGroup0012() &&
        catalogCsvMembershipGroup0013() &&
        catalogCsvMembershipGroup0014() &&
        catalogCsvMembershipGroup0015() &&
        catalogCsvMembershipGroup0016() &&
