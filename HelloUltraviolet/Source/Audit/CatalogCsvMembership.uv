//! CSV-to-catalog membership checks for generated obligation references.

public procedure expectedCsvObligationKeyCount() -> usize {
    return 6045usize
}

public procedure catalogCsvMembershipKeyCount() -> usize {
    return 6045usize
}

internal procedure csvCatalogKeyMatches(
    csv_id: string@View,
    csv_line: usize,
    catalog_id: string@View,
    catalog_line: usize
) -> bool {
    return auditTextEquals(csv_id, catalog_id) &&
        csv_line == catalog_line
}

