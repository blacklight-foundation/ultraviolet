public procedure catalogCoverageIsComplete() -> bool {
    return generatedCatalogObligationCount() == EXPECTED_OBLIGATION_COUNT &&
        generatedCatalogValidatedObligationCount() == EXPECTED_OBLIGATION_COUNT
}
