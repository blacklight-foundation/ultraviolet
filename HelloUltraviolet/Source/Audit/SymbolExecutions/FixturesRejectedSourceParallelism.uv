//! Compiled symbol execution checks for FixturesRejectedSourceParallelism.

using HelloUltraviolet::Audit::FixtureCatalog::RejectedSource::{ validatedParallelismRejectedSourceFixtureCount }

public procedure catalogCompiledSymbolsExecuteFixturesRejectedSourceParallelism(context: Context) -> bool {
    var passed: bool = true
    passed = recordCatalogSymbolExecution(
        context,
        "validatedParallelismRejectedSourceFixtureCount",
        validatedParallelismRejectedSourceFixtureCount() > 0usize
    ) && passed
    return passed
}
