//! Compiled symbol execution checks for FixturesRejectedSourceParsing.

using HelloUltraviolet::Audit::FixtureCatalog::RejectedSource::{ validatedParsingRejectedSourceFixtureCount }

public procedure catalogCompiledSymbolsExecuteFixturesRejectedSourceParsing(context: Context) -> bool {
    var passed: bool = true
    passed = recordCatalogSymbolExecution(
        context,
        "validatedParsingRejectedSourceFixtureCount",
        validatedParsingRejectedSourceFixtureCount() > 0usize
    ) && passed
    return passed
}
