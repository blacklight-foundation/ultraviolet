//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.3 Expression Grammar.


public procedure countAppendixBCompleteGrammarReferenceBExpressionGrammarObligations() -> usize {
    return 3usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBExpressionGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.3.ExpressionGrammar",
        100535usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    if acceptedObligationEntryMatches(
        "req.B.3.ClosureExprUnionParameterParentheses",
        100613usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    if acceptedObligationEntryMatches(
        "grammar.B.3.ControlAndSpecialExpressionGrammar",
        100626usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
