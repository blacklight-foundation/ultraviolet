//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.1 Lexical Grammar.


public procedure countAppendixBCompleteGrammarReferenceBLexicalGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBLexicalGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.1.LexicalGrammar",
        99348usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
