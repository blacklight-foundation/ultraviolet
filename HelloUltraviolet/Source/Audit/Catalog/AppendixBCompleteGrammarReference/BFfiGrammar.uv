//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.13 FFI Grammar.


public procedure countAppendixBCompleteGrammarReferenceBFfiGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBFfiGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.13.FFIGrammar",
        101015usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
