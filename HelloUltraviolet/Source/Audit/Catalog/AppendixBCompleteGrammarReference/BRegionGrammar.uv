//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.14 Region Grammar.


public procedure countAppendixBCompleteGrammarReferenceBRegionGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBRegionGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.14.RegionGrammar",
        101041usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
