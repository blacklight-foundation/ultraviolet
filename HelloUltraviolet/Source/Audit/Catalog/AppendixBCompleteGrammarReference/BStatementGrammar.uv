//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.5 Statement Grammar.


public procedure countAppendixBCompleteGrammarReferenceBStatementGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBStatementGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.5.StatementGrammar",
        99659usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
