//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.12 Metaprogramming Grammar.


public procedure countAppendixBCompleteGrammarReferenceBMetaprogrammingGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBMetaprogrammingGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.12.MetaprogrammingGrammar",
        100982usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
