//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.11 Async Grammar.


public procedure countAppendixBCompleteGrammarReferenceBAsyncGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBAsyncGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.11.AsyncGrammar",
        101256usize,
        "HelloUltraviolet::Reference::Async",
        "runAsyncCompositionFormsReference",
        "Source/Reference/Async/CompositionForms.uv"
    ) {
        count = count + 1usize
    }
    return count
}
