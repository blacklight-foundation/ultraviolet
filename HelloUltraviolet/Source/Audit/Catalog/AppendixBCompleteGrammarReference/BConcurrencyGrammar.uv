//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.10 Concurrency Grammar.


public procedure countAppendixBCompleteGrammarReferenceBConcurrencyGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBConcurrencyGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.10.ConcurrencyGrammar",
        100919usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
