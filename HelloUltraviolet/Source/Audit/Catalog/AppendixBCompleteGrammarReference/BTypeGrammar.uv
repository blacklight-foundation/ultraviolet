//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.2 Type Grammar.


public procedure countAppendixBCompleteGrammarReferenceBTypeGrammarObligations() -> usize {
    return 3usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBTypeGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.2.TypeGrammar",
        100422usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    if acceptedObligationEntryMatches(
        "req.B.2.ClosureTypeUnionParameterParentheses",
        100482usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    if acceptedObligationEntryMatches(
        "grammar.B.2.GenericRefinementModalTypeGrammar",
        100495usize,
        "HelloUltraviolet::Reference::Parsing",
        "runParsingItemSequencingReference",
        "Source/Reference/Parsing/ItemSequencing.uv"
    ) {
        count = count + 1usize
    }
    return count
}
