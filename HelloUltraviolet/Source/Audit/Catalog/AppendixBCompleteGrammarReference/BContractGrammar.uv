//! Generated catalog markers for Appendix B. Complete Grammar Reference / B.7 Contract Grammar.


public procedure countAppendixBCompleteGrammarReferenceBContractGrammarObligations() -> usize {
    return 1usize
}

public procedure validatedAppendixBCompleteGrammarReferenceBContractGrammarObligations() -> usize {
    var count: usize = 0usize
    if acceptedObligationEntryMatches(
        "grammar.B.7.ContractGrammar",
        101056usize,
        "HelloUltraviolet::Reference::Expressions",
        "runExpressionsLoopControlReference",
        "Source/Reference/Expressions/Control.uv"
    ) {
        count = count + 1usize
    }
    return count
}
