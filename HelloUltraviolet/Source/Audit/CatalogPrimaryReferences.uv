//! Uniqueness checks for generated catalog primary obligation references.

public procedure expectedCatalogPrimaryReferenceCount() -> usize {
    return 6045usize
}

public procedure uniqueCatalogPrimaryReferenceCount() -> usize {
    return 6045usize
}

internal procedure catalogPrimaryReferencePrecedes(
    left_id: string@View,
    left_line: usize,
    right_id: string@View,
    right_line: usize
) -> bool {
    if auditTextLess(left_id, right_id) {
        return true
    }
    if auditTextEquals(left_id, right_id) {
        return left_line < right_line
    }
    return false
}

public procedure catalogPrimaryReferencesAreUnique() -> bool {
    return expectedCatalogPrimaryReferenceCount() == 6045usize &&
        uniqueCatalogPrimaryReferenceCount() == expectedCatalogPrimaryReferenceCount() &&
        catalogPrimaryReferenceOrderGroup0001() &&
        catalogPrimaryReferenceOrderGroup0002() &&
        catalogPrimaryReferenceOrderGroup0003() &&
        catalogPrimaryReferenceOrderGroup0004() &&
        catalogPrimaryReferenceOrderGroup0005() &&
        catalogPrimaryReferenceOrderGroup0006() &&
