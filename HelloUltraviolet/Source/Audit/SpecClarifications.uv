//! Compiled index of obligations whose source-level fixture shape needs SPEC clarification.

public record SpecClarification {
    public obligation_id: string@View
    public sourceability: string@View
    public exercise_kind: string@View
}

public procedure specClarification(
    obligation_id: string@View,
    sourceability: string@View,
    exercise_kind: string@View
) -> SpecClarification {
    return SpecClarification {
        obligation_id: obligation_id,
        sourceability: sourceability,
        exercise_kind: exercise_kind
    }
}

public procedure specClarificationMatches(
    clarification: SpecClarification,
    obligation_id: string@View,
    sourceability: string@View,
    exercise_kind: string@View
) -> bool {
    return auditTextEquals(clarification.obligation_id, obligation_id) &&
        auditTextEquals(clarification.sourceability, sourceability) &&
        auditTextEquals(clarification.exercise_kind, exercise_kind)
}

public procedure expectedSpecClarificationCount() -> usize {
    return 24usize
}

public procedure specClarificationCount() -> usize {
    return 24usize
}

