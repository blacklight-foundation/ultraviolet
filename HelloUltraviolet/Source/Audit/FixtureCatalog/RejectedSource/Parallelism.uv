//! Rejected structured-parallelism specimens.

internal procedure parallelismSpecimenMatches(
    name: string@View,
    fixture_path: string@View,
    source_path: string@View,
    expected_path: string@View,
    code: string@View,
    obligation_id: string@View
) -> bool {
    return rejectedSpecimenMatches(
        rejectedSpecimen(
            name,
            fixture_path,
            source_path,
            expected_path,
            expectedDiagnostic(code, obligation_id)
        ),
        name,
        fixture_path,
        source_path,
        expected_path,
        code,
        obligation_id
    )
}

public procedure parallelismRejectedSourceFixtureCount() -> usize {
    return 33usize
}

