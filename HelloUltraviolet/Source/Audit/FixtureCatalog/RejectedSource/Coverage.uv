//! Coverage checks for rejected-source fixture metadata.

public procedure expectedRejectedSourceFixtureCount() -> usize {
    return 447usize
}

public procedure rejectedSourceFixtureCount() -> usize {
    return sourceTextRejectedSourceFixtureCount() +
        parsingRejectedSourceFixtureCount() +
        attributesRejectedSourceFixtureCount() +
        dataTypesRejectedSourceFixtureCount() +
        modulesRejectedSourceFixtureCount() +
        namesRejectedSourceFixtureCount() +
        proceduresRejectedSourceFixtureCount() +
        statementsRejectedSourceFixtureCount() +
        permissionsRejectedSourceFixtureCount() +
        expressionsRejectedSourceFixtureCount() +
        patternsRejectedSourceFixtureCount() +
        polymorphismRejectedSourceFixtureCount() +
        ffiRejectedSourceFixtureCount() +
        keysRejectedSourceFixtureCount() +
        parallelismRejectedSourceFixtureCount() +
        comptimeRejectedSourceFixtureCount()
}

public procedure validatedRejectedSourceFixtureCount() -> usize {
    return validatedSourceTextRejectedSourceFixtureCount() +
        validatedParsingRejectedSourceFixtureCount() +
        validatedAttributesRejectedSourceFixtureCount() +
        validatedDataTypesRejectedSourceFixtureCount() +
        validatedModulesRejectedSourceFixtureCount() +
        validatedNamesRejectedSourceFixtureCount() +
        validatedProceduresRejectedSourceFixtureCount() +
        validatedStatementsRejectedSourceFixtureCount() +
        validatedPermissionsRejectedSourceFixtureCount() +
        validatedExpressionsRejectedSourceFixtureCount() +
        validatedPatternsRejectedSourceFixtureCount() +
        validatedPolymorphismRejectedSourceFixtureCount() +
        validatedFFIRejectedSourceFixtureCount() +
        validatedKeysRejectedSourceFixtureCount() +
        validatedParallelismRejectedSourceFixtureCount() +
        validatedComptimeRejectedSourceFixtureCount()
}

public procedure rejectedSourceFixturesAreIndexed() -> bool {
    return rejectedSourceFixtureCount() == expectedRejectedSourceFixtureCount() &&
        validatedRejectedSourceFixtureCount() == expectedRejectedSourceFixtureCount()
}
