//! Rejected attribute specimens.

public procedure attributesRejectedSourceFixtureCount() -> usize {
    return 20usize
}

internal procedure attributeRejectedFixtureMatches(
    name: string@View,
    fixture_path: string@View,
    source_path: string@View,
    expected_path: string@View,
    expected_code: string@View,
    obligation_id: string@View
) -> bool {
    return rejectedSpecimenMatches(
        rejectedSpecimen(
            name,
            fixture_path,
            source_path,
            expected_path,
            expectedDiagnostic(expected_code, obligation_id)
        ),
        name,
        fixture_path,
        source_path,
        expected_path,
        expected_code,
        obligation_id
    )
}

