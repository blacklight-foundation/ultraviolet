        "Fixtures/RejectedSource/Attributes/PackedLayoutOnEnum/Expected.uv",
        "E-MOD-2454",
        "diagnostics.LayoutAttributeDiagnostics"
    ) {
        count = count + 1usize
    }
    if rejectedSpecimenMatches(
        rejectedSpecimen(
            "ReservedVendorNamespace",
            "Fixtures/RejectedSource/Attributes/ReservedVendorNamespace",
            "Fixtures/RejectedSource/Attributes/ReservedVendorNamespace/Source/Main.uv",
            "Fixtures/RejectedSource/Attributes/ReservedVendorNamespace/Expected.uv",
            expectedDiagnostic("E-CNF-0402", "diagnostics.VendorAttributeDiagnostics")
        ),
        "ReservedVendorNamespace",
        "Fixtures/RejectedSource/Attributes/ReservedVendorNamespace",
        "Fixtures/RejectedSource/Attributes/ReservedVendorNamespace/Source/Main.uv",
        "Fixtures/RejectedSource/Attributes/ReservedVendorNamespace/Expected.uv",
        "E-CNF-0402",
