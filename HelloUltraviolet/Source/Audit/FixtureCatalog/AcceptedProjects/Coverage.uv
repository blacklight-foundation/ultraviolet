//! Coverage checks for accepted project fixture metadata.

public procedure expectedAcceptedProjectFixtureCount() -> usize {
    return 51usize
}

public procedure acceptedProjectFixtureCount() -> usize {
    return 51usize
}

internal procedure hostedExportLibraryExpectationMatches(
    expectation: AcceptedProjectExpectation,
    expectation_name: string@View,
    obligation_id: string@View
) -> bool {
    return acceptedProjectSpecimenMatches(
        acceptedProjectSpecimen(
            "HostedExportLibrary",
            "Fixtures/AcceptedProjects/HostedExportLibrary",
            "Fixtures/AcceptedProjects/HostedExportLibrary/Ultraviolet.toml",
            "Fixtures/AcceptedProjects/HostedExportLibrary/Source/Library.uv",
            "HostedExportLibrary",
            "library",
            expectation
        ),
        "HostedExportLibrary",
        "Fixtures/AcceptedProjects/HostedExportLibrary",
        "Fixtures/AcceptedProjects/HostedExportLibrary/Ultraviolet.toml",
        "Fixtures/AcceptedProjects/HostedExportLibrary/Source/Library.uv",
        "HostedExportLibrary",
        "library",
        expectation_name,
        obligation_id
    )
}

internal procedure expressionSemanticsExpectationMatches(
    expectation: AcceptedProjectExpectation,
    expectation_name: string@View,
    obligation_id: string@View
) -> bool {
    return acceptedProjectSpecimenMatches(
        acceptedProjectSpecimen(
            "ExpressionSemantics",
            "Fixtures/AcceptedProjects/ExpressionSemantics",
            "Fixtures/AcceptedProjects/ExpressionSemantics/Ultraviolet.toml",
            "Fixtures/AcceptedProjects/ExpressionSemantics/Source/Library.uv",
            "ExpressionSemantics",
            "library",
            expectation
        ),
        "ExpressionSemantics",
        "Fixtures/AcceptedProjects/ExpressionSemantics",
        "Fixtures/AcceptedProjects/ExpressionSemantics/Ultraviolet.toml",
        "Fixtures/AcceptedProjects/ExpressionSemantics/Source/Library.uv",
        "ExpressionSemantics",
        "library",
        expectation_name,
        obligation_id
    )
}

