public procedure acceptedProjectFixturesAreIndexed() -> bool {
    return acceptedProjectFixtureCount() == expectedAcceptedProjectFixtureCount() &&
        validatedAcceptedProjectFixtureCount() == expectedAcceptedProjectFixtureCount()
}
