//! Coverage checks for artifact project fixture metadata.

public procedure expectedArtifactProjectFixtureCount() -> usize {
    return 7usize
}

public procedure artifactProjectFixtureCount() -> usize {
    return 7usize
}

public procedure validatedArtifactProjectFixtureCount() -> usize {
    var count: usize = 0usize
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "StaticLibraryArchive",
            "Fixtures/ArtifactProjects/StaticLibraryArchive",
            "Fixtures/ArtifactProjects/StaticLibraryArchive/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/StaticLibraryArchive/Source/Library.uv",
            "Fixtures/ArtifactProjects/StaticLibraryArchive/build/lib/StaticLibraryArchive.lib",
            "Fixtures/ArtifactProjects/StaticLibraryArchive/build/obj/StaticLibraryArchive.obj",
            artifactExpectation("StaticLibraryPrimaryArtifact", "PrimaryArtifactSet")
        ),
        "StaticLibraryArchive",
        "Fixtures/ArtifactProjects/StaticLibraryArchive",
        "Fixtures/ArtifactProjects/StaticLibraryArchive/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/StaticLibraryArchive/Source/Library.uv",
        "Fixtures/ArtifactProjects/StaticLibraryArchive/build/lib/StaticLibraryArchive.lib",
        "Fixtures/ArtifactProjects/StaticLibraryArchive/build/obj/StaticLibraryArchive.obj",
        "StaticLibraryPrimaryArtifact",
        "PrimaryArtifactSet"
    ) {
        count = count + 1usize
    }
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "EmitLlLibrary",
            "Fixtures/ArtifactProjects/EmitLlLibrary",
            "Fixtures/ArtifactProjects/EmitLlLibrary/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/EmitLlLibrary/Source/Library.uv",
            "Fixtures/ArtifactProjects/EmitLlLibrary/build/ir/EmitLlLibrary.ll",
            "Fixtures/ArtifactProjects/EmitLlLibrary/build/obj/EmitLlLibrary.obj",
            artifactExpectation("LlvmIrArtifact", "IRSet")
        ),
        "EmitLlLibrary",
        "Fixtures/ArtifactProjects/EmitLlLibrary",
        "Fixtures/ArtifactProjects/EmitLlLibrary/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/EmitLlLibrary/Source/Library.uv",
        "Fixtures/ArtifactProjects/EmitLlLibrary/build/ir/EmitLlLibrary.ll",
        "Fixtures/ArtifactProjects/EmitLlLibrary/build/obj/EmitLlLibrary.obj",
        "LlvmIrArtifact",
        "IRSet"
    ) {
        count = count + 1usize
    }
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "EmitBcLibrary",
            "Fixtures/ArtifactProjects/EmitBcLibrary",
            "Fixtures/ArtifactProjects/EmitBcLibrary/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/EmitBcLibrary/Source/Library.uv",
            "Fixtures/ArtifactProjects/EmitBcLibrary/build/ir/EmitBcLibrary.bc",
            "Fixtures/ArtifactProjects/EmitBcLibrary/build/obj/EmitBcLibrary.obj",
            artifactExpectation("LlvmBitcodeArtifact", "def.24.LLVMText21Acceptance")
        ),
        "EmitBcLibrary",
        "Fixtures/ArtifactProjects/EmitBcLibrary",
        "Fixtures/ArtifactProjects/EmitBcLibrary/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/EmitBcLibrary/Source/Library.uv",
        "Fixtures/ArtifactProjects/EmitBcLibrary/build/ir/EmitBcLibrary.bc",
        "Fixtures/ArtifactProjects/EmitBcLibrary/build/obj/EmitBcLibrary.obj",
        "LlvmBitcodeArtifact",
        "def.24.LLVMText21Acceptance"
    ) {
        count = count + 1usize
    }
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "FlowProofRuntimeErasure",
            "Fixtures/ArtifactProjects/FlowProofRuntimeErasure",
            "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/Source/Library.uv",
            "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/build/ir/FlowProofRuntimeErasure.ll",
            "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/build/obj/FlowProofRuntimeErasure.obj",
            artifactExpectation("VerificationFactRuntimeErasure", "req.15.VerificationFactsNoRuntimeRepresentation")
        ),
        "FlowProofRuntimeErasure",
        "Fixtures/ArtifactProjects/FlowProofRuntimeErasure",
        "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/Source/Library.uv",
        "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/build/ir/FlowProofRuntimeErasure.ll",
        "Fixtures/ArtifactProjects/FlowProofRuntimeErasure/build/obj/FlowProofRuntimeErasure.obj",
        "VerificationFactRuntimeErasure",
        "req.15.VerificationFactsNoRuntimeRepresentation"
    ) {
        count = count + 1usize
    }
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "ExecutableOutput",
            "Fixtures/ArtifactProjects/ExecutableOutput",
            "Fixtures/ArtifactProjects/ExecutableOutput/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/ExecutableOutput/Source/Main.uv",
            "Fixtures/ArtifactProjects/ExecutableOutput/build/bin/ExecutableOutput.exe",
            "Fixtures/ArtifactProjects/ExecutableOutput/build/bin/ExecutableOutput.map",
            artifactExpectation("ExecutablePrimaryArtifact", "PrimaryArtifactSet")
        ),
        "ExecutableOutput",
        "Fixtures/ArtifactProjects/ExecutableOutput",
        "Fixtures/ArtifactProjects/ExecutableOutput/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/ExecutableOutput/Source/Main.uv",
        "Fixtures/ArtifactProjects/ExecutableOutput/build/bin/ExecutableOutput.exe",
        "Fixtures/ArtifactProjects/ExecutableOutput/build/bin/ExecutableOutput.map",
        "ExecutablePrimaryArtifact",
        "PrimaryArtifactSet"
    ) {
        count = count + 1usize
    }
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "ReducedEmptyDispatchPanic",
            "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic",
            "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Source/Main.uv",
            "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/build/bin/ReducedEmptyDispatchPanic.exe",
            "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/build/bin/ReducedEmptyDispatchPanic.map",
            artifactExpectation(
                "ReducedEmptyDispatchRuntimePanic",
                "requirement.20.StructuredParallelismRuntimePanicOwnership"
            )
        ),
        "ReducedEmptyDispatchPanic",
        "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic",
        "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Source/Main.uv",
        "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/build/bin/ReducedEmptyDispatchPanic.exe",
        "Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/build/bin/ReducedEmptyDispatchPanic.map",
        "ReducedEmptyDispatchRuntimePanic",
        "requirement.20.StructuredParallelismRuntimePanicOwnership"
    ) {
        count = count + 1usize
    }
    if artifactProjectSpecimenMatches(
        artifactProjectSpecimen(
            "AArch64DependencyObject",
            "Fixtures/ArtifactProjects/AArch64DependencyObject",
            "Fixtures/ArtifactProjects/AArch64DependencyObject/Ultraviolet.toml",
            "Fixtures/ArtifactProjects/AArch64DependencyObject/Source/Library.uv",
            "Fixtures/ArtifactProjects/AArch64DependencyObject/build/obj/AArch64DependencyObject.o",
            "Fixtures/ArtifactProjects/AArch64DependencyObject/build/.uv-incremental/AArch64DependencyObject.manifest",
            artifactExpectation("AArch64DependencyObject", "def.TargetProfile")
        ),
        "AArch64DependencyObject",
        "Fixtures/ArtifactProjects/AArch64DependencyObject",
        "Fixtures/ArtifactProjects/AArch64DependencyObject/Ultraviolet.toml",
        "Fixtures/ArtifactProjects/AArch64DependencyObject/Source/Library.uv",
        "Fixtures/ArtifactProjects/AArch64DependencyObject/build/obj/AArch64DependencyObject.o",
        "Fixtures/ArtifactProjects/AArch64DependencyObject/build/.uv-incremental/AArch64DependencyObject.manifest",
        "AArch64DependencyObject",
        "def.TargetProfile"
    ) {
        count = count + 1usize
    }
    return count
}

public procedure artifactProjectFixturesAreIndexed() -> bool {
    return artifactProjectFixtureCount() == expectedArtifactProjectFixtureCount() &&
        validatedArtifactProjectFixtureCount() == expectedArtifactProjectFixtureCount()
}
