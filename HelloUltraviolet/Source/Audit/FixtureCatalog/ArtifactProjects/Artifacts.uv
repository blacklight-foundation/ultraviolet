//! Runtime path checks for artifact project fixture source artifacts.

using HelloUltraviolet::Audit::{ auditTextContains }

internal procedure artifactProjectSourceArtifactsExist(
    context: Context,
    manifest_path: string@View,
    source_path: string@View
) -> bool {
    return context.io~>exists(manifest_path) &&
        context.io~>exists(source_path)
}

public procedure artifactProjectFixtureSourceArtifactsExist(context: Context) -> bool {
    return artifactProjectSourceArtifactsExist(
        context,
        "HelloUltraviolet/Fixtures/ArtifactProjects/StaticLibraryArchive/Ultraviolet.toml",
        "HelloUltraviolet/Fixtures/ArtifactProjects/StaticLibraryArchive/Source/Library.uv"
    ) &&
        artifactProjectSourceArtifactsExist(
        context,
        "HelloUltraviolet/Fixtures/ArtifactProjects/EmitLlLibrary/Ultraviolet.toml",
        "HelloUltraviolet/Fixtures/ArtifactProjects/EmitLlLibrary/Source/Library.uv"
    ) &&
        artifactProjectSourceArtifactsExist(
        context,
        "HelloUltraviolet/Fixtures/ArtifactProjects/EmitBcLibrary/Ultraviolet.toml",
        "HelloUltraviolet/Fixtures/ArtifactProjects/EmitBcLibrary/Source/Library.uv"
    ) &&
        artifactProjectSourceArtifactsExist(
            context,
            "HelloUltraviolet/Fixtures/ArtifactProjects/FlowProofRuntimeErasure/Ultraviolet.toml",
            "HelloUltraviolet/Fixtures/ArtifactProjects/FlowProofRuntimeErasure/Source/Library.uv"
        ) &&
        artifactProjectSourceArtifactsExist(
            context,
            "HelloUltraviolet/Fixtures/ArtifactProjects/ExecutableOutput/Ultraviolet.toml",
            "HelloUltraviolet/Fixtures/ArtifactProjects/ExecutableOutput/Source/Main.uv"
        ) &&
        artifactProjectSourceArtifactsExist(
            context,
            "HelloUltraviolet/Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Ultraviolet.toml",
            "HelloUltraviolet/Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Source/Main.uv"
        ) &&
        artifactProjectSourceArtifactsExist(
            context,
            "HelloUltraviolet/Fixtures/ArtifactProjects/AArch64DependencyObject/Ultraviolet.toml",
            "HelloUltraviolet/Fixtures/ArtifactProjects/AArch64DependencyObject/Source/Library.uv"
        )
}

internal procedure artifactProjectExpectedFileMatches(
    context: Context,
    expected_path: string@View,
    expected_text: string@View
) -> bool {
    let read_result: Outcome<unique string@Managed, IoError> = context.io~>read_file(expected_path)
    return if move read_result is {
        @Value { value } {
            let text: string@View = string::as_view(value)
            auditTextEquals(text, expected_text)
        }
        @Error {
            false
        }
    }
}

public procedure reducedEmptyDispatchPanicExpectedArtifactMatches(context: Context) -> bool {
    return artifactProjectExpectedFileMatches(
        context,
        "HelloUltraviolet/Fixtures/ArtifactProjects/ReducedEmptyDispatchPanic/Expected.uv",
        "//! Expected runtime panic metadata for the ReducedEmptyDispatchPanic artifact specimen.\n\nexpectedDiagnostic(\"P-SEM-2862\", \"requirement.20.StructuredParallelismRuntimePanicOwnership\")\nexpectedDiagnostic(\"P-SEM-2862\", \"diagnostics.20.StructuredParallelismSupplement\")\n"
    )
}

internal procedure artifactTextExcludes(
    context: Context,
    artifact_path: string@View,
    forbidden_text: string@View
) -> bool {
    let read_result: Outcome<unique string@Managed, IoError> = context.io~>read_file(artifact_path)
    return if move read_result is {
        @Value { value } {
            let text: string@View = string::as_view(value)
            !auditTextContains(text, forbidden_text)
        }
        @Error {
            false
        }
    }
}

public procedure artifactProjectRuntimeErasureArtifactsMatch(context: Context) -> bool {
    let ir_path: string@View =
        "HelloUltraviolet/Fixtures/ArtifactProjects/FlowProofRuntimeErasure/build/ir/FlowProofRuntimeErasure.ll"
    return context.io~>exists(ir_path) &&
        context.io~>exists(
            "HelloUltraviolet/Fixtures/ArtifactProjects/FlowProofRuntimeErasure/build/obj/FlowProofRuntimeErasure.obj"
        ) &&
        artifactTextExcludes(context, ir_path, "VerificationFact") &&
        artifactTextExcludes(context, ir_path, "FlowFactsAt") &&
        artifactTextExcludes(context, ir_path, "ProofContextAt") &&
        artifactTextExcludes(context, ir_path, "ContractFactsAt") &&
        artifactTextExcludes(context, ir_path, "ContractCheck") &&
        artifactTextExcludes(context, ir_path, "ContractViolation") &&
        artifactTextExcludes(context, ir_path, "Precondition")
}

public procedure artifactProjectAArch64DependencyObjectArtifactsExist(context: Context) -> bool {
    return context.io~>exists(
        "HelloUltraviolet/Fixtures/ArtifactProjects/AArch64DependencyObject/build/obj/AArch64DependencyObject.o"
    ) &&
        context.io~>exists(
            "HelloUltraviolet/Fixtures/ArtifactProjects/AArch64DependencyObject/build/.ultraviolet-incremental/AArch64DependencyObject.manifest"
        )
}

public procedure artifactProjectEmitBcLibraryArtifactsExist(context: Context) -> bool {
    return context.io~>exists(
        "HelloUltraviolet/Fixtures/ArtifactProjects/EmitBcLibrary/build/ir/EmitBcLibrary.bc"
    ) &&
        context.io~>exists(
            "HelloUltraviolet/Fixtures/ArtifactProjects/EmitBcLibrary/build/obj/EmitBcLibrary.obj"
        ) &&
        context.io~>exists(
            "HelloUltraviolet/Fixtures/ArtifactProjects/EmitBcLibrary/build/lib/EmitBcLibrary.lib"
        )
}
