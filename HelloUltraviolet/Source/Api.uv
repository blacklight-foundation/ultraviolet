public record ReferenceResult {
    public passed: bool
    public exercised_sections: usize
}

public procedure referenceResult(
    passed: bool,
    exercised_sections: usize
) -> ReferenceResult {
    return ReferenceResult {
        passed: passed,
        exercised_sections: exercised_sections
    }
}

internal procedure writeReferenceMessage(context: Context, text: string@View) -> bool {
    let output: Outcome<(), IoError> = context.io~>write_stderr(text)
    return if output is {
        @Value {
            true
        }
        @Error {
            false
        }
    }
}

internal procedure recordReferenceResult(
    context: Context,
    name: string@View,
    passed: bool
) -> bool {
    if passed {
        return true
    }

    if (!writeReferenceMessage(context, "reference failed: ")) {
        return false
    }
    if (!writeReferenceMessage(context, name)) {
        return false
    }
    if (!writeReferenceMessage(context, "\n")) {
        return false
    }
    return false
}

public procedure runReferenceCorpus(context: Context) -> ReferenceResult {
    var passed: bool = true
    passed = recordReferenceResult(
        context,
        "catalogCoverageIsComplete",
        catalogCoverageIsComplete()
