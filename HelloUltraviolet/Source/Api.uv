public record ReferenceResult {
    public passed: bool
    public exercised_sections: usize
}

public procedure referenceResult(
    passed: bool,
    exercised_sections: usize
) -> ReferenceResult {
    return ReferenceResult {
        passed: passed,
        exercised_sections: exercised_sections
    }
}

internal procedure writeReferenceMessage(context: Context, text: string@View) -> bool {
    let output: Outcome<(), IoError> = context.fs~>write_stderr(text)
    return if output is {
        @Value {
            true
        }
        @Error {
            false
        }
    }
}

internal procedure recordReferenceResult(
    context: Context,
    name: string@View,
    passed: bool
) -> bool {
    if passed {
        return true
    }

    if (!writeReferenceMessage(context, "reference failed: ")) {
        return false
    }
    if (!writeReferenceMessage(context, name)) {
        return false
    }
    if (!writeReferenceMessage(context, "\n")) {
        return false
    }
    return false
}

public procedure runReferenceCorpus(context: Context) -> ReferenceResult {
    var passed: bool = true
    passed = passed && recordReferenceResult(
        context,
        "catalogCoverageIsComplete",
        catalogCoverageIsComplete()
    )
    passed = passed && recordReferenceResult(
        context,
        "catalogMatchesCsvObligations",
        catalogMatchesCsvObligations()
    )
    passed = passed && recordReferenceResult(
        context,
        "catalogPrimaryReferencesAreUnique",
        catalogPrimaryReferencesAreUnique()
    )
    passed = passed && recordReferenceResult(
        context,
        "catalogSourcePathsExist",
        catalogSourcePathsExist(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "catalogCompiledSymbolsExecute",
        catalogCompiledSymbolsExecute(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "acceptedProjectFixturesAreIndexed",
        acceptedProjectFixturesAreIndexed()
    )
    passed = passed && recordReferenceResult(
        context,
        "acceptedProjectFixtureArtifactsExist",
        acceptedProjectFixtureArtifactsExist(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "artifactProjectFixturesAreIndexed",
        artifactProjectFixturesAreIndexed()
    )
    passed = passed && recordReferenceResult(
        context,
        "artifactProjectFixtureSourceArtifactsExist",
        artifactProjectFixtureSourceArtifactsExist(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "artifactProjectRuntimeErasureArtifactsMatch",
        artifactProjectRuntimeErasureArtifactsMatch(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "reducedEmptyDispatchPanicExpectedArtifactMatches",
        reducedEmptyDispatchPanicExpectedArtifactMatches(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "diagnosticSourceFixturesAreIndexed",
        diagnosticSourceFixturesAreIndexed()
    )
    passed = passed && recordReferenceResult(
        context,
        "diagnosticSourceFixtureArtifactsExist",
        diagnosticSourceFixtureArtifactsExist(context)
    )
    passed = passed && recordReferenceResult(
        context,
        "validTransmuteTargetExpectedDiagnosticFileMatches",
