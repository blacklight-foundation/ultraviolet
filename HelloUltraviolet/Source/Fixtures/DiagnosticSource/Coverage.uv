//! Coverage checks for diagnostic-source fixture metadata.

public procedure expectedDiagnosticSourceFixtureCount() -> usize {
    return 19usize
}

public procedure diagnosticSourceFixtureCount() -> usize {
    return expressionsDiagnosticSourceFixtureCount() +
        asyncDiagnosticSourceFixtureCount() +
        keysDiagnosticSourceFixtureCount() +
        parallelismDiagnosticSourceFixtureCount()
}

public procedure validatedDiagnosticSourceFixtureCount() -> usize {
    return validatedExpressionsDiagnosticSourceFixtureCount() +
        validatedAsyncDiagnosticSourceFixtureCount() +
        validatedKeysDiagnosticSourceFixtureCount() +
        validatedParallelismDiagnosticSourceFixtureCount()
}

public procedure diagnosticSourceFixturesAreIndexed() -> bool {
    return diagnosticSourceFixtureCount() == expectedDiagnosticSourceFixtureCount() &&
        validatedDiagnosticSourceFixtureCount() == expectedDiagnosticSourceFixtureCount()
}
