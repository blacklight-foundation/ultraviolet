//! Runtime content checks for rejected-source expected diagnostic metadata.

internal procedure expectedDiagnosticFileMatches(
    context: Context,
    expected_path: string@View,
    expected_text: string@View
) -> bool {
    let read_result: Outcome<unique string@Managed, IoError> = context.fs~>read_file(expected_path)
    return if move read_result is {
        @Value { value } {
            let text: string@View = string::as_view(value)
            auditTextEquals(text, expected_text)
        }
        @Error {
            false
        }
    }
}

public procedure unterminatedStringExpectedDiagnosticFileMatches(context: Context) -> bool {
    return expectedDiagnosticFileMatches(
        context,
        "HelloUltraviolet/Fixtures/RejectedSource/SourceText/UnterminatedString/Expected.uv",
        "//! Expected diagnostic metadata for the UnterminatedString rejected-source specimen.\n\nexpectedDiagnostic(\"E-SRC-0301\", \"Lex-String-Unterminated\")\n"
    )
}

