//! Runtime path checks for rejected-source fixture artifacts.

internal procedure rejectedFixtureArtifactsExist(
    context: Context,
    manifest_path: string@View,
    source_path: string@View,
    expected_path: string@View
) -> bool {
    return context.fs~>exists(manifest_path) &&
        context.fs~>exists(source_path) &&
        context.fs~>exists(expected_path)
}

public procedure rejectedSourceFixtureArtifactsExist(context: Context) -> bool {
    var artifacts_exist: bool = true
    artifacts_exist = artifacts_exist && rejectedFixtureArtifactsExist(
        context,
        "HelloUltraviolet/Fixtures/RejectedSource/SourceText/UnterminatedString/Ultraviolet.toml",
        "HelloUltraviolet/Fixtures/RejectedSource/SourceText/UnterminatedString/Source/Main.uv",
