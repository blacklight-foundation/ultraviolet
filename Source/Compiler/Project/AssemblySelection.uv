// Obligation responsibility: Source/Compiler/Project/AssemblySelection.uv
//
// This file owns selected-assembly command target resolution:
//
// - Select-Only@L3872
//   |As| = 1    target = ⊥    As = [A_0]
//   Γ ⊢ SelectAssembly(As, target) ⇓ A_0
// - Select-Only-Exe@L3890
//   |As| > 1    target = ⊥
//   |{A ∈ As | A.kind = "executable"}| = 1
//   Γ ⊢ SelectAssembly(As, target) ⇓ A_e
// - Select-By-Name@L3908
//   target ≠ ⊥    A ∈ As    A.name = target
//   Γ ⊢ SelectAssembly(As, target) ⇓ A
// - Select-Err@L3926
//   Ambiguous absent selection or missing named selection emits
//   Code(Assembly-Select-Err).

public modal AssemblyTarget {
    @Absent {
    }

    @Named {
        public name: AssemblyName
    }
}

public type AssemblyTargetValue =
    AssemblyTarget@Absent | AssemblyTarget@Named

public modal AssemblySelection {
    @Selected {
        public assembly_name: AssemblyName
    }

    @Missing {
        public requested_name: AssemblyName
    }

    @Ambiguous {
    }
}

public type AssemblySelectionValue =
    AssemblySelection@Selected |
    AssemblySelection@Missing |
    AssemblySelection@Ambiguous

public procedure absentAssemblyTarget() -> AssemblyTargetValue {
    return AssemblyTarget@Absent {}
}

public procedure namedAssemblyTarget(name: AssemblyName) -> AssemblyTargetValue {
    return AssemblyTarget@Named { name: name }
}

public procedure selectAssembly(
    assemblies: AssemblyListValue,
    target: AssemblyTargetValue
) -> AssemblySelectionValue {
    return if target is {
        @Absent {
            selectAssemblyFromAbsentTarget(assemblies)
        }
        @Named { name } {
            selectAssemblyByNameFromAssemblies(assemblies, name)
        }
    }
}

public procedure selectAssemblyByName(
    project: Project,
    requested_name: AssemblyName
) -> AssemblySelectionValue {
    return selectAssemblyByNameFromAssemblies(project.assemblies, requested_name)
}

internal procedure selectAssemblyByNameFromAssemblies(
    assemblies: AssemblyListValue,
    requested_name: AssemblyName
) -> AssemblySelectionValue {
    let lookup: AssemblyLookupValue = findAssemblyInList(assemblies, requested_name)
    return if lookup is {
        @Found { assembly_name } {
            AssemblySelection@Selected { assembly_name: assembly_name }
        }
        @Missing { name } {
            AssemblySelection@Missing { requested_name: name }
        }
    }
}

public procedure selectedAssembly(assembly_name: AssemblyName) -> AssemblySelectionValue {
    return AssemblySelection@Selected { assembly_name: assembly_name }
}

public procedure missingAssemblySelection(
    requested_name: AssemblyName
) -> AssemblySelectionValue {
    return AssemblySelection@Missing { requested_name: requested_name }
}

public procedure ambiguousAssemblySelection() -> AssemblySelectionValue {
    return AssemblySelection@Ambiguous {}
}

internal procedure selectAssemblyFromAbsentTarget(
    assemblies: AssemblyListValue
) -> AssemblySelectionValue {
    if (assemblyListCount(assemblies) == 1) {
        return selectOnlyAssembly(assemblies)
    }
    let executable_count: usize = executableAssemblyCount(assemblies)
    if (executable_count == 1) {
        return selectOnlyExecutableAssembly(assemblies)
    }
    return ambiguousAssemblySelection()
}

internal procedure selectOnlyAssembly(
    assemblies: AssemblyListValue
) -> AssemblySelectionValue {
    return if assemblies is {
        @Empty {
            ambiguousAssemblySelection()
        }
        @Entry { assembly: project_assembly } {
            selectedAssembly(project_assembly.name)
        }
    }
}

internal procedure selectOnlyExecutableAssembly(
    assemblies: AssemblyListValue
) -> AssemblySelectionValue {
    return if assemblies is {
        @Empty {
            ambiguousAssemblySelection()
        }
        @Entry { assembly: project_assembly, tail } {
            if (assemblyKindIsExecutable(project_assembly.kind)) {
                selectedAssembly(project_assembly.name)
            } else {
                selectOnlyExecutableAssembly(tail)
            }
        }
    }
}

internal procedure executableAssemblyCount(
    assemblies: AssemblyListValue
) -> usize {
    return if assemblies is {
        @Empty {
            0
        }
        @Entry { assembly: project_assembly, tail } {
            if (assemblyKindIsExecutable(project_assembly.kind)) {
                1 + executableAssemblyCount(tail)
            } else {
                executableAssemblyCount(tail)
            }
        }
    }
}

internal procedure assemblyKindIsExecutable(kind: AssemblyKindValue) -> bool {
    return if kind is {
        @Executable {
            true
        }
        @Library {
            false
        }
        @Dependency {
            false
        }
    }
}
