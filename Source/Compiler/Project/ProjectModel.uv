}

public procedure emptyProjectTextStorage() -> ProjectTextStorageListValue {
    return ProjectTextStorageList@Empty {}
}

public procedure projectTextStorageListEntry(
    move text: unique string@Managed,
    move tail: ProjectTextStorageListValue
) -> ProjectTextStorageListValue {
    return ProjectTextStorageList@Entry {
        _text: move text,
        tail: move tail
    }
}

public procedure projectTextStorageListCount(
    storage: ProjectTextStorageListValue
) -> usize {
    return if storage is {
        @Empty {
            storage~>count()
        }
        @Entry {
            storage~>count()
        }
    }
}

public procedure sourceFile(
    path: SourceFilePath,
    module_path: ModulePath,
    file_order: usize
) -> SourceFile {
    return SourceFile {
        path: path,
        module_path: module_path,
        file_order: file_order
    }
}

