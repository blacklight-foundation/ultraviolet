internal let PROJECT_PATH_SEPARATOR: u8 = 47
internal let PROJECT_COLON: u8 = 58
internal let PROJECT_DOT: u8 = 46
internal let PROJECT_U_LOWER: u8 = 117
internal let PROJECT_V_LOWER: u8 = 118

public modal AssemblyKind {
    @Executable {
    }

    @Library {
    }

    @Dependency {
    }
}

public type AssemblyKindValue =
    AssemblyKind@Executable |
    AssemblyKind@Library |
    AssemblyKind@Dependency

public modal LinkKind {
    @Static {
    }

    @Shared {
    }

    @None {
    }
}

public type LinkKindValue =
    LinkKind@Static | LinkKind@Shared | LinkKind@None

public record ProjectRoot {
    public text: string@View
}

public record AssemblyName {
    public text: string@View
}

public record ModulePath {
    public text: string@View
}

public record DirectoryPath {
    public text: string@View
}

public record SourceFilePath {
    public text: string@View
}

public modal ProjectTextStorageList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        private _text: unique string@Managed
        public tail: ProjectTextStorageListValue

        public procedure count(~) -> usize {
            return 1 + projectTextStorageListCount(self.tail)
        }
    }
}

public type ProjectTextStorageListValue =
    ProjectTextStorageList@Empty | ProjectTextStorageList@Entry

public record SourceFile {
    public path: SourceFilePath
    public module_path: ModulePath
    public file_order: usize
}

public modal SourceFileList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public file: SourceFile
        public tail: SourceFileListValue

        public procedure count(~) -> usize {
            return 1 + sourceFileListCount(self.tail)
        }
    }
}

public type SourceFileListValue =
    SourceFileList@Empty | SourceFileList@Entry

public record Module {
    public path: ModulePath
    public directory: DirectoryPath
    public source_files: SourceFileListValue
}

public modal ModuleList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public module: Module
        public tail: ModuleListValue

        public procedure count(~) -> usize {
            return 1 + moduleListCount(self.tail)
        }
    }
}

public type ModuleListValue =
    ModuleList@Empty | ModuleList@Entry

public record Assembly {
    public name: AssemblyName
    public kind: AssemblyKindValue
    public link_kind: LinkKindValue
    public root_directory: DirectoryPath
    public modules: ModuleListValue
}

public modal AssemblyList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public assembly: Assembly
        public tail: AssemblyListValue

        public procedure count(~) -> usize {
            return 1 + assemblyListCount(self.tail)
        }
    }
}

public type AssemblyListValue =
    AssemblyList@Empty | AssemblyList@Entry

public record Project {
    public root: ProjectRoot
    public assemblies: AssemblyListValue
    private _text_storage: ProjectTextStorageListValue
}

public modal AssemblyLookup {
    @Found {
        public assembly_name: AssemblyName
    }

    @Missing {
        public name: AssemblyName
    }
}

public type AssemblyLookupValue =
    AssemblyLookup@Found | AssemblyLookup@Missing

public modal ModuleLookup {
    @Found {
        public path: ModulePath
    }

    @Missing {
        public path: ModulePath
    }
}

public type ModuleLookupValue =
    ModuleLookup@Found | ModuleLookup@Missing

