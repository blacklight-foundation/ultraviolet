        name: name,
        kind: kind,
        link_kind: link_kind,
        root_directory: root_directory,
        modules: move modules
    }
}

public procedure emptyAssemblies() -> AssemblyListValue {
    return AssemblyList@Empty {}
}

public procedure assemblyListEntry(
    move assembly: Assembly,
    move tail: AssemblyListValue
) -> AssemblyListValue {
    return AssemblyList@Entry {
        assembly: move assembly,
        tail: move tail
    }
}

public procedure project(
    root: ProjectRoot,
    move assemblies: AssemblyListValue
) -> Project {
    return projectWithTextStorage(
        root,
        move assemblies,
        emptyProjectTextStorage()
    )
}

public procedure projectWithTextStorage(
    root: ProjectRoot,
    move assemblies: AssemblyListValue,
    move text_storage: ProjectTextStorageListValue
) -> Project {
    return Project {
        root: root,
        assemblies: move assemblies,
        _text_storage: move text_storage
    }
}

public procedure sourceFileListCount(source_files: SourceFileListValue) -> usize {
    return if source_files is {
        @Empty {
            source_files~>count()
        }
        @Entry {
            source_files~>count()
        }
    }
}

public procedure moduleListCount(modules: ModuleListValue) -> usize {
    return if modules is {
        @Empty {
            modules~>count()
        }
        @Entry {
            modules~>count()
        }
    }
}

public procedure assemblyListCount(assemblies: AssemblyListValue) -> usize {
    return if assemblies is {
        @Empty {
            assemblies~>count()
        }
        @Entry {
            assemblies~>count()
        }
    }
}

public procedure findAssemblyByName(
    project: Project,
    name: AssemblyName
) -> AssemblyLookupValue {
    return findAssemblyInList(project.assemblies, name)
}

internal procedure findAssemblyInList(
    assemblies: AssemblyListValue,
    name: AssemblyName
) -> AssemblyLookupValue {
    return if assemblies is {
        @Empty {
            AssemblyLookup@Missing { name: name }
        }
        @Entry { assembly: candidate_assembly, tail } {
            if (projectTextEquals(candidate_assembly.name.text, name.text)) {
                AssemblyLookup@Found { assembly_name: candidate_assembly.name }
            } else {
                findAssemblyInList(tail, name)
            }
        }
    }
}

public procedure findModuleInProject(
    project: Project,
    path: ModulePath
) -> ModuleLookupValue {
    return findModuleInAssemblies(project.assemblies, path)
}

internal procedure findModuleInAssemblies(
    assemblies: AssemblyListValue,
    path: ModulePath
) -> ModuleLookupValue {
    return if assemblies is {
        @Empty {
            ModuleLookup@Missing { path: path }
        }
        @Entry { assembly: candidate_assembly, tail } {
            let found: ModuleLookupValue =
                findModuleInList(candidate_assembly.modules, path)
            if found is {
                @Found {
                    found
                }
                @Missing {
                    findModuleInAssemblies(tail, path)
                }
            }
        }
    }
}

public procedure findModuleInList(
    modules: ModuleListValue,
    path: ModulePath
) -> ModuleLookupValue {
    return if modules is {
        @Empty {
            ModuleLookup@Missing { path: path }
        }
        @Entry { module: candidate_module, tail } {
            if (projectTextEquals(candidate_module.path.text, path.text)) {
                ModuleLookup@Found { path: candidate_module.path }
            } else {
                findModuleInList(tail, path)
            }
        }
    }
}

public procedure moduleListContainsPath(
    modules: ModuleListValue,
    path: ModulePath
) -> bool {
    return if modules is {
        @Empty {
            false
        }
        @Entry { module: candidate_module, tail } {
            if (projectTextEquals(candidate_module.path.text, path.text)) {
                true
            } else {
                moduleListContainsPath(tail, path)
            }
        }
    }
}

public procedure assemblyHasTestsSubtree(assembly: Assembly) -> bool {
    let name: AssemblyName = assembly.name
    return moduleListHasTestsSubtree(assembly.modules, name)
}

internal procedure moduleListHasTestsSubtree(
    modules: ModuleListValue,
    name: AssemblyName
) -> bool {
    return if modules is {
        @Empty {
            false
        }
        @Entry { module: candidate_module, tail } {
            if (modulePathIsTestsSubtree(name, candidate_module.path)) {
                true
            } else {
                moduleListHasTestsSubtree(tail, name)
            }
        }
    }
}

public procedure modulePathIsTestsSubtree(
    name: AssemblyName,
    path: ModulePath
) -> bool {
    let name_length: usize = string::length(name.text)
    let path_length: usize = string::length(path.text)
    let tests_length: usize = 5
    let prefix_length: usize = name_length + 2 + tests_length

    if (path_length < prefix_length) {
        return false
    }
    if (!projectTextStartsWith(path.text, name.text)) {
        return false
    }
    if (projectTextByte(path.text, name_length) != PROJECT_COLON) {
        return false
    }
    if (projectTextByte(path.text, name_length + 1) != PROJECT_COLON) {
        return false
    }
    if (!projectTextSegmentEquals(path.text, name_length + 2, "Tests")) {
        return false
    }
    if (path_length == prefix_length) {
        return true
    }
    if (path_length < prefix_length + 2) {
        return false
    }
    return projectTextByte(path.text, prefix_length) == PROJECT_COLON &&
        projectTextByte(path.text, prefix_length + 1) == PROJECT_COLON
}

public procedure modulePathContains(
    candidate: ModulePath,
    prefix: ModulePath
) -> bool {
    let candidate_length: usize = string::length(candidate.text)
    let prefix_length: usize = string::length(prefix.text)
    if (candidate_length < prefix_length) {
        return false
    }
    if (!projectTextStartsWith(candidate.text, prefix.text)) {
        return false
    }
    if (candidate_length == prefix_length) {
        return true
    }
    if (candidate_length < prefix_length + 2) {
        return false
    }
    return projectTextByte(candidate.text, prefix_length) == PROJECT_COLON &&
        projectTextByte(candidate.text, prefix_length + 1) == PROJECT_COLON
}

public procedure sourceFileHasUvExtension(path: SourceFilePath) -> bool {
    let length: usize = string::length(path.text)
    if (length < 3) {
        return false
    }
    return projectTextByte(path.text, length - 3) == PROJECT_DOT &&
        projectTextByte(path.text, length - 2) == PROJECT_U_LOWER &&
        projectTextByte(path.text, length - 1) == PROJECT_V_LOWER
}

public procedure projectTextEquals(left: string@View, right: string@View) -> bool {
    let left_length: usize = string::length(left)
    let right_length: usize = string::length(right)
    if (left_length != right_length) {
        return false
    }
    return projectTextSegmentEquals(left, 0, right)
}

public procedure projectTextStartsWith(text: string@View, prefix: string@View) -> bool {
    if (string::length(text) < string::length(prefix)) {
        return false
    }
    return projectTextSegmentEquals(text, 0, prefix)
}

public procedure projectTextSegmentEquals(
    text: string@View,
    start: usize,
    expected: string@View
) -> bool
{
    let expected_length: usize = string::length(expected)
    if (start + expected_length > string::length(text)) {
        return false
    }

    var index: usize = 0

    loop {
        if (index >= expected_length) {
            break
        }

        if (projectTextByte(text, start + index) != projectTextByte(expected, index)) {
            return false
        }

        index = index + 1
    }

    return true
}

internal procedure projectTextByte(text: string@View, index: usize) -> u8
|: index < string::length(text)
{
    let view: bytes@View = bytes::view_string(text)
    let data: const [u8] = bytes::as_slice(view)
    return data[index]
}
