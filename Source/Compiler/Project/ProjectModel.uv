}

public procedure sharedLinkKind() -> LinkKindValue {
    return LinkKind@Shared {}
}

public procedure noLinkKind() -> LinkKindValue {
    return LinkKind@None {}
}

public procedure projectRoot(text: string@View) -> ProjectRoot {
    return ProjectRoot { text: text }
}

public procedure assemblyName(text: string@View) -> AssemblyName {
    return AssemblyName { text: text }
}

public procedure modulePath(text: string@View) -> ModulePath {
    return ModulePath { text: text }
}

public procedure directoryPath(text: string@View) -> DirectoryPath {
    return DirectoryPath { text: text }
}

public procedure sourceFilePath(text: string@View) -> SourceFilePath {
