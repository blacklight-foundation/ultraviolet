    return ModuleList@Empty {}
}

public procedure moduleListEntry(
    move module: Module,
    move tail: ModuleListValue
) -> ModuleListValue {
    return ModuleList@Entry {
        module: move module,
        tail: move tail
    }
}

public procedure assembly(
    name: AssemblyName,
    kind: AssemblyKindValue,
    link_kind: LinkKindValue,
    root_directory: DirectoryPath,
    move modules: ModuleListValue
) -> Assembly {
