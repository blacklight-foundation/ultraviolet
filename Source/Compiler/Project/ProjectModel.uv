}

public procedure sourceFileListEntry(
    file: SourceFile,
    move tail: SourceFileListValue
) -> SourceFileListValue {
    return SourceFileList@Entry {
        file: file,
        tail: move tail
    }
}

public procedure module(
    path: ModulePath,
    directory: DirectoryPath,
    move source_files: SourceFileListValue
) -> Module {
    return Module {
        path: path,
        directory: directory,
        source_files: move source_files
    }
}

