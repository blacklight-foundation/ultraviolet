internal procedure reverseManifestAssemblies(
    move source: ManifestAssemblyListValue,
    move target: ManifestAssemblyListValue
) -> ManifestAssemblyListValue {
    return if source is {
        @Empty {
            move target
        }
        @Entry { assembly: manifest_assembly, tail } {
            reverseManifestAssemblies(
                move tail,
                manifestAssemblyListEntry(manifest_assembly, move target)
            )
        }
    }
}

internal procedure manifestLineEnd(text: string@View, start: usize) -> usize {
    let length: usize = string::length(text)
    var index: usize = start
    loop {
        if (index >= length) {
            break
        }
        if (manifestTextByteEquals(text, index, MANIFEST_LF)) {
            break
        }
        index = index + 1
    }
    return index
}

internal procedure manifestNextLineStart(text: string@View, line_end: usize) -> usize {
    if (line_end < string::length(text)) {
        if (manifestTextByteEquals(text, line_end, MANIFEST_LF)) {
            return line_end + 1
        }
    }
    return string::length(text)
}

internal procedure manifestTrimStart(
    text: string@View,
    start: usize,
    end: usize
) -> usize {
    var index: usize = start
    loop {
        if (index >= end) {
            break
        }
        if (!manifestTextByteIsHorizontalSpace(text, index)) {
            break
        }
        index = index + 1
    }
    return index
}

internal procedure manifestTrimEnd(
    text: string@View,
    start: usize,
    end: usize
) -> usize {
    var index: usize = end
    loop {
        if (index <= start) {
            break
        }
        if (!manifestTextByteIsHorizontalSpaceOrCR(text, index - 1)) {
            break
        }
        index = index - 1
    }
    return index
}

internal procedure manifestKeyEnd(text: string@View, start: usize, end: usize) -> usize {
    var index: usize = start
    loop {
        if (index >= end) {
            break
        }
        if (manifestTextByteEndsKey(text, index)) {
            break
        }
        index = index + 1
    }
    return index
}

internal procedure manifestStringLiteralEnd(
    text: string@View,
    start: usize,
    end: usize
) -> usize {
    var index: usize = start
    loop {
        if (index >= end) {
            break
        }
        if (manifestTextByteEquals(text, index, MANIFEST_QUOTE)) {
            break
        }
        index = index + 1
    }
    return index
}

internal procedure manifestBareValueEnd(
    text: string@View,
    start: usize,
    end: usize
) -> usize {
    var index: usize = start
    loop {
        if (index >= end) {
            break
        }
        if (manifestTextByteIsHorizontalSpace(text, index) ||
            manifestTextByteEquals(text, index, MANIFEST_HASH)) {
            break
        }
        index = index + 1
    }
    return index
}

internal procedure manifestTextByteEquals(
    text: string@View,
    index: usize,
    expected: u8
) -> bool {
    if (index >= string::length(text)) {
        return false
    }
    return manifestTextByte(text, index) == expected
}

internal procedure manifestTextByteIsHorizontalSpace(
    text: string@View,
    index: usize
) -> bool {
    if (index >= string::length(text)) {
        return false
    }
    return manifestByteIsHorizontalSpace(manifestTextByte(text, index))
}

internal procedure manifestTextByteIsHorizontalSpaceOrCR(
    text: string@View,
    index: usize
) -> bool {
    if (index >= string::length(text)) {
        return false
    }
    let byte: u8 = manifestTextByte(text, index)
    return manifestByteIsHorizontalSpace(byte) || byte == MANIFEST_CR
}

internal procedure manifestTextByteEndsKey(text: string@View, index: usize) -> bool {
    if (index >= string::length(text)) {
        return true
    }
    let byte: u8 = manifestTextByte(text, index)
    return manifestByteIsHorizontalSpace(byte) || byte == MANIFEST_EQUALS
}

internal procedure manifestLineEquals(
    text: string@View,
    start: usize,
    end: usize,
    expected: string@View
) -> bool {
    if (end - start != string::length(expected)) {
        return false
    }
    return manifestTextSegmentEquals(text, start, expected)
}

internal procedure manifestTextEquals(left: string@View, right: string@View) -> bool {
    if (string::length(left) != string::length(right)) {
        return false
    }
    return manifestTextSegmentEquals(left, 0, right)
}

internal procedure manifestTextSegmentEquals(
    text: string@View,
    start: usize,
    expected: string@View
) -> bool {
    let expected_length: usize = string::length(expected)
    if (start + expected_length > string::length(text)) {
        return false
    }

    var index: usize = 0
    loop {
        if (index >= expected_length) {
            break
        }
        if (manifestTextByte(text, start + index) !=
            manifestTextByte(expected, index)) {
            return false
        }
        index = index + 1
    }
    return true
}

internal procedure manifestByteIsHorizontalSpace(byte: u8) -> bool {
    return byte == MANIFEST_SPACE || byte == MANIFEST_TAB
}

internal procedure manifestTextByte(text: string@View, index: usize) -> u8
|: index < string::length(text)
{
    let view: bytes@View = bytes::view_string(text)
    let data: const [u8] = bytes::as_slice(view)
    return data[index]
}
