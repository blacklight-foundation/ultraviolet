// Support responsibility: Source/Compiler/Semantics/Declarations/Contracts.uv
//
// This file owns the contract value model consumed by declaration checking and
// source-native test procedure validation. Test procedures use ordinary
// postconditions; the runner observes the same postcondition result as any
// other procedure execution.

public record ContractResultBinding {
    public text: string@View
}

public modal Postcondition {
    @Absent {
        public procedure isPresent(~) -> bool {
            return false
        }
    }

    @Present {
        public result_binding: ContractResultBinding

        public procedure isPresent(~) -> bool {
            return true
        }
    }
}

public type PostconditionValue =
    Postcondition@Absent | Postcondition@Present

public record ProcedureContract {
    public postcondition: PostconditionValue
}

public procedure contractResultBinding(text: string@View) -> ContractResultBinding {
    return ContractResultBinding { text: text }
}

public procedure absentPostcondition() -> PostconditionValue {
    return Postcondition@Absent {}
}

public procedure resultPostcondition() -> PostconditionValue {
    return Postcondition@Present {
        result_binding: contractResultBinding("@result")
    }
}

public procedure procedureContract(
    postcondition: PostconditionValue
) -> ProcedureContract {
    return ProcedureContract { postcondition: postcondition }
}

public procedure emptyProcedureContract() -> ProcedureContract {
    return procedureContract(absentPostcondition())
}

public procedure procedureContractWithResultPostcondition() -> ProcedureContract {
    return procedureContract(resultPostcondition())
}

public procedure postconditionIsPresent(postcondition: PostconditionValue) -> bool {
    return if postcondition is {
        @Absent {
            postcondition~>isPresent()
        }
        @Present {
            postcondition~>isPresent()
        }
    }
}
