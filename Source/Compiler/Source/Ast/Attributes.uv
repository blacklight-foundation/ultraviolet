// Support responsibility: Source/Compiler/Source/Ast/Attributes.uv
//
// This file defines the ordinary attribute AST value model consumed by
// Source/Compiler/Source/Parser/AttributeParser.uv and
// Source/Compiler/Semantics/Attributes/TestAttributes.uv. Source-native `[[test]]`
// attributes use this ordinary representation:
//
// - parse.TestAttributeByOrdinaryAttributeParser@L28356
//   `[[test]]` is parsed by the ordinary attribute parser from §9.1.2. The
//   `name` argument is represented as `⟨name, string_literal⟩`. Each
//   `covers(...)` argument is represented as `⟨covers, [string_literal]⟩`.

internal let ATTRIBUTE_T_LOWER: u8 = 116
internal let ATTRIBUTE_N_LOWER: u8 = 110
internal let ATTRIBUTE_C_LOWER: u8 = 99

public record AttributeName {
    public text: string@View
}

public modal AttributeArgument {
    @NamedString {
        public name: AttributeName
        public value: string@View
    }

    @CallString {
        public name: AttributeName
        public value: string@View
    }
}

public type AttributeArgumentValue =
    AttributeArgument@NamedString | AttributeArgument@CallString

public modal AttributeArgumentList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public argument: AttributeArgumentValue
        public tail: AttributeArgumentListValue

        public procedure count(~) -> usize {
            return 1 + attributeArgumentListCount(self.tail)
        }
    }
}

public type AttributeArgumentListValue =
    AttributeArgumentList@Empty | AttributeArgumentList@Entry

public record Attribute {
    public name: AttributeName
    public arguments: AttributeArgumentListValue
}

public procedure attributeName(text: string@View) -> AttributeName {
    return AttributeName { text: text }
}

public procedure namedStringAttributeArgument(
    name: AttributeName,
    value: string@View
) -> AttributeArgumentValue {
    return AttributeArgument@NamedString {
        name: name,
        value: value
    }
}

public procedure callStringAttributeArgument(
    name: AttributeName,
    value: string@View
) -> AttributeArgumentValue {
    return AttributeArgument@CallString {
        name: name,
        value: value
    }
}

public procedure emptyAttributeArguments() -> AttributeArgumentListValue {
    return AttributeArgumentList@Empty {}
}

public procedure attributeArgumentListEntry(
    argument: AttributeArgumentValue,
    move tail: AttributeArgumentListValue
) -> AttributeArgumentListValue {
    return AttributeArgumentList@Entry {
        argument: argument,
        tail: move tail
    }
}

public procedure attributeArgumentListCount(
    arguments: AttributeArgumentListValue
) -> usize {
    return if arguments is {
        @Empty {
            arguments~>count()
        }
        @Entry {
            arguments~>count()
        }
    }
}

public procedure attribute(
    name: AttributeName,
    move arguments: AttributeArgumentListValue
) -> Attribute {
    return Attribute {
        name: name,
        arguments: move arguments
    }
}

public procedure attributeNameEquals(
    name: AttributeName,
    expected: string@View
) -> bool {
    return attributeTextEquals(name.text, expected)
}

public procedure attributeArgumentNameEquals(
    argument: AttributeArgumentValue,
    expected: string@View
) -> bool {
    return if argument is {
        @NamedString { name } {
            attributeNameEquals(name, expected)
        }
        @CallString { name } {
            attributeNameEquals(name, expected)
        }
    }
}

public procedure attributeArgumentStringValue(
    argument: AttributeArgumentValue
) -> string@View {
    return if argument is {
        @NamedString { value } {
            value
        }
        @CallString { value } {
            value
        }
    }
}

public procedure attributeTextEquals(left: string@View, right: string@View) -> bool {
    let left_length: usize = string::length(left)
    let right_length: usize = string::length(right)
    if (left_length != right_length) {
        return false
    }

    var index: usize = 0
    loop {
        if (index >= left_length) {
            break
        }
        if (attributeTextByte(left, index) != attributeTextByte(right, index)) {
            return false
        }
        index = index + 1
    }

    return true
}

internal procedure attributeTextByte(text: string@View, index: usize) -> u8
|: index < string::length(text)
{
    let view: bytes@View = bytes::view_string(text)
    let data: const [u8] = bytes::as_slice(view)
    return data[index]
}
