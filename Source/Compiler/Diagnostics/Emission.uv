// Obligation responsibility: Source/Compiler/Diagnostics/Emission.uv
//
// This file owns canonical diagnostic construction helpers used by parser,
// semantic, command, and source-native testing owners.

public procedure errorDiagnostic(
    code: string@View,
    message: string@View
) -> Diagnostic {
    return diagnostic(
        diagnosticCodeFromText(code),
        diagnosticSeverityError(),
        message,
        absentDiagnosticSpan()
    )
}

public procedure sourceErrorDiagnostic(
    code: string@View,
    span: SourceSpan,
    message: string@View
) -> Diagnostic {
    return diagnostic(
        diagnosticCodeFromText(code),
        diagnosticSeverityError(),
        message,
        presentDiagnosticSpan(span)
    )
}

public procedure singleErrorDiagnosticStream(
    diagnostics_region: unique Region@Active,
    code: string@View,
    message: string@View
) -> DiagnosticStreamValue {
    return singleDiagnosticStream(
        diagnostics_region,
        errorDiagnostic(code, message)
    )
}

public procedure unknownTestTargetDiagnostic(target_text: string@View) -> Diagnostic {
    return errorDiagnostic(CODE_TEST_UNKNOWN_TARGET, "unknown uv test target")
}

public procedure malformedCoverageReferenceDiagnostic(
    reference_text: string@View
) -> Diagnostic {
    return errorDiagnostic(CODE_TEST_MALFORMED_COVERAGE, "malformed covers argument")
}

public procedure unknownTestTargetDiagnosticStream(
    diagnostics_region: unique Region@Active,
    target_text: string@View
) -> DiagnosticStreamValue {
    return singleDiagnosticStream(
        diagnostics_region,
        unknownTestTargetDiagnostic(target_text)
    )
}

public procedure unknownCoverageReferenceDiagnostic(
    reference_text: string@View
) -> Diagnostic {
    return errorDiagnostic(
        CODE_TEST_UNKNOWN_COVERAGE_REFERENCE,
        "unknown audit coverage reference"
    )
}
