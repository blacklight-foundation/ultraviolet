// Obligation responsibility: Source/Compiler/Diagnostics/Codes.uv
//
// This file owns diagnostic severity and diagnostic-code value construction for
// the compiler diagnostics model:
//
// - def.DiagnosticSeverity@L1503
//   Diagnostic severities are the stable categories used by diagnostic streams.
// - def.DiagCodeOpt@L1518
//   A diagnostic may carry a canonical diagnostic code.
// - diagnostics.CommandLineDiagnostics@L2166
//   Command-line diagnostics include E-CLI-0001 through E-CLI-0003.
// - diagnostics.TestAttributes@L28940
//   Source-native test diagnostics include E-MOD-2452 and E-TST-0101 through
//   E-TST-0108.

public modal DiagnosticSeverity {
    @Error {
        public procedure isError(~) -> bool {
            return true
        }
    }

    @Warning {
        public procedure isError(~) -> bool {
            return false
        }
    }

    @Info {
        public procedure isError(~) -> bool {
            return false
        }
    }

    @Panic {
        public procedure isError(~) -> bool {
            return true
        }
    }

    @Note {
        public procedure isError(~) -> bool {
            return false
        }
    }
}

public type DiagnosticSeverityValue =
    DiagnosticSeverity@Error |
    DiagnosticSeverity@Warning |
    DiagnosticSeverity@Info |
    DiagnosticSeverity@Panic |
    DiagnosticSeverity@Note

public record DiagnosticCode {
    public text: string@View
}

public modal DiagnosticCodeOption {
    @Absent {
        public procedure isPresent(~) -> bool {
            return false
        }
    }

    @Present {
        public code: DiagnosticCode

        public procedure isPresent(~) -> bool {
            return true
        }
    }
}

public type DiagnosticCodeOptionValue =
    DiagnosticCodeOption@Absent | DiagnosticCodeOption@Present

public procedure diagnosticCode(text: string@View) -> DiagnosticCode {
    return DiagnosticCode { text: text }
}

public procedure absentDiagnosticCode() -> DiagnosticCodeOptionValue {
    return DiagnosticCodeOption@Absent {}
}

public procedure presentDiagnosticCode(code: DiagnosticCode) -> DiagnosticCodeOptionValue {
    return DiagnosticCodeOption@Present { code: code }
}

public procedure diagnosticCodeFromText(text: string@View) -> DiagnosticCodeOptionValue {
    return presentDiagnosticCode(diagnosticCode(text))
}

public procedure diagnosticCodeOptionIsPresent(code: DiagnosticCodeOptionValue) -> bool {
    return if code is {
        @Absent {
            code~>isPresent()
        }
        @Present {
            code~>isPresent()
        }
    }
}

public procedure diagnosticSeverityError() -> DiagnosticSeverityValue {
    return DiagnosticSeverity@Error {}
}

public procedure diagnosticSeverityWarning() -> DiagnosticSeverityValue {
    return DiagnosticSeverity@Warning {}
}

public procedure diagnosticSeverityInfo() -> DiagnosticSeverityValue {
    return DiagnosticSeverity@Info {}
}

public procedure diagnosticSeverityPanic() -> DiagnosticSeverityValue {
    return DiagnosticSeverity@Panic {}
}

public procedure diagnosticSeverityNote() -> DiagnosticSeverityValue {
    return DiagnosticSeverity@Note {}
}

public procedure diagnosticSeverityIsError(severity: DiagnosticSeverityValue) -> bool {
    return if severity is {
        @Error {
            severity~>isError()
        }
        @Warning {
            severity~>isError()
        }
        @Info {
            severity~>isError()
        }
        @Panic {
            severity~>isError()
        }
        @Note {
            severity~>isError()
        }
    }
}

public let CODE_CLI_UNKNOWN_COMMAND: string@View = "E-CLI-0001"
public let CODE_CLI_PIPELINE_UNAVAILABLE: string@View = "E-CLI-0002"
public let CODE_CLI_OUTPUT_WRITE_FAILED: string@View = "E-CLI-0003"

public let CODE_TEST_ATTRIBUTE_WRONG_TARGET: string@View = "E-MOD-2452"
public let CODE_TEST_MALFORMED_ARGUMENT: string@View = "E-TST-0101"
public let CODE_TEST_DUPLICATE_NAME: string@View = "E-TST-0102"
public let CODE_TEST_MALFORMED_COVERAGE: string@View = "E-TST-0103"
public let CODE_TEST_INVALID_PROCEDURE_SHAPE: string@View = "E-TST-0104"
public let CODE_TEST_INVALID_CONTEXT_PARAMETER: string@View = "E-TST-0105"
public let CODE_TEST_MISSING_POSTCONDITION: string@View = "E-TST-0106"
public let CODE_TEST_UNKNOWN_COVERAGE_REFERENCE: string@View = "E-TST-0107"
public let CODE_TEST_UNKNOWN_TARGET: string@View = "E-TST-0108"
