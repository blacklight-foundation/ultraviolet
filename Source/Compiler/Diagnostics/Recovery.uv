// Obligation responsibility: Source/Compiler/Diagnostics/Recovery.uv
//
// This file owns diagnostic recovery-policy value states used by parsers and
// semantic passes that continue after an emitted error.

public modal DiagnosticRecoveryPolicy {
    @StopAfterError {
    }

    @Continue {
    }
}

public type DiagnosticRecoveryPolicyValue =
    DiagnosticRecoveryPolicy@StopAfterError | DiagnosticRecoveryPolicy@Continue

public procedure stopAfterErrorRecovery() -> DiagnosticRecoveryPolicyValue {
    return DiagnosticRecoveryPolicy@StopAfterError {}
}

public procedure continueAfterErrorRecovery() -> DiagnosticRecoveryPolicyValue {
    return DiagnosticRecoveryPolicy@Continue {}
}
