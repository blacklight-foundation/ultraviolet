// Obligation responsibility: Source/Compiler/Diagnostics/Sources.uv
//
// This file owns diagnostic span presence used by diagnostics:
//
// - NoSpan-External@L1982
//   External-origin diagnostics have span = bottom.

using UltravioletCompiler::Core::{
    SourceSpan
}

public modal DiagnosticSpan {
    @Absent {
        public procedure isPresent(~) -> bool {
            return false
        }
    }

    @Present {
        public span: SourceSpan

        public procedure isPresent(~) -> bool {
            return true
        }
    }
}

public type DiagnosticSpanValue =
    DiagnosticSpan@Absent | DiagnosticSpan@Present

public procedure absentDiagnosticSpan() -> DiagnosticSpanValue {
    return DiagnosticSpan@Absent {}
}

public procedure presentDiagnosticSpan(span: SourceSpan) -> DiagnosticSpanValue {
    return DiagnosticSpan@Present { span: span }
}

public procedure diagnosticSpanIsPresent(span: DiagnosticSpanValue) -> bool {
    return if span is {
        @Absent {
            span~>isPresent()
        }
        @Present {
            span~>isPresent()
        }
    }
}
