// Test responsibility: Source/Compiler/Tests/Source/Parser/TestAttributes/GrammarTestAttributeTests.uv
//
// This file owns source-native tests for grammar.TestAttribute@L28683:
//
// test_attribute      ::= "[[" "test" ("(" test_attribute_args ")")? "]]"
// test_attribute_args ::= test_attribute_arg ("," test_attribute_arg)*
// test_attribute_arg  ::= "name" ":" string_literal
//                       | "covers" "(" string_literal ")"

using UltravioletCompiler::Source::Ast::{
    AttributeArgumentListValue,
    attributeArgumentListCount,
    attributeArgumentNameEquals,
    attributeArgumentStringValue,
    attributeNameEquals
}
using UltravioletCompiler::Source::Parser::{
    AttributeParseResultValue,
    parseTestAttribute,
    parseTestAttributeWithoutArguments,
    singleTestCoverageArgument,
    testAttributeArguments2,
    testCoverageAttributeArgument,
    testNameAttributeArgument
}

[[test(
    name: "test attribute grammar accepts bare test attribute",
    covers("grammar.TestAttribute@L28683")
)]]
internal procedure testAttributeGrammarAcceptsBareAttribute() -> bool
|: => @result
{
    let result: AttributeParseResultValue = parseTestAttributeWithoutArguments()
    return if result is {
        @Parsed { attribute } {
            attributeNameEquals(attribute.name, "test") &&
                attributeArgumentListCount(attribute.arguments) == 0
        }
        @Rejected {
            false
        }
    }
}

[[test(
    name: "test attribute grammar accepts coverage argument list",
    covers("grammar.TestAttribute@L28683")
)]]
internal procedure testAttributeGrammarAcceptsCoverageArgumentList() -> bool
|: => @result
{
    let result: AttributeParseResultValue =
        parseTestAttribute(singleTestCoverageArgument("grammar.TestAttribute@L28683"))
    return if result is {
        @Parsed { attribute } {
            attributeNameEquals(attribute.name, "test") &&
                attributeArgumentListCount(attribute.arguments) == 1
        }
        @Rejected {
            false
        }
    }
}
