[[test(
    name: "PathComps prepends drive root tag before tail segments",
    covers("def.PathComponents@L3223")
)]]
internal procedure pathComponentsPrependsDriveRootTag() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "C:/one//two/")
        passed = componentCountEquals(path, 3) &&
            componentAtEquals(path, 0, "C:") &&
            componentAtEquals(path, 1, "one") &&
            componentAtEquals(path, 2, "two")
    }
    return passed
}

[[test(
    name: "PathComps keeps drive root without tail as one component",
    covers("def.PathComponents@L3223")
)]]
internal procedure pathComponentsKeepsDriveRootWithoutTail() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "C:/")
        passed = componentCountEquals(path, 1) && componentAtEquals(path, 0, "C:")
    }
    return passed
}

[[test(
    name: "PathComps prepends UNC root tag before tail segments",
    covers("def.PathComponents@L3223")
)]]
internal procedure pathComponentsPrependsUNCRootTag() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "//server/share")
        passed = componentCountEquals(path, 3) &&
            componentAtEquals(path, 0, "//") &&
            componentAtEquals(path, 1, "server") &&
            componentAtEquals(path, 2, "share")
    }
    return passed
}

[[test(
    name: "PathComps prepends root-relative tag before tail segments",
    covers("def.PathComponents@L3223")
)]]
internal procedure pathComponentsPrependsRootRelativeTag() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "/one//two")
        passed = componentCountEquals(path, 3) &&
            componentAtEquals(path, 0, "/") &&
            componentAtEquals(path, 1, "one") &&
            componentAtEquals(path, 2, "two")
    }
    return passed
}

[[test(
    name: "PathComps of relative path is only its segments",
    covers("def.PathComponents@L3223")
)]]
internal procedure pathComponentsOfRelativePathIsOnlySegments() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "one//two/")
        passed = componentCountEquals(path, 2) &&
            componentAtEquals(path, 0, "one") &&
            componentAtEquals(path, 1, "two")
    }
    return passed
}
