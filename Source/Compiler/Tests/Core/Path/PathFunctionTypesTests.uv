[[test(
    name: "Join entrypoint returns Path",
    covers("def.PathFunctionTypes@L3289")
)]]
internal procedure joinEntrypointReturnsPath() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let base: Path = pathFromViewText(paths, "root")
        let child: Path = pathFromViewText(paths, "child")
        let path: Path = joinPath(
            paths,
            move base,
            move child
        )
        passed = pathTextEquals(path, "root/child")
    }
    return passed
}

[[test(
    name: "Normalize entrypoint returns Path",
    covers("def.PathFunctionTypes@L3289")
)]]
internal procedure normalizeEntrypointReturnsPath() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let source: Path = pathFromViewText(paths, "root/./child")
        let path: Path = normalizePath(paths, move source)
        passed = pathTextEquals(path, "root/child")
    }
    return passed
}

[[test(
    name: "Canon entrypoint returns canonical path result",
    covers("def.PathFunctionTypes@L3289")
)]]
internal procedure canonEntrypointReturnsCanonicalPathResult() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let source: Path = pathFromViewText(paths, "root/child")
        let value: CanonicalPathResultValue = canonPath(paths, move source)
        passed = canonicalPathAcceptedAs(
            value,
            "root/child"
        )
    }
    return passed
}
