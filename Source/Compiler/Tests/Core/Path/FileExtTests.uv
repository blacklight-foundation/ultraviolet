[[test(
    name: "FileExt is empty when basename has no dot",
    covers("def.FileExt@L3407")
)]]
internal procedure fileExtensionEmptyWhenBasenameHasNoDot() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathFileExtEquals(pathFromViewText(paths, "root/file"), "")
    }
    return passed
}

[[test(
    name: "FileExt is empty when the only dot is leading",
    covers("def.FileExt@L3407")
)]]
internal procedure fileExtensionEmptyWhenOnlyDotIsLeading() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathFileExtEquals(pathFromViewText(paths, "root/.profile"), "")
    }
    return passed
}

[[test(
    name: "FileExt begins at the last non-leading dot",
    covers("def.FileExt@L3407")
)]]
internal procedure fileExtensionBeginsAtLastNonLeadingDot() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathFileExtEquals(pathFromViewText(paths, "root/file.tar.gz"), ".gz")
    }
    return passed
}

[[test(
    name: "FileExt of trailing dot is the trailing dot",
    covers("def.FileExt@L3407")
)]]
internal procedure fileExtensionOfTrailingDotIsTrailingDot() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathFileExtEquals(pathFromViewText(paths, "root/file."), ".")
    }
    return passed
}

[[test(
    name: "FileExt of parent traversal basename is dot",
    covers("def.FileExt@L3407")
)]]
internal procedure fileExtensionOfParentTraversalBasenameIsDot() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathFileExtEquals(pathFromViewText(paths, "root/.."), ".")
    }
    return passed
}
