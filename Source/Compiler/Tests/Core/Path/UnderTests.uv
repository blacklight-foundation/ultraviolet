[[test(
    name: "Under compares normalized owner prefix",
    covers("def.Under@L3333")
)]]
internal procedure underComparesNormalizedOwnerPrefix() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "root/child/file")
        let owner: Path = pathFromViewText(paths, "root/./child")
        passed = pathUnder(
            paths,
            move path,
            move owner
        )
    }
    return passed
}

[[test(
    name: "Under compares normalized path prefix",
    covers("def.Under@L3333")
)]]
internal procedure underComparesNormalizedPathPrefix() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "root/./child")
        let owner: Path = pathFromViewText(paths, "root")
        passed = pathUnder(
            paths,
            move path,
            move owner
        )
    }
    return passed
}

[[test(
    name: "Under preserves root tag distinction",
    covers("def.Under@L3333")
)]]
internal procedure underPreservesRootTagDistinction() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let path: Path = pathFromViewText(paths, "/root/./child")
        let owner: Path = pathFromViewText(paths, "/root")
        passed = pathUnder(
            paths,
            move path,
            move owner
        )
    }
    return passed
}

[[test(
    name: "Under rejects non-prefix owner",
    covers("def.Under@L3333")
)]]
internal procedure underRejectsNonPrefixOwner() -> bool
|: => !@result
{
    var passed: bool = true
    region as paths {
        let path: Path = pathFromViewText(paths, "root/other/file")
        let owner: Path = pathFromViewText(paths, "root/child")
        passed = pathUnder(
            paths,
            move path,
            move owner
        )
    }
    return passed
}
