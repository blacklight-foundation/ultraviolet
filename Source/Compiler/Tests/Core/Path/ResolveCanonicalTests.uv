[[test(
    name: "Resolve canonicalizes root and joined path",
    covers("Resolve-Canonical@L3426")
)]]
internal procedure resolveCanonicalizesRootAndJoinedPath() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root/.")
        let path: Path = pathFromViewText(paths, "child/./file")
        let value: PathResolutionResultValue = resolvePath(paths, move root, move path)
        passed = pathResolutionResolvedAs(value, "C:/root/child/file") &&
            pathResolutionResolvedUnderRoot(value)
    }
    return passed
}

[[test(
    name: "Resolve rejects root parent traversal",
    covers("Resolve-Canonical-Err@L3444")
)]]
internal procedure resolveRejectsRootParentTraversal() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root/..")
        let path: Path = pathFromViewText(paths, "child")
        let value: PathResolutionResultValue = resolvePath(paths, move root, move path)
        passed = pathResolutionUnavailableFromRoot(value)
    }
    return passed
}

[[test(
    name: "Resolve rejects joined path parent traversal",
    covers("Resolve-Canonical-Err@L3444")
)]]
internal procedure resolveRejectsJoinedPathParentTraversal() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root")
        let path: Path = pathFromViewText(paths, "child/..")
        let value: PathResolutionResultValue = resolvePath(paths, move root, move path)
        passed = pathResolutionUnavailableFromPath(value)
    }
    return passed
}

[[test(
    name: "Resolve accepts absolute path with separate canonical root",
    covers("Resolve-Canonical@L3426")
)]]
internal procedure resolveAcceptsAbsolutePathWithSeparateCanonicalRoot() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        let root: Path = pathFromViewText(paths, "C:/root")
        let path: Path = pathFromViewText(paths, "D:/other")
        let value: PathResolutionResultValue = resolvePath(paths, move root, move path)
        passed = pathResolutionResolvedAs(value, "D:/other") &&
            !pathResolutionResolvedUnderRoot(value)
    }
    return passed
}
