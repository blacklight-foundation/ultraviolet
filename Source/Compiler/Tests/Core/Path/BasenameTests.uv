[[test(
    name: "Basename of empty path is empty",
    covers("def.Basename@L3390")
)]]
internal procedure basenameOfEmptyPathIsEmpty() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathBasenameEquals(pathFromViewText(paths, ""), "")
    }
    return passed
}

[[test(
    name: "Basename of root-relative root is the root tag",
    covers("def.Basename@L3390")
)]]
internal procedure basenameOfRootRelativeRootIsRootTag() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathBasenameEquals(pathFromViewText(paths, "/"), "/")
    }
    return passed
}

[[test(
    name: "Basename of UNC root is the UNC tag",
    covers("def.Basename@L3390")
)]]
internal procedure basenameOfUNCRootIsUNCTag() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathBasenameEquals(pathFromViewText(paths, "//"), "//")
    }
    return passed
}

[[test(
    name: "Basename returns the final component",
    covers("def.Basename@L3390")
)]]
internal procedure basenameReturnsFinalComponent() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathBasenameEquals(pathFromViewText(paths, "root/file.txt"), "file.txt")
    }
    return passed
}

[[test(
    name: "Basename ignores trailing separators",
    covers("def.Basename@L3390")
)]]
internal procedure basenameIgnoresTrailingSeparators() -> bool
|: => @result
{
    var passed: bool = false
    region as paths {
        passed = pathBasenameEquals(pathFromViewText(paths, "root/dir/"), "dir")
    }
    return passed
}
