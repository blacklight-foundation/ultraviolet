// Test responsibility: Source/Compiler/Tests/Driver/Testing/ConformanceTestAttributeDynamicSemanticsTests.uv
//
// This file owns source-native tests for
// conformance.TestAttributeDynamicSemantics@L28842:
//
// During test execution, ordinary return plus a satisfied postcondition passes;
// ordinary return plus a violated postcondition fails; panic, unavailable
// authority, ill-formed invocation, or harness failure errors.

using UltravioletCompiler::Diagnostics::{ diagnosticStreamHasErrors }
using UltravioletCompiler::Driver::Testing::{
    TestDriverExecutionValue,
    sourceNativeTestExecutionFromProject,
    testDriverRequest
}

[[test(
    name: "test result summary classifies passed failed and error outcomes",
    covers("conformance.TestAttributeDynamicSemantics@L28842")
)]]
internal procedure testResultSummaryClassifiesPassedFailedAndErrorOutcomes() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let results: TestResultListValue =
            testResultListEntry(
                testResult(dynamicSemanticsTest("passed"), passedTestOutcome()),
                testResultListEntry(
                    testResult(
                        dynamicSemanticsTest("failed"),
                        failedTestOutcome(
                            singleErrorDiagnosticStream(
                                diagnostics_region,
                                "E-TST-0106",
                                "failed"
                            )
                        )
                    ),
                    testResultListEntry(
                        testResult(
                            dynamicSemanticsTest("error"),
                            errorTestOutcome(
                                singleErrorDiagnosticStream(
                                    diagnostics_region,
                                    "E-TST-0108",
                                    "error"
                                )
                            )
                        ),
                        emptyTestResults()
                    )
                )
            )
        let summary: TestResultSummary = summarizeTestResults(move results)
        passed = summary.passed == 1 && summary.failed == 1 && summary.errors == 1
    }
    return passed
}

[[test(
    name: "source-native execution plans selected tests from loaded project",
    covers("conformance.TestAttributeDynamicSemantics@L28842")
)]]
internal procedure sourceNativeExecutionPlansSelectedTestsFromLoadedProject() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let execution: TestDriverExecutionValue =
            sourceNativeTestExecutionFromProject(
                diagnostics_region,
                testDriverRequest(
                    ".",
                    "uv.exe",
                    absentTestTargetCandidate(),
                    "x86_64-win64",
                    "normal"
                ),
                dynamicSemanticsProject(),
                discoveredTestListEntry(
                    dynamicSemanticsTest("selected"),
                    emptyDiscoveredTests()
                )
            )
        passed = if execution is {
            @Ready { run } {
                if run is {
                    @Planned { selection } {
                        discoveredTestListCount(selection.tests) == 1
                    }
                    @HarnessBuilt {
                        false
                    }
                    @ExecutableBuilt {
                        false
                    }
                    @Running {
                        false
                    }
                    @Completed {
                        false
                    }
                }
            }
            @ProjectRequired {
                false
            }
            @Rejected {
                false
            }
        }
    }
    return passed
}

[[test(
    name: "source-native execution rejects unknown loaded-project target",
    covers("conformance.TestAttributeDynamicSemantics@L28842")
)]]
internal procedure sourceNativeExecutionRejectsUnknownLoadedProjectTarget() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let execution: TestDriverExecutionValue =
            sourceNativeTestExecutionFromProject(
                diagnostics_region,
                testDriverRequest(
                    ".",
                    "uv.exe",
                    textTestTargetCandidate("MissingAssembly"),
                    "x86_64-win64",
                    "normal"
                ),
                dynamicSemanticsProject(),
                emptyDiscoveredTests()
            )
        passed = if execution is {
            @Rejected { diagnostics } {
                diagnosticStreamHasErrors(diagnostics)
            }
            @ProjectRequired {
                false
            }
            @Ready {
                false
            }
        }
    }
    return passed
}

internal procedure dynamicSemanticsTest(symbol_text: string@View) -> DiscoveredTest {
    return discoveredTest(
        testProcedureSymbol(symbol_text),
        testDisplayName(symbol_text),
        assemblyName("UltravioletCompiler"),
        modulePath("UltravioletCompiler::Tests::Driver::Testing"),
        sourceFilePath(
            "Source/Compiler/Tests/Driver/Testing/ConformanceTestAttributeDynamicSemanticsTests.uv"
        ),
        0,
        sourceSpan(
            "Source/Compiler/Tests/Driver/Testing/ConformanceTestAttributeDynamicSemanticsTests.uv",
            0,
            1,
            1,
            1,
            1,
            2
        ),
        testProcedureSymbol(symbol_text),
        false,
        emptyCoverageReferences()
    )
}

internal procedure dynamicSemanticsProject() -> Project {
    return project(
        projectRoot("C:/Dev/Ultraviolet"),
        assemblyListEntry(
            assembly(
                assemblyName("UltravioletCompiler"),
                executableAssemblyKind(),
                noLinkKind(),
                directoryPath("Compiler"),
                moduleListEntry(
                    module(
                        modulePath("UltravioletCompiler::Tests::Driver::Testing"),
                        directoryPath("Source/Compiler/Tests/Driver/Testing"),
                        emptySourceFiles()
                    ),
                    emptyModules()
                )
            ),
            emptyAssemblies()
        )
    )
}
