// Test responsibility: Source/Compiler/Tests/Driver/CLI/TestCommandInputTests.uv
//
// This file exercises executable command parsing, including the `uv test`
// command input shape and the main-entry command selection surface. Audit
// coverage for `uv test` lowering lives in
// Source/Compiler/Tests/Driver/Testing/LoweringTestHarnessGenerationTests.uv.

using UltravioletCompiler::Driver::{
    PipelineOutputModeValue,
    PipelineRequest,
    PipelineTargetProfileValue
}

using UltravioletCompiler::Driver::CLI::{
    CommandArguments,
    CommandFailureReasonValue,
    CommandParseResultValue,
    OutputModeValue,
    PositionalArgumentsValue,
    TargetProfileInputValue,
    TestCommandInputResultValue,
    absentTargetProfile,
    buildCommandArguments,
    buildPipelineRequest,
    cliTextEquals,
    checkCommandArguments,
    commandArguments,
    machineReadableOutputMode,
    noPositionals,
    normalOutputMode,
    onePositional,
    parseCommand,
    pipelineOutputModeFromInput,
    pipelineTargetProfileFromInput,
    quietOutputMode,
    targetProfileFromText,
    testCommandArguments,
    testCommandArgumentsWithTarget,
    testCommandInputFromArguments,
    tooManyPositionals
}

[[test(
    name: "uv test accepts absent positional target"
)]]
internal procedure uvTestAcceptsAbsentTarget() -> bool
|: => @result
{
    let arguments: CommandArguments = testCommandArguments()
    let result: TestCommandInputResultValue =
        testCommandInputFromArguments(".", arguments)
    return if result is {
        @Accepted { input } {
            !input~>hasTarget()
        }
        @Rejected {
            false
        }
    }
}

[[test(
    name: "uv test accepts one positional target"
)]]
internal procedure uvTestAcceptsOneTarget() -> bool
|: => @result
{
    let arguments: CommandArguments =
        testCommandArgumentsWithTarget("Source/Compiler/Tests/Core/Path")
    let result: TestCommandInputResultValue =
        testCommandInputFromArguments(".", arguments)
    return if result is {
        @Accepted { input } {
            input~>hasTarget()
        }
        @Rejected {
            false
        }
    }
}

[[test(
    name: "uv test rejects extra positional target"
)]]
internal procedure uvTestRejectsExtraTarget() -> bool
|: => @result
{
    let target_profile: TargetProfileInputValue = absentTargetProfile()
    let output_mode: OutputModeValue = normalOutputMode()
    let positionals: PositionalArgumentsValue =
        tooManyPositionals("Source/Compiler/Tests/Core/Path", "extra")
    let arguments: CommandArguments =
        commandArguments("test", positionals, target_profile, output_mode)
    let result: CommandParseResultValue = parseCommand(".", arguments)
    return if result is {
        @Parsed {
            false
        }
        @Rejected { reason } {
            commandFailureIsTestTargetRejected(reason, "E-TST-0108")
        }
    }
}

[[test(
    name: "empty command resolves to version command",
    covers("def.15.MainEntryPointDefinitions@L52806")
)]]
internal procedure emptyCommandResolvesToVersion() -> bool
|: => @result
{
    let arguments: CommandArguments = commandArguments(
        "",
        noPositionals(),
        absentTargetProfile(),
        normalOutputMode()
    )
    let result: CommandParseResultValue = parseCommand(".", arguments)
    return if result is {
        @Parsed {
            true
        }
        @Rejected {
            false
        }
    }
}

[[test(
    name: "unknown command is rejected",
    covers("def.15.MainEntryPointDefinitions@L52806")
)]]
internal procedure unknownCommandIsRejected() -> bool
|: => @result
{
    let arguments: CommandArguments = commandArguments(
        "bogus",
        noPositionals(),
        absentTargetProfile(),
        normalOutputMode()
    )
    let result: CommandParseResultValue = parseCommand(".", arguments)
    return if result is {
        @Parsed {
            false
        }
        @Rejected { reason } {
            commandFailureIsUnknownCommand(reason, "bogus")
        }
    }
}

[[test(
    name: "project commands parse into command states",
    covers("def.15.MainEntryPointDefinitions@L52806")
)]]
internal procedure projectCommandsParseIntoCommandStates() -> bool
|: => @result
{
    let build_result: CommandParseResultValue =
        parseCommand(".", buildCommandArguments())
    let check_result: CommandParseResultValue =
        parseCommand(".", checkCommandArguments())
    let clean_result: CommandParseResultValue =
        parseCommand(
            ".",
            commandArguments("clean", noPositionals(), absentTargetProfile(), normalOutputMode())
        )
    let init_result: CommandParseResultValue =
        parseCommand(
            ".",
            commandArguments("init", noPositionals(), absentTargetProfile(), normalOutputMode())
        )
    let run_result: CommandParseResultValue =
        parseCommand(
            ".",
            commandArguments("run", noPositionals(), absentTargetProfile(), normalOutputMode())
        )

    return commandParseResultIsBuild(build_result) &&
        commandParseResultIsCheck(check_result) &&
        commandParseResultIsClean(clean_result) &&
        commandParseResultIsInit(init_result) &&
        commandParseResultIsRun(run_result)
}

internal procedure commandFailureIsTestTargetRejected(
    reason: CommandFailureReasonValue,
    expected_code: string@View
) -> bool {
    return if reason is {
        @UnknownCommand {
            false
        }
        @PipelineUnavailable {
            false
        }
        @OutputWriteFailed {
            false
        }
        @TestTargetRejected { code } {
            cliTextEquals(code, expected_code)
        }
    }
}

internal procedure commandFailureIsUnknownCommand(
    reason: CommandFailureReasonValue,
    expected_command_name: string@View
) -> bool {
    return if reason is {
        @UnknownCommand { command_name } {
            cliTextEquals(command_name, expected_command_name)
        }
        @PipelineUnavailable {
            false
        }
        @OutputWriteFailed {
            false
        }
        @TestTargetRejected {
            false
        }
    }
}

internal procedure commandParseResultIsBuild(result: CommandParseResultValue) -> bool {
    return if result is {
        @Parsed { command } {
            if command is {
                @Build {
                    true
                }
                @Check {
                    false
                }
                @Clean {
                    false
                }
                @Init {
                    false
                }
                @Run {
                    false
                }
                @Test {
                    false
                }
                @Version {
                    false
                }
            }
        }
        @Rejected {
            false
        }
    }
}

