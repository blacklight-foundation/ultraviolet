// Test responsibility:
// Source/Compiler/Tests/Project/AssemblyLoader/StepAsmDone/StepAsmDoneTests.uv
//
// This file owns source-native tests for Step-Asm-Done@L3816.

using UltravioletCompiler::Project::{
    AssemblyListValue,
    ProjectLoadValue,
    assembly,
    assemblyListEntry,
    assemblyName,
    directoryPath,
    emptyAssemblies,
    emptyManifestAssemblies,
    emptyModules,
    executableAssemblyKind,
    libraryAssemblyKind,
    manifest,
    noLinkKind,
    projectLoadFromDiscoveredAssemblies,
    projectRoot,
    projectTextEquals
}

[[test(
    name: "project load completes from discovered assemblies in deterministic order",
    covers("Step-Asm-Done@L3816")
)]]
internal procedure projectLoadCompletesFromDiscoveredAssembliesInDeterministicOrder() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let load: ProjectLoadValue =
            projectLoadFromDiscoveredAssemblies(
                diagnostics_region,
                projectRoot("C:/Dev/Ultraviolet"),
                manifest(emptyManifestAssemblies()),
                stepAsmDoneAssemblies()
            )

        passed = if load is {
            @Complete { project } {
                assemblyListStartsWith(project.assemblies, "AAssembly")
            }
            @RootLocated {
                false
            }
            @ManifestParsed {
                false
            }
            @ManifestValidated {
                false
            }
            @AssembliesDiscovered {
                false
            }
            @Failed {
                false
            }
        }
    }
    return passed
}

internal procedure stepAsmDoneAssemblies() -> AssemblyListValue {
    return assemblyListEntry(
        assembly(
            assemblyName("uv"),
            executableAssemblyKind(),
            noLinkKind(),
            directoryPath("Source/Tools/Uv"),
            emptyModules()
        ),
        assemblyListEntry(
            assembly(
                assemblyName("AAssembly"),
                libraryAssemblyKind(),
                noLinkKind(),
                directoryPath("A"),
                emptyModules()
            ),
            emptyAssemblies()
        )
    )
}

internal procedure assemblyListStartsWith(
    assemblies: AssemblyListValue,
    expected_name: string@View
) -> bool {
    return if assemblies is {
        @Empty {
            false
        }
        @Entry { assembly: project_assembly } {
            projectTextEquals(project_assembly.name.text, expected_name)
        }
    }
}
