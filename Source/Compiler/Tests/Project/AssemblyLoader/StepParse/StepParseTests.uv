// Test responsibility:
// Source/Compiler/Tests/Project/AssemblyLoader/StepParse/StepParseTests.uv
//
// This file owns source-native tests for Step-Parse@L3558.

using UltravioletCompiler::Project::{
    ProjectLoadValue,
    manifestAssemblyListCount,
    projectLoadParseManifestText,
    projectRoot
}

[[test(
    name: "project load parse transition enters manifest parsed state",
    covers("Step-Parse@L3558")
)]]
internal procedure projectLoadParseTransitionEntersManifestParsedState() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let load: ProjectLoadValue = projectLoadParseManifestText(
            diagnostics_region,
            projectRoot("C:/Dev/Ultraviolet"),
            "[[assembly]]\nname = \"UltravioletCompiler\"\nkind = \"library\"\nlink_kind = \"static\"\nroot = \"Compiler\"\n"
        )

        passed = if load is {
            @ManifestParsed { manifest } {
                manifestAssemblyListCount(manifest.assemblies) == 1
            }
            @RootLocated {
                false
            }
            @ManifestValidated {
                false
            }
            @AssembliesDiscovered {
                false
            }
            @Complete {
                false
            }
            @Failed {
                false
            }
        }
    }
    return passed
}
