// Test responsibility:
// Source/Compiler/Tests/Project/AssemblyLoader/StepValidate/StepValidateTests.uv
//
// This file owns source-native tests for Step-Validate@L3615.

using UltravioletCompiler::Project::{
    ManifestAssemblyListValue,
    ProjectLoadValue,
    emptyManifestAssemblies,
    manifest,
    manifestAssembly,
    manifestAssemblyListCount,
    manifestAssemblyListEntry,
    parsedManifest,
    projectLoadFromManifestParse,
    projectRoot
}

[[test(
    name: "project load advances parsed manifest into validated state",
    covers("Step-Validate@L3615")
)]]
internal procedure projectLoadAdvancesParsedManifestIntoValidatedState() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let load: ProjectLoadValue =
            projectLoadFromManifestParse(
                diagnostics_region,
                projectRoot("C:/Dev/Ultraviolet"),
                parsedManifest(manifest(stepValidateManifestAssemblies()))
            )

        passed = if load is {
            @ManifestValidated { manifest: validated_manifest } {
                manifestAssemblyListCount(validated_manifest.assemblies) == 2
            }
            @RootLocated {
                false
            }
            @ManifestParsed {
                false
            }
            @AssembliesDiscovered {
                false
            }
            @Complete {
                false
            }
            @Failed {
                false
            }
        }
    }
    return passed
}

internal procedure stepValidateManifestAssemblies() -> ManifestAssemblyListValue {
    return manifestAssemblyListEntry(
        manifestAssembly("ZAssembly", "library", "static", "Z"),
        manifestAssemblyListEntry(
            manifestAssembly("AAssembly", "library", "static", "A"),
            emptyManifestAssemblies()
        )
    )
}
