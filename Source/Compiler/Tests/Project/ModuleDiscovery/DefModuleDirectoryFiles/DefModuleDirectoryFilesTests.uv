// Test responsibility:
// Source/Compiler/Tests/Project/ModuleDiscovery/DefModuleDirectoryFiles/DefModuleDirectoryFilesTests.uv
//
// This file owns source-native tests for def.ModuleDirectoryFiles@L4345.

using UltravioletCompiler::Project::{
    SourceFilePathListValue,
    directoryPath,
    emptySourceFilePaths,
    directoryScanFiles,
    directoryScan,
    modulePath,
    projectTextEquals,
    sourceFilePath,
    sourceFilePathListEntry
}

[[test(
    name: "module directory files include only uv sources",
    covers("def.ModuleDirectoryFiles@L4345")
)]]
internal procedure directoryScanFilesIncludeOnlyUvSources() -> bool
|: => @result
{
    let files: SourceFilePathListValue =
        directoryScanFiles(
            directoryScan(
                directoryPath("Source/Compiler/Core"),
                modulePath("UltravioletCompiler::Core"),
                sourceFilePathListEntry(
                    sourceFilePath("Source/Compiler/Core/readme.txt"),
                    sourceFilePathListEntry(
                        sourceFilePath("Source/Compiler/Core/Path.uv"),
                        emptySourceFilePaths()
                    )
                ),
                true
            )
        )

    return if files is {
        @Empty {
            false
        }
        @Entry { path, tail } {
            projectTextEquals(path.text, "Source/Compiler/Core/Path.uv") &&
                sourceFilePathListIsEmpty(tail)
        }
    }
}

internal procedure sourceFilePathListIsEmpty(files: SourceFilePathListValue) -> bool {
    return if files is {
        @Empty {
            true
        }
        @Entry {
            false
        }
    }
}
