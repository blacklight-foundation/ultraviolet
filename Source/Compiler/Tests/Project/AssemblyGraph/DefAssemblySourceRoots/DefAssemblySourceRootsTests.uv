// Test responsibility:
// Source/Compiler/Tests/Project/AssemblyGraph/DefAssemblySourceRoots/DefAssemblySourceRootsTests.uv
//
// This file owns source-native tests for def.AssemblySourceRoots@L4420:
//
// AssemblySourceRoots(As) = { A.source_root | A ∈ As }
// RootDepth(S) = |PathComps(S)|

using UltravioletCompiler::Project::{
    assembly,
    assemblyListEntry,
    assemblyName,
    assemblySourceRootListCount,
    assemblySourceRoots,
    directoryPath,
    emptyAssemblies,
    emptyModules,
    executableAssemblyKind,
    libraryAssemblyKind,
    noLinkKind
}

[[test(
    name: "assembly source roots are projected from loaded assemblies",
    covers("def.AssemblySourceRoots@L4420")
)]]
internal procedure assemblySourceRootsAreProjectedFromLoadedAssemblies() -> bool
|: => @result
{
    return assemblySourceRootListCount(
        assemblySourceRoots(
            assemblyListEntry(
                assembly(
                    assemblyName("UltravioletCompiler"),
                    libraryAssemblyKind(),
                    noLinkKind(),
                    directoryPath("Compiler"),
                    emptyModules()
                ),
                assemblyListEntry(
                    assembly(
                        assemblyName("uv"),
                        executableAssemblyKind(),
                        noLinkKind(),
                        directoryPath("Source/Tools/Uv"),
                        emptyModules()
                    ),
                    emptyAssemblies()
                )
            )
        )
    ) == 2
}
