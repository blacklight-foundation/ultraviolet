// Test responsibility:
// Source/Compiler/Tests/Project/Manifest/ParseManifestErr/ParseManifestErrTests.uv
//
// This file owns source-native tests for Parse-Manifest-Err@L2240.

using UltravioletCompiler::Project::{
    ManifestParseValue,
    parseManifestText
}

[[test(
    name: "manifest parser reports malformed key value syntax",
    covers("Parse-Manifest-Err@L2240")
)]]
internal procedure manifestParserReportsMalformedKeyValueSyntax() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        passed = manifestParseFails(
            parseManifestText(
                diagnostics_region,
                "[[assembly]]\nname \"UltravioletCompiler\"\nkind = \"library\"\nroot = \"Compiler\"\n"
            )
        )
    }
    return passed
}

[[test(
    name: "manifest parser reports duplicate table fields",
    covers("Parse-Manifest-Err@L2240")
)]]
internal procedure manifestParserReportsDuplicateTableFields() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        passed = manifestParseFails(
            parseManifestText(
                diagnostics_region,
                "[[assembly]]\nname = \"UltravioletCompiler\"\nname = \"CompilerAgain\"\nkind = \"library\"\nroot = \"Compiler\"\n"
            )
        )
    }
    return passed
}

internal procedure manifestParseFails(parse: ManifestParseValue) -> bool {
    return if parse is {
        @Parsed {
            false
        }
        @Failed {
            true
        }
    }
}
