// Test responsibility:
// Source/Compiler/Tests/Project/ManifestValidation/WFAssemblyRootPathErr/WFAssemblyRootPathErrTests.uv
//
// This file owns source-native tests for WF-Assembly-Root-Path-Err@L2469.

using UltravioletCompiler::Project::{ manifestAssemblyRootPathIsValid }

[[test(
    name: "manifest validation rejects absolute or escaping assembly roots",
    covers("WF-Assembly-Root-Path-Err@L2469")
)]]
internal procedure manifestValidationRejectsAbsoluteOrEscapingAssemblyRoots() -> bool
|: => @result
{
    return !manifestAssemblyRootPathIsValid("/Compiler") &&
        !manifestAssemblyRootPathIsValid("C:/Compiler") &&
        !manifestAssemblyRootPathIsValid("../Compiler")
}
