// Test responsibility:
// Source/Compiler/Tests/Project/ManifestValidation/WFTopKeysErr/WFTopKeysErrTests.uv
//
// This file owns source-native tests for WF-TopKeys-Err@L2628.

using UltravioletCompiler::Project::{
    ManifestValidationValue,
    emptyManifestAssemblies,
    manifestAssembly,
    manifestAssemblyListEntry,
    manifestWithTopKeyState,
    validateManifest
}

[[test(
    name: "manifest validation rejects unknown top keys",
    covers("WF-TopKeys-Err@L2628")
)]]
internal procedure manifestValidationRejectsUnknownTopKeys() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let validation: ManifestValidationValue = validateManifest(
            diagnostics_region,
            manifestWithTopKeyState(
                manifestAssemblyListEntry(
                    manifestAssembly("App", "executable", "", "Source/Tools/Uv"),
                    emptyManifestAssemblies()
                ),
                true
            )
        )

        passed = manifestValidationIsInvalid(validation)
    }
    return passed
}

internal procedure manifestValidationIsInvalid(
    validation: ManifestValidationValue
) -> bool {
    return if validation is {
        @Valid {
            false
        }
        @Invalid {
            true
        }
    }
}
