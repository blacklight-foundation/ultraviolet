using UltravioletCompiler::Project::{ manifestAssemblyRootPathIsValid }

[[test(
    name: "manifest validation accepts relative assembly roots",
    covers("WF-Assembly-Root-Path@L2451")
)]]
internal procedure manifestValidationAcceptsRelativeAssemblyRoots() -> bool
|: => @result
{
    return manifestAssemblyRootPathIsValid("Compiler") &&
        manifestAssemblyRootPathIsValid("Source/Tools/Uv")
}
