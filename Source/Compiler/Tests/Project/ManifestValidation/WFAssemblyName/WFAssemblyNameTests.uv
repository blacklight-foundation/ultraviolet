using UltravioletCompiler::Project::{ manifestAssemblyNameIsValid }

[[test(
    name: "manifest validation accepts identifier assembly names",
    covers("WF-Assembly-Name@L2358")
)]]
internal procedure manifestValidationAcceptsIdentifierAssemblyNames() -> bool
|: => @result
{
    return manifestAssemblyNameIsValid("UltravioletCompiler") &&
        manifestAssemblyNameIsValid("_Generated42")
}
