using UltravioletCompiler::Project::{ manifestAssemblyKindIsValid }

[[test(
    name: "manifest validation rejects undeclared assembly kinds",
    covers("WF-Assembly-Kind-Err@L2433")
)]]
internal procedure manifestValidationRejectsUndeclaredAssemblyKinds() -> bool
|: => @result
{
    return !manifestAssemblyKindIsValid("binary") &&
        !manifestAssemblyKindIsValid("")
}
