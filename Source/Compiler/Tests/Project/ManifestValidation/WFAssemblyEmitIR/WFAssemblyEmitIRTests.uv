// This file owns source-native tests for WF-Assembly-EmitIR@L2502.

using UltravioletCompiler::Project::{ manifestAssemblyEmitIRIsValid }

[[test(
    name: "manifest validation accepts declared emit_ir values",
    covers("WF-Assembly-EmitIR@L2502")
)]]
internal procedure manifestValidationAcceptsDeclaredEmitIRValues() -> bool
|: => @result
{
    return manifestAssemblyEmitIRIsValid("") &&
        manifestAssemblyEmitIRIsValid("none") &&
        manifestAssemblyEmitIRIsValid("ll") &&
        manifestAssemblyEmitIRIsValid("bc")
}
