// Test responsibility:
// Source/Compiler/Tests/Project/ManifestValidation/WFTopKeys/WFTopKeysTests.uv
//
// This file owns source-native tests for WF-TopKeys@L2610.

using UltravioletCompiler::Project::{
    ManifestValidationValue,
    emptyManifestAssemblies,
    manifestAssembly,
    manifestAssemblyListEntry,
    manifestWithTopKeyState,
    validateManifest
}

[[test(
    name: "manifest validation accepts only declared top keys",
    covers("WF-TopKeys@L2610")
)]]
internal procedure manifestValidationAcceptsOnlyDeclaredTopKeys() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let validation: ManifestValidationValue = validateManifest(
            diagnostics_region,
            manifestWithTopKeyState(
                manifestAssemblyListEntry(
                    manifestAssembly("App", "executable", "", "Source/Tools/Uv"),
                    emptyManifestAssemblies()
                ),
                false
            )
        )

        passed = manifestValidationIsValid(validation)
    }
    return passed
}

internal procedure manifestValidationIsValid(
    validation: ManifestValidationValue
) -> bool {
    return if validation is {
        @Valid {
            true
        }
        @Invalid {
            false
        }
    }
}
