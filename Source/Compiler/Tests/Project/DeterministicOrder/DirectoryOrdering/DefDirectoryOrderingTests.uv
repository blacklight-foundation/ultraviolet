// Test responsibility:
// Source/Compiler/Tests/Project/DeterministicOrder/DefDirectoryOrderingTests.uv
//
// This file owns source-native tests for def.DirectoryOrdering@L4209.

using UltravioletCompiler::Project::{
    AssemblyListValue,
    ModuleListValue,
    assembly,
    assemblyName,
    directoryPath,
    emptyAssemblies,
    emptyModules,
    emptySourceFiles,
    insertAssemblyOrdered,
    insertModuleOrdered,
    libraryAssemblyKind,
    module,
    modulePath,
    projectTextEquals,
    staticLinkKind
}

[[test(
    name: "module insertion orders by module path text",
    covers("def.DirectoryOrdering@L4209")
)]]
internal procedure moduleInsertionOrdersByModulePathText() -> bool
|: => @result
{
    let modules: ModuleListValue =
        insertModuleOrdered(
            module(
                modulePath("UltravioletCompiler::Tests::B"),
                directoryPath("Source/Compiler/Tests/B"),
                emptySourceFiles()
            ),
            insertModuleOrdered(
                module(
                    modulePath("UltravioletCompiler::Tests::A"),
                    directoryPath("Source/Compiler/Tests/A"),
                    emptySourceFiles()
                ),
                emptyModules()
            )
        )

    return moduleListStartsWith(modules, "UltravioletCompiler::Tests::A")
}

[[test(
    name: "assembly insertion orders by assembly name text",
    covers("def.DirectoryOrdering@L4209")
)]]
internal procedure assemblyInsertionOrdersByAssemblyNameText() -> bool
|: => @result
{
    let assemblies: AssemblyListValue =
        insertAssemblyOrdered(
            assembly(
                assemblyName("ZAssembly"),
                libraryAssemblyKind(),
                staticLinkKind(),
                directoryPath("Z"),
                emptyModules()
            ),
            insertAssemblyOrdered(
                assembly(
                    assemblyName("AAssembly"),
                    libraryAssemblyKind(),
                    staticLinkKind(),
                    directoryPath("A"),
                    emptyModules()
                ),
                emptyAssemblies()
            )
        )

    return assemblyListStartsWith(assemblies, "AAssembly")
}

internal procedure moduleListStartsWith(
    modules: ModuleListValue,
    expected_path: string@View
) -> bool {
    return if modules is {
        @Empty {
            false
        }
        @Entry { module: project_module } {
            projectTextEquals(project_module.path.text, expected_path)
        }
    }
}

internal procedure assemblyListStartsWith(
    assemblies: AssemblyListValue,
    expected_name: string@View
) -> bool {
    return if assemblies is {
        @Empty {
            false
        }
        @Entry { assembly: project_assembly } {
            projectTextEquals(project_assembly.name.text, expected_name)
        }
    }
}
