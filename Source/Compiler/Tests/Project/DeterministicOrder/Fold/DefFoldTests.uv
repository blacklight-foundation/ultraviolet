// Test responsibility:
// Source/Compiler/Tests/Project/DeterministicOrder/Fold/DefFoldTests.uv
//
// This file owns source-native tests for def.Fold@L4178.

using UltravioletCompiler::Project::{ projectFoldedTextLexicographicallyPrecedes }

[[test(
    name: "fold compares case-folded text",
    covers("def.Fold@L4178")
)]]
internal procedure foldComparesCaseFoldedText() -> bool
|: => @result
{
    return !projectFoldedTextLexicographicallyPrecedes("A", "a") &&
        !projectFoldedTextLexicographicallyPrecedes("a", "A") &&
        projectFoldedTextLexicographicallyPrecedes("a", "B")
}
