// Test responsibility:
// Source/Compiler/Tests/Project/DeterministicOrder/DefFileOrderingTests.uv
//
// This file owns source-native tests for def.FileOrdering@L4125.

using UltravioletCompiler::Project::{
    SourceFileListValue,
    emptySourceFiles,
    insertSourceFileOrdered,
    modulePath,
    projectTextEquals,
    sourceFile,
    sourceFilePath
}

[[test(
    name: "source file insertion orders by folded path text",
    covers("def.FileOrdering@L4125")
)]]
internal procedure sourceFileInsertionOrdersByFoldedPathText() -> bool
|: => @result
{
    let files: SourceFileListValue =
        insertSourceFileOrdered(
            sourceFile(
                sourceFilePath("Source/Compiler/Tests/b.uv"),
                modulePath("UltravioletCompiler::Tests"),
                0
            ),
            insertSourceFileOrdered(
                sourceFile(
                    sourceFilePath("Source/Compiler/Tests/A.uv"),
                    modulePath("UltravioletCompiler::Tests"),
                    1
                ),
                emptySourceFiles()
            )
        )

    return sourceFileListStartsWith(files, "Source/Compiler/Tests/A.uv")
}

[[test(
    name: "source file insertion uses original path as folded-key tiebreaker",
    covers("def.FileOrdering@L4125")
)]]
internal procedure sourceFileInsertionUsesOriginalPathAsFoldedKeyTiebreaker() -> bool
|: => @result
{
    let files: SourceFileListValue =
        insertSourceFileOrdered(
            sourceFile(
                sourceFilePath("Source/Compiler/Tests/a.uv"),
                modulePath("UltravioletCompiler::Tests"),
                0
            ),
            insertSourceFileOrdered(
                sourceFile(
                    sourceFilePath("Source/Compiler/Tests/A.uv"),
                    modulePath("UltravioletCompiler::Tests"),
                    0
                ),
                emptySourceFiles()
            )
        )

    return sourceFileListStartsWith(files, "Source/Compiler/Tests/A.uv")
}

internal procedure sourceFileListStartsWith(
    files: SourceFileListValue,
    expected_path: string@View
) -> bool {
    return if files is {
        @Empty {
            false
        }
        @Entry { file } {
            projectTextEquals(file.path.text, expected_path)
        }
    }
}
