// Test responsibility:
// Source/Compiler/Tests/Project/RootDiscovery/WFProjectRoot/WFProjectRootTests.uv
//
// This file owns source-native tests for WF-Project-Root@L3512:
//
// exists(`Ultraviolet.toml` at R)
// ───────────────────────────
// ⊢ R : ProjectRoot

using UltravioletCompiler::Project::{
    directoryPath,
    projectRootCandidate,
    projectRootCandidateIsWellFormed
}

[[test(
    name: "project root is well formed when manifest exists at root",
    covers("WF-Project-Root@L3512")
)]]
internal procedure projectRootIsWellFormedWhenManifestExistsAtRoot() -> bool
|: => @result
{
    return projectRootCandidateIsWellFormed(
        projectRootCandidate(directoryPath("C:/Dev/Ultraviolet"), true)
    )
}
