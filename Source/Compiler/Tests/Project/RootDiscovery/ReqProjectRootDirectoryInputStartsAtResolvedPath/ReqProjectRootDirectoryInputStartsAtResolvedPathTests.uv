// Test responsibility:
// Source/Compiler/Tests/Project/RootDiscovery/ReqProjectRootDirectoryInputStartsAtResolvedPath/ReqProjectRootDirectoryInputStartsAtResolvedPathTests.uv
//
// This file owns source-native tests for
// req.ProjectRootDirectoryInputStartsAtResolvedPath@L2331:
//
// otherwise the upward search MUST begin from the resolved path itself.

using UltravioletCompiler::Project::{
    directoryOrUnresolvedInputPath,
    projectRootSearchStart,
    projectTextEquals,
    resolvedInputPath
}

[[test(
    name: "directory input begins project-root search at resolved path",
    covers("req.ProjectRootDirectoryInputStartsAtResolvedPath@L2331")
)]]
internal procedure directoryInputBeginsSearchAtResolvedPath() -> bool
|: => @result
{
    let start = projectRootSearchStart(
        resolvedInputPath("C:/Dev/Ultraviolet/Compiler"),
        directoryOrUnresolvedInputPath()
    )

    return projectTextEquals(start.text, "C:/Dev/Ultraviolet/Compiler")
}
