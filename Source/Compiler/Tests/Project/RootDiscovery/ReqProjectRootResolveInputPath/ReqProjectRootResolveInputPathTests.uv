// Test responsibility:
// Source/Compiler/Tests/Project/RootDiscovery/ReqProjectRootResolveInputPath/ReqProjectRootResolveInputPathTests.uv
//
// This file owns source-native tests for req.ProjectRootResolveInputPath@L2281:
//
// When project loading begins from one command-line input path `p`, the
// implementation MUST first resolve any relative `p` against the host current
// working directory before searching upward for `Ultraviolet.toml`.

using UltravioletCompiler::Project::{
    CommandInputPathResolutionValue,
    commandInputPath,
    commandInputPathResolutionIsResolved,
    directoryPath,
    prepareCommandInputPathResolution,
    projectTextEquals
}

[[test(
    name: "relative project-root input requires host resolution before search",
    covers("req.ProjectRootResolveInputPath@L2281")
)]]
internal procedure relativeProjectRootInputRequiresResolutionBeforeSearch() -> bool
|: => @result
{
    let resolution: CommandInputPathResolutionValue =
        prepareCommandInputPathResolution(
            directoryPath("C:/Dev/Ultraviolet"),
            commandInputPath("Source/Compiler/Tests/Core/Path")
        )

    return if resolution is {
        @NeedsHostResolution { current_directory, input } {
            !commandInputPathResolutionIsResolved(resolution) &&
                projectTextEquals(current_directory.text, "C:/Dev/Ultraviolet") &&
                projectTextEquals(input.text, "Source/Compiler/Tests/Core/Path")
        }
        @Resolved {
            false
        }
    }
}

[[test(
    name: "absolute project-root input is already resolved for search",
    covers("req.ProjectRootResolveInputPath@L2281")
)]]
internal procedure absoluteProjectRootInputIsAlreadyResolvedForSearch() -> bool
|: => @result
{
    let resolution: CommandInputPathResolutionValue =
        prepareCommandInputPathResolution(
            directoryPath("C:/Dev/Ultraviolet"),
            commandInputPath("C:/Dev/Ultraviolet/Compiler")
        )

    return if resolution is {
        @NeedsHostResolution {
            false
        }
        @Resolved { resolved_path } {
            commandInputPathResolutionIsResolved(resolution) &&
                projectTextEquals(resolved_path.text, "C:/Dev/Ultraviolet/Compiler")
        }
    }
}
