// Test responsibility: Source/Compiler/Tests/Semantics/Attributes/TestAttributes/ReqTestAttributeProcedureTargetTests.uv
//
// This file owns source-native tests for req.TestAttributeProcedureTarget@L28768:
//
// `[[test]]` is valid only on ordinary source procedures.

[[test(
    name: "test attribute accepts ordinary procedure target",
    covers("req.TestAttributeProcedureTarget@L28768")
)]]
internal procedure testAttributeAcceptsOrdinaryProcedureTarget() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let parsed: AttributeParseResultValue = parseTestAttributeWithoutArguments()
        passed = if parsed is {
            @Parsed { attribute: parsed_attribute } {
                let check: TestAttributeSemanticCheckValue =
                    classifyTestProcedure(
                        diagnostics_region,
                        parsed_attribute,
                        ordinaryProcedureTestAttributeTarget(),
                        "UltravioletCompiler::Tests::Example::ordinaryTarget",
                        false
                    )
                if check is {
                    @Accepted {
                        true
                    }
                    @Rejected {
                        false
                    }
                }
            }
            @Rejected {
                false
            }
        }
    }
    return passed
}

[[test(
    name: "test attribute rejects non-procedure target",
    covers("req.TestAttributeProcedureTarget@L28768")
)]]
internal procedure testAttributeRejectsNonProcedureTarget() -> bool
|: => @result
{
    var passed: bool = false
    region as diagnostics_region {
        let parsed: AttributeParseResultValue = parseTestAttributeWithoutArguments()
        passed = if parsed is {
            @Parsed { attribute: parsed_attribute } {
                let check: TestAttributeSemanticCheckValue =
                    classifyTestProcedure(
                        diagnostics_region,
                        parsed_attribute,
                        invalidTestAttributeTarget(),
                        "UltravioletCompiler::Tests::Example::invalidTarget",
                        false
                    )
                if check is {
                    @Accepted {
                        false
                    }
                    @Rejected {
                        true
                    }
                }
            }
            @Rejected {
                false
            }
        }
    }
    return passed
}
