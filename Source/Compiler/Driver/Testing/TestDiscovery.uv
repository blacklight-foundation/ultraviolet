// Obligation responsibility: Source/Compiler/Driver/Testing/TestDiscovery.uv
//
// This file owns source-native test target resolution, test identity data, and
// deterministic discovery ordering:
//
// - lowering.TestHarnessGeneration@L28516
//   `uv test [target]` resolves an absent target, host path target, assembly
//   name, or module path into a test scope.
// - def.TestDiscoveryOrder@L28575
//   Selected tests are ordered by module path, source file order, declaration
//   span, then fully-qualified procedure symbol.

using UltravioletCompiler::Core::{
    SourceSpan
}
using UltravioletCompiler::Diagnostics::{
    CODE_TEST_UNKNOWN_TARGET,
    DiagnosticStreamValue,
    diagnosticStreamAppend,
    emptyDiagnosticStream,
    singleErrorDiagnosticStream,
    unknownCoverageReferenceDiagnostic,
    unknownTestTargetDiagnosticStream
}
using UltravioletCompiler::Project::{
    Assembly,
    AssemblyListValue,
    AssemblyName,
    DirectoryPath,
    ModulePath,
    Project,
    SourceFilePath,
    assemblyName,
    directoryPath,
    moduleListContainsPath,
    modulePath,
    projectTextEquals,
    projectTextSegmentEquals,
    projectTextStartsWith,
    sourceFilePath
}

public modal TestTargetCandidate {
    @Absent {
    }

    @ProjectRootPath {
        public path: DirectoryPath
    }

    @DirectoryPath {
        public path: DirectoryPath
    }

    @SourceFilePath {
        public path: SourceFilePath
    }

    @Text {
        public text: string@View
    }
}

public type TestTargetCandidateValue =
    TestTargetCandidate@Absent |
    TestTargetCandidate@ProjectRootPath |
    TestTargetCandidate@DirectoryPath |
    TestTargetCandidate@SourceFilePath |
    TestTargetCandidate@Text

public modal TestScope {
    @AllTests {
        public procedure includes(~, project: Project, test: DiscoveredTest) -> bool {
            return modulePathTextIsTestsSubtree(
                test.owning_assembly.text,
                test.module_path.text
            )
        }
    }

    @AssemblyTests {
        public assembly_name: AssemblyName

        public procedure includes(~, project: Project, test: DiscoveredTest) -> bool {
            return projectTextEquals(test.owning_assembly.text, self.assembly_name.text) &&
                modulePathTextIsTestsSubtree(
                    self.assembly_name.text,
                    test.module_path.text
                )
        }
    }

    @ModuleTests {
        public path: ModulePath

        public procedure includes(~, project: Project, test: DiscoveredTest) -> bool {
            return modulePathTextContains(test.module_path.text, self.path.text) &&
                modulePathTextIsTestsSubtree(
                    test.owning_assembly.text,
                    test.module_path.text
                )
        }
    }

    @SourceFileTests {
        public path: SourceFilePath

        public procedure includes(~, project: Project, test: DiscoveredTest) -> bool {
            return projectTextEquals(test.source_file.text, self.path.text) &&
                modulePathTextIsTestsSubtree(
                    test.owning_assembly.text,
                    test.module_path.text
                )
        }
    }

    @DirectoryTests {
        public path: DirectoryPath

        public procedure includes(~, project: Project, test: DiscoveredTest) -> bool {
            return sourceFileIsUnderDirectory(test.source_file, self.path) &&
                modulePathTextIsTestsSubtree(
                    test.owning_assembly.text,
                    test.module_path.text
                )
        }
    }
}

public type TestScopeValue =
    TestScope@AllTests |
    TestScope@AssemblyTests |
    TestScope@ModuleTests |
    TestScope@SourceFileTests |
    TestScope@DirectoryTests

public modal TestTargetResolution {
    @Resolved {
        public scope: TestScopeValue
    }

    @Unknown {
        public target_text: string@View
    }
}

public type TestTargetResolutionValue =
    TestTargetResolution@Resolved | TestTargetResolution@Unknown

public record TestProcedureSymbol {
    public text: string@View
}

public record TestDisplayName {
    public text: string@View
}

public record DiscoveredTest {
    public stable_identity: TestProcedureSymbol
    public display_name: TestDisplayName
    public owning_assembly: AssemblyName
    public module_path: ModulePath
    public source_file: SourceFilePath
    public source_file_order: usize
    public declaration_span: SourceSpan
    public procedure_symbol: TestProcedureSymbol
    public requires_context: bool
    public coverage_references: CoverageReferenceListValue
}

public modal DiscoveredTestList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public test: DiscoveredTest
        public tail: DiscoveredTestListValue

        public procedure count(~) -> usize {
            return 1 + discoveredTestListCount(self.tail)
        }
    }
}

public type DiscoveredTestListValue =
    DiscoveredTestList@Empty | DiscoveredTestList@Entry

public record TestSelection {
    public project: Project
    public scope: TestScopeValue
    public tests: DiscoveredTestListValue
}

public procedure absentTestTargetCandidate() -> TestTargetCandidateValue {
    return TestTargetCandidate@Absent {}
}

public procedure projectRootTestTargetCandidate(
    path: string@View
) -> TestTargetCandidateValue {
    return TestTargetCandidate@ProjectRootPath {
        path: directoryPath(path)
    }
}

public procedure directoryTestTargetCandidate(
    path: string@View
) -> TestTargetCandidateValue {
    return TestTargetCandidate@DirectoryPath {
        path: directoryPath(path)
    }
}

public procedure sourceFileTestTargetCandidate(
    path: string@View
) -> TestTargetCandidateValue {
    return TestTargetCandidate@SourceFilePath {
        path: sourceFilePath(path)
    }
}

public procedure textTestTargetCandidate(text: string@View) -> TestTargetCandidateValue {
    return TestTargetCandidate@Text { text: text }
}

public procedure allTestsScope() -> TestScopeValue {
    return TestScope@AllTests {}
}

public procedure assemblyTestsScope(assembly_name: AssemblyName) -> TestScopeValue {
    return TestScope@AssemblyTests { assembly_name: assembly_name }
}

public procedure moduleTestsScope(path: ModulePath) -> TestScopeValue {
    return TestScope@ModuleTests { path: path }
}

public procedure sourceFileTestsScope(path: SourceFilePath) -> TestScopeValue {
    return TestScope@SourceFileTests { path: path }
}

public procedure directoryTestsScope(path: DirectoryPath) -> TestScopeValue {
    return TestScope@DirectoryTests { path: path }
}

public procedure resolvedTestTarget(scope: TestScopeValue) -> TestTargetResolutionValue {
    return TestTargetResolution@Resolved { scope: scope }
}

public procedure unknownTestTarget(target_text: string@View) -> TestTargetResolutionValue {
    return TestTargetResolution@Unknown { target_text: target_text }
}

public procedure resolveTestTarget(
    project: Project,
    candidate: TestTargetCandidateValue
) -> TestTargetResolutionValue {
    return if candidate is {
        @Absent {
            resolvedTestTarget(allTestsScope())
        }
        @ProjectRootPath {
            resolvedTestTarget(allTestsScope())
        }
        @DirectoryPath { path } {
            resolvedTestTarget(directoryTestsScope(path))
        }
        @SourceFilePath { path } {
            resolvedTestTarget(sourceFileTestsScope(path))
        }
        @Text { text } {
            resolveTextTestTarget(project.assemblies, text)
        }
    }
}

internal procedure resolveTextTestTarget(
    assemblies: AssemblyListValue,
    text: string@View
) -> TestTargetResolutionValue {
    return if assemblies is {
        @Empty {
            unknownTestTarget(text)
        }
        @Entry { assembly: candidate_assembly, tail } {
            if (projectTextEquals(candidate_assembly.name.text, text)) {
                resolvedTestTarget(assemblyTestsScope(candidate_assembly.name))
            } else if (moduleListContainsPath(
                candidate_assembly.modules,
                modulePath(text)
            )) {
                resolvedTestTarget(moduleTestsScope(modulePath(text)))
            } else {
                resolveTextTestTarget(tail, text)
            }
        }
    }
}

public procedure testProcedureSymbol(text: string@View) -> TestProcedureSymbol {
    return TestProcedureSymbol { text: text }
}

public procedure testDisplayName(text: string@View) -> TestDisplayName {
    return TestDisplayName { text: text }
}

public procedure discoveredTest(
    stable_identity: TestProcedureSymbol,
    display_name: TestDisplayName,
    owning_assembly: AssemblyName,
    module_path: ModulePath,
    source_file: SourceFilePath,
    source_file_order: usize,
    declaration_span: SourceSpan,
    procedure_symbol: TestProcedureSymbol,
    requires_context: bool,
    move coverage_references: CoverageReferenceListValue
) -> DiscoveredTest {
    return DiscoveredTest {
        stable_identity: stable_identity,
        display_name: display_name,
        owning_assembly: owning_assembly,
        module_path: module_path,
        source_file: source_file,
        source_file_order: source_file_order,
        declaration_span: declaration_span,
        procedure_symbol: procedure_symbol,
        requires_context: requires_context,
        coverage_references: move coverage_references
    }
}

public procedure emptyDiscoveredTests() -> DiscoveredTestListValue {
    return DiscoveredTestList@Empty {}
}

public procedure discoveredTestListEntry(
    move test: DiscoveredTest,
    move tail: DiscoveredTestListValue
) -> DiscoveredTestListValue {
    return DiscoveredTestList@Entry {
        test: move test,
        tail: move tail
    }
}

public procedure insertDiscoveredTestOrdered(
    move test: DiscoveredTest,
    move tests: DiscoveredTestListValue
) -> DiscoveredTestListValue {
    return if tests is {
        @Empty {
            discoveredTestListEntry(move test, emptyDiscoveredTests())
        }
        @Entry { test: candidate_test, tail } {
            if (discoveredTestPrecedes(test, candidate_test)) {
                discoveredTestListEntry(
                    move test,
                    discoveredTestListEntry(move candidate_test, move tail)
                )
            } else {
                discoveredTestListEntry(
                    move candidate_test,
                    insertDiscoveredTestOrdered(move test, move tail)
                )
            }
        }
    }
}

public procedure sortDiscoveredTests(
    move tests: DiscoveredTestListValue
) -> DiscoveredTestListValue {
    return if tests is {
        @Empty {
            emptyDiscoveredTests()
        }
        @Entry { test, tail } {
            insertDiscoveredTestOrdered(move test, sortDiscoveredTests(move tail))
        }
    }
}

public procedure discoveredTestListCount(tests: DiscoveredTestListValue) -> usize {
    return if tests is {
        @Empty {
            tests~>count()
        }
        @Entry {
            tests~>count()
        }
    }
}

public procedure testSelection(
    move project: Project,
    move scope: TestScopeValue,
    move tests: DiscoveredTestListValue
) -> TestSelection {
    return TestSelection {
        project: move project,
        scope: move scope,
        tests: move tests
    }
}

public procedure selectDiscoveredTests(
    project: Project,
    scope: TestScopeValue,
    move tests: DiscoveredTestListValue
) -> DiscoveredTestListValue {
    return selectDiscoveredTestsByScope(project, scope, move tests)
}

internal procedure selectDiscoveredTestsByScope(
    project: Project,
    scope: TestScopeValue,
    move tests: DiscoveredTestListValue
) -> DiscoveredTestListValue {
    return if tests is {
        @Empty {
            emptyDiscoveredTests()
        }
        @Entry { test, tail } {
            let selected_tail: DiscoveredTestListValue =
                selectDiscoveredTestsByScope(project, scope, move tail)
            if (testScopeIncludes(scope, project, test)) {
                discoveredTestListEntry(move test, move selected_tail)
            } else {
                move selected_tail
            }
        }
    }
}

internal procedure testScopeIncludes(
    scope: TestScopeValue,
    project: Project,
    test: DiscoveredTest
) -> bool {
    return if scope is {
        @AllTests {
            scope~>includes(project, test)
        }
        @AssemblyTests { assembly_name } {
            scope~>includes(project, test)
        }
        @ModuleTests { path } {
            scope~>includes(project, test)
        }
        @SourceFileTests { path } {
            scope~>includes(project, test)
        }
        @DirectoryTests { path } {
            scope~>includes(project, test)
        }
    }
}

internal procedure sourceFileIsUnderDirectory(
    source_file: SourceFilePath,
    directory: DirectoryPath
) -> bool {
    return sourceFileTextIsUnderDirectory(source_file.text, directory.text)
}

internal procedure sourceFileTextIsUnderDirectory(
    source_file_text: string@View,
    directory_text: string@View
) -> bool {
    let directory_length: usize = string::length(directory_text)
    let source_length: usize = string::length(source_file_text)
    if (source_length < directory_length) {
        return false
    }
    if (!projectTextStartsWith(source_file_text, directory_text)) {
        return false
    }
    if (source_length == directory_length) {
        return true
    }
    return projectTextSegmentEquals(source_file_text, directory_length, "/")
}

internal procedure modulePathTextContains(
    candidate_text: string@View,
    prefix_text: string@View
) -> bool {
    let candidate_length: usize = string::length(candidate_text)
    let prefix_length: usize = string::length(prefix_text)
    if (candidate_length < prefix_length) {
        return false
    }
    if (!projectTextStartsWith(candidate_text, prefix_text)) {
        return false
    }
    if (candidate_length == prefix_length) {
        return true
    }
    return projectTextSegmentEquals(candidate_text, prefix_length, "::")
}

internal procedure modulePathTextIsTestsSubtree(
    assembly_name_text: string@View,
    module_path_text: string@View
) -> bool {
    let name_length: usize = string::length(assembly_name_text)
    let path_length: usize = string::length(module_path_text)
    let tests_length: usize = 5
    let prefix_length: usize = name_length + 2 + tests_length

    if (path_length < prefix_length) {
        return false
    }
    if (!projectTextStartsWith(module_path_text, assembly_name_text)) {
        return false
    }
    if (!projectTextSegmentEquals(module_path_text, name_length, "::")) {
        return false
    }
    if (!projectTextSegmentEquals(module_path_text, name_length + 2, "Tests")) {
        return false
    }
    if (path_length == prefix_length) {
        return true
    }
    return projectTextSegmentEquals(module_path_text, prefix_length, "::")
}

public procedure discoveredTestPrecedes(
    left: DiscoveredTest,
    right: DiscoveredTest
) -> bool {
    if (!projectTextEquals(left.module_path.text, right.module_path.text)) {
        return testTextLexicographicallyPrecedes(
            left.module_path.text,
            right.module_path.text
        )
    }
    if (left.source_file_order != right.source_file_order) {
        return left.source_file_order < right.source_file_order
    }
    if (left.declaration_span.start_line != right.declaration_span.start_line) {
        return left.declaration_span.start_line < right.declaration_span.start_line
    }
    if (left.declaration_span.start_column != right.declaration_span.start_column) {
        return left.declaration_span.start_column < right.declaration_span.start_column
    }
    return testTextLexicographicallyPrecedes(
        left.procedure_symbol.text,
        right.procedure_symbol.text
    )
}

internal procedure testTextLexicographicallyPrecedes(
    left: string@View,
    right: string@View
) -> bool {
    let left_length: usize = string::length(left)
    let right_length: usize = string::length(right)
    let common_length: usize = testMinLength(left_length, right_length)
    var index: usize = 0

    loop {
        if (index >= left_length) {
            break
        }
        if (index >= right_length) {
            break
        }

        let left_byte: u8 = testTextByte(left, index)
        let right_byte: u8 = testTextByte(right, index)
        if (left_byte < right_byte) {
            return true
        }
        if (left_byte > right_byte) {
            return false
        }
        index = index + 1
    }

    return left_length < right_length
}

internal procedure testMinLength(left: usize, right: usize) -> usize {
    if (left < right) {
        return left
    }
    return right
}

internal procedure testTextByte(text: string@View, index: usize) -> u8
|: index < string::length(text)
{
    let view: bytes@View = bytes::view_string(text)
    let data: const [u8] = bytes::as_slice(view)
    return data[index]
}
