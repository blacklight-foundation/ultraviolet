// Obligation responsibility: Source/Compiler/Driver/Testing/TestHarness.uv
//
// This file owns the source-native test harness plan and generation lifecycle:
//
// - lowering.TestHarnessGeneration@L28863
//   For each selected assembly, `uv test` generates an ephemeral harness under
//   that assembly's build output directory and compiles it through the ordinary
//   compiler path.

public record HarnessEntrySymbol {
    public text: string@View
}

public record HarnessPlan {
    public selected_assembly: Assembly
    public generated_harness_path: SourceFilePath
    public selected_tests: DiscoveredTestListValue
    public entry_symbol: HarnessEntrySymbol
}

public modal HarnessGeneration {
    @Planned {
        public selected_assembly: Assembly
        public selected_tests: DiscoveredTestListValue
        public entry_symbol: HarnessEntrySymbol

        public transition generated(
            generated_path: SourceFilePath
        ) -> @Generated {
            return HarnessGeneration@Generated {
                plan: HarnessPlan {
                    selected_assembly: move self.selected_assembly,
                    generated_harness_path: generated_path,
                    selected_tests: move self.selected_tests,
                    entry_symbol: move self.entry_symbol
                }
            }
        }
    }

    @Generated {
        public plan: HarnessPlan
    }

    @Failed {
        public selected_assembly: Assembly
        public selected_tests: DiscoveredTestListValue
        public entry_symbol: HarnessEntrySymbol
        public diagnostics: DiagnosticStreamValue
    }
}

public type HarnessGenerationValue =
    HarnessGeneration@Planned |
    HarnessGeneration@Generated |
    HarnessGeneration@Failed

public procedure harnessEntrySymbol(text: string@View) -> HarnessEntrySymbol {
    return HarnessEntrySymbol { text: text }
}

public procedure harnessPlan(
    move selected_assembly: Assembly,
    generated_harness_path: SourceFilePath,
    move selected_tests: DiscoveredTestListValue,
    entry_symbol: HarnessEntrySymbol
) -> HarnessPlan {
    return HarnessPlan {
        selected_assembly: move selected_assembly,
        generated_harness_path: generated_harness_path,
        selected_tests: move selected_tests,
        entry_symbol: entry_symbol
    }
}

public procedure plannedHarnessGeneration(
    move selected_assembly: Assembly,
    move selected_tests: DiscoveredTestListValue,
    entry_symbol: HarnessEntrySymbol
) -> HarnessGenerationValue {
    return HarnessGeneration@Planned {
        selected_assembly: move selected_assembly,
        selected_tests: move selected_tests,
        entry_symbol: entry_symbol
    }
}

public procedure generatedHarnessGeneration(move plan: HarnessPlan) -> HarnessGenerationValue {
    return HarnessGeneration@Generated { plan: move plan }
}

public procedure failedHarnessGeneration(
    move selected_assembly: Assembly,
    move selected_tests: DiscoveredTestListValue,
    entry_symbol: HarnessEntrySymbol,
    move diagnostics: DiagnosticStreamValue
) -> HarnessGenerationValue {
    return HarnessGeneration@Failed {
        selected_assembly: move selected_assembly,
        selected_tests: move selected_tests,
        entry_symbol: entry_symbol,
        diagnostics: move diagnostics
    }
}
