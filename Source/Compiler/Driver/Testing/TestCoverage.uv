// Support responsibility: Source/Compiler/Driver/Testing/TestCoverage.uv
//
// This file supports source-native test coverage validation against the
// obligation ledger. Primary extraction and static argument ownership lives in
// Source/Compiler/Semantics/Attributes/TestAttributes.uv:
//
// - def.TestCoverage@L28751
//   `covers(...)` entries are represented in source order.
// - def.TestAttributeArgsOk@L28782
//   Coverage references use the `obligation-id@Linternal_spec_line` shape.
// - diagnostics.TestAttributes@L28940
//   Malformed coverage references and unknown audit coverage references produce
//   distinct source-native test diagnostics through Diagnostics/Codes.uv and
//   Diagnostics/Emission.uv.

using UltravioletCompiler::Semantics::Attributes::{
    CoverageReference,
    CoverageReferenceListValue,
    CoverageReferenceShapeValue,
    coverageReferenceHasLedgerLine,
    emptyCoverageReferences,
    validateCoverageReferenceShape
}
using UltravioletCompiler::Diagnostics::{ malformedCoverageReferenceDiagnostic }

public modal CoverageCheck {
    @Satisfied {
    }

    @Failed {
        public diagnostics: DiagnosticStreamValue
    }
}

public type CoverageCheckValue =
    CoverageCheck@Satisfied | CoverageCheck@Failed

public procedure coverageReferencesHaveValidShape(
    diagnostics_region: unique Region@Active,
    move references: CoverageReferenceListValue
) -> CoverageCheckValue {
    let diagnostics: DiagnosticStreamValue =
        emptyDiagnosticStream(diagnostics_region)
    return coverageReferencesHaveValidShapeWithDiagnostics(
        diagnostics_region,
        move references,
        move diagnostics
    )
}

internal procedure coverageReferencesHaveValidShapeWithDiagnostics(
    diagnostics_region: unique Region@Active,
    move references: CoverageReferenceListValue,
    move diagnostics: DiagnosticStreamValue
) -> CoverageCheckValue {
    return if references is {
        @Empty {
            if (diagnosticStreamHasContent(diagnostics)) {
                CoverageCheck@Failed { diagnostics: move diagnostics }
            } else {
                CoverageCheck@Satisfied {}
            }
        }
        @Entry { reference, tail } {
            let shape: CoverageReferenceShapeValue =
                validateCoverageReferenceShape(reference)
            if shape is {
                @Valid {
                    coverageReferencesHaveValidShapeWithDiagnostics(
                        diagnostics_region,
                        move tail,
                        move diagnostics
                    )
                }
	        @Malformed {
	            let updated_diagnostics: DiagnosticStreamValue =
	                diagnosticStreamAppend(
	                    diagnostics_region,
	                    move diagnostics,
	                    malformedCoverageReferenceDiagnostic(reference.text)
	                )
	            coverageReferencesHaveValidShapeWithDiagnostics(
                        diagnostics_region,
                        move tail,
                        move updated_diagnostics
                    )
                }
            }
        }
    }
}

internal procedure diagnosticStreamHasContent(
    diagnostics: DiagnosticStreamValue
) -> bool {
    return if diagnostics is {
        @Empty {
            false
        }
        @Entry {
            true
        }
    }
}
