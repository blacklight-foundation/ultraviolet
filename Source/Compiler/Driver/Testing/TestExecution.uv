// Obligation responsibility: Source/Compiler/Driver/Testing/TestExecution.uv
//
// This file owns source-native test execution lifecycle data:
//
// - conformance.TestAttributeDynamicSemantics@L28495
//   Test procedure invocation is classified through Passed, Failed, and Error
//   outcomes after ordinary execution and postcondition checking.
// Source/Compiler/Driver/Testing/TestHarness.uv is the primary owner for
// lowering.TestHarnessGeneration@L28516. This file consumes harness plans while
// owning the execution classification rule above.

internal let TEST_DRIVER_PROJECT_MESSAGE: string@View =
    "source-native test execution requires project loading"

public record TestDriverRequest {
    public current_directory: string@View
    public executable_path: string@View
    public target: TestTargetCandidateValue
    public target_profile: string@View
    public output_mode: string@View
}

public modal TestDriverExecution {
    @ProjectRequired {
        public request: TestDriverRequest
    }

    @Rejected {
        public diagnostics: DiagnosticStreamValue
    }

    @Ready {
        public run: TestRunValue
    }
}

public type TestDriverExecutionValue =
    TestDriverExecution@ProjectRequired |
    TestDriverExecution@Rejected |
    TestDriverExecution@Ready

public modal TestRun {
    @Planned {
        public selection: TestSelection

        public transition harnessBuilt(
            move harness: HarnessPlan
        ) -> @HarnessBuilt {
            return TestRun@HarnessBuilt {
                selection: move self.selection,
                harness: move harness
            }
        }
    }

    @HarnessBuilt {
        public selection: TestSelection
        public harness: HarnessPlan

        public transition executableBuilt(
            executable_path: string@View
        ) -> @ExecutableBuilt {
            return TestRun@ExecutableBuilt {
                selection: move self.selection,
                harness: move self.harness,
                executable_path: executable_path
            }
        }
    }

    @ExecutableBuilt {
        public selection: TestSelection
        public harness: HarnessPlan
        public executable_path: string@View

        public transition running() -> @Running {
            return TestRun@Running {
                selection: move self.selection,
                harness: move self.harness,
                executable_path: move self.executable_path
            }
        }
    }

    @Running {
        public selection: TestSelection
        public harness: HarnessPlan
        public executable_path: string@View

        public transition completed(
            move results: TestResultListValue
        ) -> @Completed {
            return TestRun@Completed {
                selection: move self.selection,
                harness: move self.harness,
                executable_path: move self.executable_path,
                results: move results
            }
        }
    }

    @Completed {
        public selection: TestSelection
        public harness: HarnessPlan
        public executable_path: string@View
        public results: TestResultListValue
    }
}

public type TestRunValue =
    TestRun@Planned |
    TestRun@HarnessBuilt |
    TestRun@ExecutableBuilt |
    TestRun@Running |
    TestRun@Completed

public procedure testDriverRequest(
    current_directory: string@View,
    executable_path: string@View,
    move target: TestTargetCandidateValue,
    target_profile: string@View,
    output_mode: string@View
) -> TestDriverRequest {
    return TestDriverRequest {
        current_directory: current_directory,
        executable_path: executable_path,
        target: move target,
        target_profile: target_profile,
        output_mode: output_mode
    }
}

public procedure sourceNativeTestExecutionRequiresProject(
    move request: TestDriverRequest
) -> TestDriverExecutionValue {
    return TestDriverExecution@ProjectRequired { request: move request }
}

public procedure sourceNativeTestExecutionFromProject(
    diagnostics_region: unique Region@Active,
    move request: TestDriverRequest,
    move project: Project,
    move discovered_tests: DiscoveredTestListValue
) -> TestDriverExecutionValue {
    let resolution: TestTargetResolutionValue =
        resolveTestTarget(project, request.target)
    return if resolution is {
        @Unknown { target_text } {
            rejectedTestDriverExecution(
                unknownTestTargetDiagnosticStream(diagnostics_region, target_text)
            )
        }
        @Resolved { scope } {
            let selected_unsorted_tests: DiscoveredTestListValue =
                selectDiscoveredTests(project, scope, move discovered_tests)
            let selected_tests: DiscoveredTestListValue =
                sortDiscoveredTests(move selected_unsorted_tests)
            readyTestDriverExecution(
                plannedTestRun(
                    testSelection(
                        move project,
                        move scope,
                        move selected_tests
                    )
                )
            )
        }
    }
}

public procedure rejectedTestDriverExecution(
    move diagnostics: DiagnosticStreamValue
) -> TestDriverExecutionValue {
    return TestDriverExecution@Rejected { diagnostics: move diagnostics }
}

public procedure readyTestDriverExecution(move run: TestRunValue) -> TestDriverExecutionValue {
    return TestDriverExecution@Ready { run: move run }
}

public procedure plannedTestRun(move selection: TestSelection) -> TestRunValue {
    return TestRun@Planned { selection: move selection }
}

public procedure testDriverExecutionDiagnostics(
    diagnostics_region: unique Region@Active,
    move execution: TestDriverExecutionValue
) -> DiagnosticStreamValue {
    return if execution is {
        @ProjectRequired {
            singleErrorDiagnosticStream(
                diagnostics_region,
                CODE_TEST_UNKNOWN_TARGET,
                TEST_DRIVER_PROJECT_MESSAGE
            )
        }
        @Rejected { diagnostics } {
            move diagnostics
        }
        @Ready {
            singleErrorDiagnosticStream(
                diagnostics_region,
                CODE_TEST_UNKNOWN_TARGET,
                "test execution not completed"
            )
        }
    }
}
