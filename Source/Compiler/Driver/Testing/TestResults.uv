// Support responsibility: Source/Compiler/Driver/Testing/TestResults.uv
//
// This file owns source-native test result values and aggregate reporting data:
//
// Source/Compiler/Driver/Testing/TestExecution.uv is the primary owner for
// conformance.TestAttributeDynamicSemantics@L28495. This file supplies the
// value model used to report each classified result.

public modal TestOutcome {
    @Passed {
    }

    @Failed {
        public diagnostics: DiagnosticStreamValue
    }

    @Error {
        public diagnostics: DiagnosticStreamValue
    }
}

public type TestOutcomeValue =
    TestOutcome@Passed | TestOutcome@Failed | TestOutcome@Error

public record TestResult {
    public test: DiscoveredTest
    public outcome: TestOutcomeValue
}

public modal TestResultList {
    @Empty {
        public procedure count(~) -> usize {
            return 0
        }
    }

    @Entry {
        public result: TestResult
        public tail: TestResultListValue

        public procedure count(~) -> usize {
            return 1 + testResultListCount(self.tail)
        }
    }
}

public type TestResultListValue =
    TestResultList@Empty | TestResultList@Entry

public record TestResultSummary {
    public passed: usize
    public failed: usize
    public errors: usize
}

public procedure passedTestOutcome() -> TestOutcomeValue {
    return TestOutcome@Passed {}
}

public procedure failedTestOutcome(move diagnostics: DiagnosticStreamValue) -> TestOutcomeValue {
    return TestOutcome@Failed { diagnostics: move diagnostics }
}

public procedure errorTestOutcome(move diagnostics: DiagnosticStreamValue) -> TestOutcomeValue {
    return TestOutcome@Error { diagnostics: move diagnostics }
}

public procedure testResult(
    move test: DiscoveredTest,
    move outcome: TestOutcomeValue
) -> TestResult {
    return TestResult {
        test: move test,
        outcome: move outcome
    }
}

public procedure emptyTestResults() -> TestResultListValue {
    return TestResultList@Empty {}
}

public procedure testResultListEntry(
    move result: TestResult,
    move tail: TestResultListValue
) -> TestResultListValue {
    return TestResultList@Entry {
        result: move result,
        tail: move tail
    }
}

public procedure testResultListCount(results: TestResultListValue) -> usize {
    return if results is {
        @Empty {
            results~>count()
        }
        @Entry {
            results~>count()
        }
    }
}

public procedure emptyTestResultSummary() -> TestResultSummary {
    return testResultSummary(0, 0, 0)
}

public procedure testResultSummary(
    passed: usize,
    failed: usize,
    errors: usize
) -> TestResultSummary {
    return TestResultSummary {
        passed: passed,
        failed: failed,
        errors: errors
    }
}

public procedure summarizeTestResults(move results: TestResultListValue) -> TestResultSummary {
    return summarizeTestResultsFrom(move results, emptyTestResultSummary())
}

internal procedure summarizeTestResultsFrom(
    move results: TestResultListValue,
    summary: TestResultSummary
) -> TestResultSummary {
    return if results is {
        @Empty {
            summary
        }
        @Entry { result, tail } {
            summarizeTestResultsFrom(
                move tail,
                testResultSummaryWithOutcome(summary, move result.outcome)
            )
        }
    }
}

internal procedure testResultSummaryWithOutcome(
    summary: TestResultSummary,
    move outcome: TestOutcomeValue
) -> TestResultSummary {
    return if outcome is {
        @Passed {
            testResultSummary(summary.passed + 1, summary.failed, summary.errors)
        }
        @Failed {
            testResultSummary(summary.passed, summary.failed + 1, summary.errors)
        }
        @Error {
            testResultSummary(summary.passed, summary.failed, summary.errors + 1)
        }
    }
}
