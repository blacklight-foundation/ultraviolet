// Obligation responsibility: Source/Compiler/Driver/CLI/InitCommand.uv
//
// This file owns the `uv init` command entry procedure. It receives the parsed
// command arguments from the command modal and routes project initialization to
// the canonical project pipeline boundary.

public procedure executeInitCommand(
    host: DriverHost,
    diagnostics_region: unique Region@Active,
    arguments: CommandArguments
) -> CommandResultValue {
    let request: PipelineRequest = initPipelineRequest(
        host~>currentDirectory(),
        host~>executablePath(),
        arguments
    )
    let submission: PipelineSubmissionValue = submitPipelineRequest(request)
    return commandResultFromPipelineSubmission(diagnostics_region, submission)
}

public procedure initPipelineRequest(
    current_directory: string@View,
    executable_path: string@View,
    arguments: CommandArguments
) -> PipelineRequest {
    return pipelineRequest(
        current_directory,
        executable_path,
        pipelineTargetProfileFromInput(arguments.target_profile),
        pipelineOutputModeFromInput(arguments.output_mode),
        pipelineInitCommand()
    )
}
