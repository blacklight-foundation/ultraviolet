// Obligation responsibility: Source/Compiler/Driver/CLI/OptionValues.uv
//
// This file owns parsed CLI option value states for target profile and output
// mode. It also owns conversion from CLI option input into the driver-owned
// pipeline request value types.

internal let OPTION_TARGET_PROFILE: string@View = "--target-profile"
internal let OPTION_QUIET: string@View = "--quiet"
internal let OPTION_MACHINE_READABLE: string@View = "--machine-readable"

internal let TARGET_X86_64_SYSV: string@View = "x86_64-sysv"
internal let TARGET_X86_64_WIN64: string@View = "x86_64-win64"
internal let TARGET_AARCH64_AAPCS64: string@View = "aarch64-aapcs64"
internal let TARGET_DEFAULT: string@View = "default"
internal let OUTPUT_NORMAL: string@View = "normal"
internal let OUTPUT_QUIET: string@View = "quiet"
internal let OUTPUT_MACHINE_READABLE: string@View = "machine-readable"

public modal TargetProfileInput {
    @Absent {
    }

    @X8664SysV {
    }

    @X8664Win64 {
    }

    @Aarch64Aapcs64 {
    }

    @Unsupported {
        public text: string@View
    }
}

public type TargetProfileInputValue =
    TargetProfileInput@Absent |
    TargetProfileInput@X8664SysV |
    TargetProfileInput@X8664Win64 |
    TargetProfileInput@Aarch64Aapcs64 |
    TargetProfileInput@Unsupported

public modal OutputMode {
    @Normal {
    }

    @Quiet {
    }

    @MachineReadable {
    }
}

public type OutputModeValue =
    OutputMode@Normal |
    OutputMode@Quiet |
    OutputMode@MachineReadable

public procedure absentTargetProfile() -> TargetProfileInputValue {
    return TargetProfileInput@Absent {}
}

public procedure targetProfileFromText(text: string@View) -> TargetProfileInputValue {
    if (cliTextEquals(text, TARGET_X86_64_SYSV)) {
        return TargetProfileInput@X8664SysV {}
    }
    if (cliTextEquals(text, TARGET_X86_64_WIN64)) {
        return TargetProfileInput@X8664Win64 {}
    }
    if (cliTextEquals(text, TARGET_AARCH64_AAPCS64)) {
        return TargetProfileInput@Aarch64Aapcs64 {}
    }
    return TargetProfileInput@Unsupported { text: text }
}

public procedure normalOutputMode() -> OutputModeValue {
    return OutputMode@Normal {}
}

public procedure quietOutputMode() -> OutputModeValue {
    return OutputMode@Quiet {}
}

public procedure machineReadableOutputMode() -> OutputModeValue {
    return OutputMode@MachineReadable {}
}

public procedure pipelineTargetProfileFromInput(
    input: TargetProfileInputValue
) -> PipelineTargetProfileValue {
    return if input is {
        @Absent {
            pipelineDefaultTargetProfile()
        }
        @X8664SysV {
            pipelineX8664SysVTargetProfile()
        }
        @X8664Win64 {
            pipelineX8664Win64TargetProfile()
        }
        @Aarch64Aapcs64 {
            pipelineAarch64Aapcs64TargetProfile()
        }
        @Unsupported { text } {
            pipelineUnsupportedTargetProfile(text)
        }
    }
}

public procedure pipelineOutputModeFromInput(
    input: OutputModeValue
) -> PipelineOutputModeValue {
    return if input is {
        @Normal {
            pipelineNormalOutputMode()
        }
        @Quiet {
            pipelineQuietOutputMode()
        }
        @MachineReadable {
            pipelineMachineReadableOutputMode()
        }
    }
}

public procedure targetProfileInputText(input: TargetProfileInputValue) -> string@View {
    return if input is {
        @Absent {
            TARGET_DEFAULT
        }
        @X8664SysV {
            TARGET_X86_64_SYSV
        }
        @X8664Win64 {
            TARGET_X86_64_WIN64
        }
        @Aarch64Aapcs64 {
            TARGET_AARCH64_AAPCS64
        }
        @Unsupported { text } {
            text
        }
    }
}

public procedure outputModeText(input: OutputModeValue) -> string@View {
    return if input is {
        @Normal {
            OUTPUT_NORMAL
        }
        @Quiet {
            OUTPUT_QUIET
        }
        @MachineReadable {
            OUTPUT_MACHINE_READABLE
        }
    }
}
