// Obligation responsibility: Source/Compiler/Driver/CLI/TestCommand.uv
//
// This file owns `uv test` command coordination for the positional target model
// in lowering.TestHarnessGeneration@L28863. Target resolution, deterministic
// discovery, coverage validation, harness generation, execution, and result
// reporting are routed through their owning driver files.
//
// Relevant source-native test command rule:
//
// - lowering.TestHarnessGeneration@L28863
//   `uv test` uses an optional positional argument, resolves it to a test scope,
//   generates an ephemeral harness under the selected assembly build output, and
//   invokes selected tests in deterministic order.

import UltravioletCompiler::Driver::Testing
using UltravioletCompiler::Driver::Testing::{
    DiscoveredTestListValue,
    TestDriverExecutionValue,
    TestDriverRequest,
    TestTargetCandidateValue,
    absentTestTargetCandidate,
    directoryTestTargetCandidate,
    emptyDiscoveredTests,
    projectRootTestTargetCandidate,
    sourceFileTestTargetCandidate,
    sourceNativeTestExecutionFromProject,
    testDriverExecutionDiagnostics,
    testDriverRequest,
    textTestTargetCandidate
}
using UltravioletCompiler::Project::{
    Project,
    ProjectLoadValue,
    ProjectRoot,
    ProjectRootSearchValue,
    commandInputPath,
    directoryPath,
    findProjectRootFromHost,
    projectLoadFromHost,
    projectRootSearchRoot,
    projectRootSearchUsedManifest,
    projectTextEquals
}

internal let TEST_TARGET_ERROR_MESSAGE: string@View = "unknown uv test target"
internal let TEST_CURRENT_DIRECTORY_TEXT: string@View = "."

public modal TestTargetArgument {
    @Absent {
        public procedure isPresent(~) -> bool {
            return false
        }
    }

    @Present {
        public text: string@View

        public procedure isPresent(~) -> bool {
            return true
        }
    }
}

public type TestTargetArgumentValue =
    TestTargetArgument@Absent | TestTargetArgument@Present

public record TestCommandInput {
    public current_directory: string@View
    public target: TestTargetArgumentValue
    public target_profile: TargetProfileInputValue
    public output_mode: OutputModeValue

    public procedure hasTarget(~) -> bool {
        return testTargetArgumentIsPresent(self.target)
    }
}

public modal TestCommandInputResult {
    @Accepted {
        public input: TestCommandInput

        public procedure commandParseResult(~) -> CommandParseResultValue {
            return parsedCommand(Command@Test { input: self.input })
        }
    }

    @Rejected {
        public reason: CommandFailureReasonValue

        public procedure commandParseResult(~) -> CommandParseResultValue {
            return rejectedCommand(self.reason)
        }
    }
}

public type TestCommandInputResultValue =
    TestCommandInputResult@Accepted | TestCommandInputResult@Rejected

public procedure absentTestTarget() -> TestTargetArgumentValue {
    return TestTargetArgument@Absent {}
}

public procedure presentTestTarget(text: string@View) -> TestTargetArgumentValue {
    return TestTargetArgument@Present { text: text }
}

public procedure testTargetArgumentIsPresent(target: TestTargetArgumentValue) -> bool {
    return if target is {
        @Absent {
            target~>isPresent()
        }
        @Present {
            target~>isPresent()
        }
    }
}

public procedure testCommandInput(
    current_directory: string@View,
    target: TestTargetArgumentValue,
    target_profile: TargetProfileInputValue,
    output_mode: OutputModeValue
) -> TestCommandInput {
    return TestCommandInput {
        current_directory: current_directory,
        target: target,
        target_profile: target_profile,
        output_mode: output_mode
    }
}

public procedure testCommandInputFromArguments(
    current_directory: string@View,
    arguments: CommandArguments
) -> TestCommandInputResultValue {
    let positionals: PositionalArgumentsValue = arguments.positionals
    return if positionals is {
        @None {
            acceptedTestCommandInput(
                testCommandInput(
                    current_directory,
                    absentTestTarget(),
                    arguments.target_profile,
                    arguments.output_mode
                )
            )
        }
        @One {
            acceptedTestCommandInput(
                testCommandInput(
                    current_directory,
                    presentTestTarget(positionals.value),
                    arguments.target_profile,
                    arguments.output_mode
                )
            )
        }
        @TooMany {
            rejectedTestCommandInput(testTargetRejectedReason())
        }
    }
}

public procedure acceptedTestCommandInput(input: TestCommandInput) -> TestCommandInputResultValue {
    return TestCommandInputResult@Accepted { input: input }
}

public procedure rejectedTestCommandInput(
    reason: CommandFailureReasonValue
) -> TestCommandInputResultValue {
    return TestCommandInputResult@Rejected { reason: reason }
}

public procedure testTargetRejectedReason() -> CommandFailureReasonValue {
    return testTargetRejectedFailure(CODE_TEST_UNKNOWN_TARGET, TEST_TARGET_ERROR_MESSAGE)
}

public procedure testCommandParseResult(
    input_result: TestCommandInputResultValue
) -> CommandParseResultValue {
    return if input_result is {
        @Accepted {
            input_result~>commandParseResult()
        }
        @Rejected {
            input_result~>commandParseResult()
        }
    }
}

public procedure executeTestCommand(
    host: DriverHost,
    diagnostics_region: unique Region@Active,
    input: TestCommandInput
) -> CommandResultValue {
    let search: ProjectRootSearchValue = findProjectRootFromHost(
        host~>io(),
        directoryPath(input.current_directory),
        commandInputPath(TEST_CURRENT_DIRECTORY_TEXT)
    )
    if (!projectRootSearchUsedManifest(search)) {
        return commandFailed(diagnostics_region, testTargetRejectedReason())
    }

    let root: ProjectRoot = projectRootSearchRoot(search)
    let load: ProjectLoadValue =
        projectLoadFromHost(
            host~>io(),
            host~>heap(),
            diagnostics_region,
            root
        )
    return testCommandResultFromProjectLoad(
        host,
        diagnostics_region,
        input,
        root,
        move load
    )
}

internal procedure testCommandResultFromProjectLoad(
    host: DriverHost,
    diagnostics_region: unique Region@Active,
    input: TestCommandInput,
    root: ProjectRoot,
    move load: ProjectLoadValue
) -> CommandResultValue {
    return if load is {
        @Complete { project } {
            executeLoadedTestProject(
                host,
                diagnostics_region,
                input,
                root,
                move project
            )
        }
        @Failed { diagnostics } {
            commandFailedWithDiagnostics(move diagnostics)
        }
        @RootLocated {
            commandFailedWithDiagnostics(
                singleErrorDiagnosticStream(
                    diagnostics_region,
                    CODE_TEST_UNKNOWN_TARGET,
                    "project loading did not complete"
                )
            )
        }
        @ManifestParsed {
            commandFailedWithDiagnostics(
                singleErrorDiagnosticStream(
                    diagnostics_region,
                    CODE_TEST_UNKNOWN_TARGET,
                    "project loading did not complete"
                )
            )
        }
        @ManifestValidated {
            commandFailedWithDiagnostics(
                singleErrorDiagnosticStream(
                    diagnostics_region,
                    CODE_TEST_UNKNOWN_TARGET,
                    "project loading did not complete"
                )
            )
        }
        @AssembliesDiscovered {
            commandFailedWithDiagnostics(
                singleErrorDiagnosticStream(
                    diagnostics_region,
                    CODE_TEST_UNKNOWN_TARGET,
                    "project loading did not complete"
                )
            )
        }
    }
}

internal procedure executeLoadedTestProject(
    host: DriverHost,
    diagnostics_region: unique Region@Active,
    input: TestCommandInput,
    root: ProjectRoot,
    move project: Project
) -> CommandResultValue {
    let request: TestDriverRequest = testDriverRequest(
        input.current_directory,
        host~>executablePath(),
        testTargetCandidateFromArgument(host~>io(), root, input.target),
        targetProfileInputText(input.target_profile),
        outputModeText(input.output_mode)
    )
    let discovered_tests: DiscoveredTestListValue = emptyDiscoveredTests()
    let execution: TestDriverExecutionValue =
        sourceNativeTestExecutionFromProject(
            diagnostics_region,
            move request,
            move project,
            move discovered_tests
        )
    return commandFailedWithDiagnostics(
        testDriverExecutionDiagnostics(diagnostics_region, move execution)
    )
}

internal procedure testCommandRootInputText(target: TestTargetArgumentValue) -> string@View {
    return if target is {
        @Absent {
            TEST_CURRENT_DIRECTORY_TEXT
        }
        @Present { text } {
            text
        }
    }
}

internal procedure testTargetCandidateFromArgument(
    io: $IO,
    root: ProjectRoot,
    target: TestTargetArgumentValue
) -> TestTargetCandidateValue {
    return if target is {
        @Absent {
            absentTestTargetCandidate()
        }
        @Present { text } {
            testTargetCandidateFromPresentArgument(io, root, text)
        }
    }
}

internal procedure testTargetCandidateFromPresentArgument(
    io: $IO,
    root: ProjectRoot,
    text: string@View
) -> TestTargetCandidateValue {
    if (projectTextEquals(text, TEST_CURRENT_DIRECTORY_TEXT)) {
        return projectRootTestTargetCandidate(text)
    }
    if (projectTextEquals(text, root.text)) {
        return projectRootTestTargetCandidate(text)
    }

    let project_io: $IO = io~>restrict(root.text)
    let kind: Outcome<FileKind, IoError> = project_io~>kind(text)
    return if kind is {
        @Value { value } {
            if value is {
                FileKind::File {
                    sourceFileTestTargetCandidate(text)
                }
                FileKind::Dir {
                    directoryTestTargetCandidate(text)
                }
                FileKind::Other {
                    sourceFileTestTargetCandidate(text)
                }
            }
        }
        @Error {
            textTestTargetCandidate(text)
        }
    }
}
