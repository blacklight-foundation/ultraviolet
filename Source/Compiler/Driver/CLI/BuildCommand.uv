// Obligation responsibility: Source/Compiler/Driver/CLI/BuildCommand.uv
//
// This file owns the `uv build` command entry procedure. It receives the parsed
// command arguments from the command modal and routes build execution to the
// canonical project pipeline boundary.

public procedure executeBuildCommand(
    host: DriverHost,
    diagnostics_region: unique Region@Active,
    arguments: CommandArguments
) -> CommandResultValue {
    let request: PipelineRequest = buildPipelineRequest(
        host~>currentDirectory(),
        host~>executablePath(),
        arguments
    )
    let submission: PipelineSubmissionValue = submitPipelineRequest(request)
    return commandResultFromPipelineSubmission(diagnostics_region, submission)
}

public procedure buildPipelineRequest(
    current_directory: string@View,
    executable_path: string@View,
    arguments: CommandArguments
) -> PipelineRequest {
    return pipelineRequest(
        current_directory,
        executable_path,
        pipelineTargetProfileFromInput(arguments.target_profile),
        pipelineOutputModeFromInput(arguments.output_mode),
        pipelineBuildCommand()
    )
}
