// Obligation responsibility: Source/Compiler/Core/Path/Path.uv
//
// This file owns the public path value surface for project.path-resolution:
//
// - def.PathFunctionTypes@L3289
//   Join : Path x Path -> Path
//   Normalize : Path -> Path
//   Canon : Path partial Path

public record Path {
    private _storage: PathStorageValue
    private _components: PathComponentListValue
    private _kind: PathKindValue

    public procedure isAbsolute(~) -> bool {
        return pathKindIsAbsolute(self._kind)
    }

    public procedure isRelative(~) -> bool {
        return !self~>isAbsolute()
    }

    internal procedure componentCount(~) -> usize {
        return pathComponentListCount(self._components)
    }

    internal procedure componentAt(~, index: usize) -> PathComponentLookupValue {
        return pathComponentListAt(self._components, index)
    }

    internal procedure hasPrefix(~, candidate_prefix: Path) -> bool {
        return pathComponentListHasPrefix(self._components, candidate_prefix._components)
    }

    internal procedure containsParentTraversal(~) -> bool {
        return pathComponentListContainsParentTraversal(self._components)
    }

    internal procedure textEquals(~, text: string@View) -> bool {
        return pathComponentListTextEquals(self._components, text)
    }

    internal procedure basename(~) -> PathComponentView {
        return pathComponentListBasename(self._components)
    }

    internal procedure fileExtension(~) -> PathComponentView {
        return pathComponentListFileExtension(self._components)
    }

}

internal modal PathKind {
    @Absolute {
        internal procedure isAbsolute(~) -> bool {
            return true
        }
    }

    @Relative {
        internal procedure isAbsolute(~) -> bool {
            return false
        }
    }
}

internal type PathKindValue = PathKind@Absolute | PathKind@Relative

public record CanonicalPath {
    private _path: Path

    public procedure path(~) -> Path {
        return self._path
    }
}

internal procedure canonicalPathFromPath(move path: Path) -> CanonicalPath {
    return CanonicalPath { _path: move path }
}

public modal CanonicalPathResult {
    @Accepted {
        public canonical_path: CanonicalPath
    }

    @RejectedParentTraversal {
        public normalized_path: Path
    }
}

public type CanonicalPathResultValue =
    CanonicalPathResult@Accepted | CanonicalPathResult@RejectedParentTraversal

public modal RelativePathUnavailableReason {
    @PathRejectedParentTraversal {
    }

    @BaseRejectedParentTraversal {
    }

    @BaseNotPrefix {
    }
}

public type RelativePathUnavailableReasonValue =
    RelativePathUnavailableReason@PathRejectedParentTraversal |
    RelativePathUnavailableReason@BaseRejectedParentTraversal |
    RelativePathUnavailableReason@BaseNotPrefix

public record RelativePath {
    private _path: Path

    public procedure path(~) -> Path {
        return self._path
    }
}

internal procedure relativePathFromPath(move path: Path) -> RelativePath {
    return RelativePath { _path: move path }
}

public modal RelativePathResult {
    @Computed {
        public relative_path: RelativePath
    }

    @Unavailable {
        public reason: RelativePathUnavailableReasonValue
    }
}

public type RelativePathResultValue =
    RelativePathResult@Computed | RelativePathResult@Unavailable

internal procedure pathFromViewText(paths: unique Region@Active, text: string@View) -> Path {
    return pathFromPathText(paths, pathTextFromView(text))
}

public procedure pathFromManagedText(
    paths: unique Region@Active,
    move text: string@Managed
) -> Path {
    return pathFromPathText(paths, pathTextFromManaged(move text))
}

internal procedure pathFromPathText(paths: unique Region@Active, move text: PathTextValue) -> Path {
    let root: PathRootValue = classifyPathRoot(move text)
    let components: PathComponentListValue = pathComponentListFromRoot(paths, root)
    let kind: PathKindValue = pathKindFromRoot(root)
    let storage: PathStorageValue = textPathStorage(paths, move root)
    return pathFromParsedTextComponents(move storage, move components, move kind)
}

internal procedure pathFromParsedTextComponents(
    move storage: PathStorageValue,
    move components: PathComponentListValue,
    move kind: PathKindValue
) -> Path
{
    return Path {
        _storage: move storage,
        _components: move components,
        _kind: move kind
    }
}

internal procedure pathFromDerivedComponents(
    move storage: PathStorageValue,
    move components: PathComponentListValue
) -> Path
{
    let kind: PathKindValue = pathKindFromComponents(components)
    return Path {
        _storage: move storage,
        _components: move components,
        _kind: kind
    }
}

internal procedure pathComponents(path: Path) -> PathComponentListValue {
    return path._components
}

internal procedure pathComponentCount(path: Path) -> usize {
    return path~>componentCount()
}

internal procedure pathComponentAt(path: Path, index: usize) -> PathComponentLookupValue {
    return path~>componentAt(index)
}

internal procedure pathComponentEquals(path: Path, index: usize, text: string@View) -> bool {
    return pathComponentLookupEqualsText(pathComponentAt(path, index), text)
}

internal procedure absolutePathKind() -> PathKindValue {
    return PathKind@Absolute {}
}

internal procedure relativePathKind() -> PathKindValue {
    return PathKind@Relative {}
}

internal procedure pathKindFromRoot(root: PathRootValue) -> PathKindValue {
    if (pathRootIsAbsolute(root)) {
        return absolutePathKind()
    }
    return relativePathKind()
}

internal procedure pathKindFromComponents(components: PathComponentListValue) -> PathKindValue {
    if (pathComponentListIsAbsolute(components)) {
        return absolutePathKind()
    }
    return relativePathKind()
}

internal procedure pathKindIsAbsolute(kind: PathKindValue) -> bool {
    return if kind is {
        @Absolute {
            kind~>isAbsolute()
        }
        @Relative {
            kind~>isAbsolute()
        }
    }
}
